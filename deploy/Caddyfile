#
# Caddy reverse proxy for inflect-compliance.
# inflect.34-140-180-255.sslip.io is substituted by the deploy script once the VM's
# external IP is known (pattern: <ip-with-dashes>.sslip.io).
# Let's Encrypt issues a cert automatically on first request.
#

{
    # Use the production LE endpoint by default (default behaviour).
    # Set ACME_EMAIL in the env if you want certificate expiry mail.
    email {$ACME_EMAIL:admin@inflect.app}

    # Advertise HTTP/3 (QUIC) at the origin as well as h1/h2. Caddy emits
    # the Alt-Svc header automatically so direct-to-origin clients (no CDN
    # in front) negotiate h3; behind CloudFront the edge speaks h3 to the
    # viewer (see http_version in infra/terraform/modules/cdn/main.tf).
    servers {
        protocols h1 h2 h3
    }
}

inflect.34-140-180-255.sslip.io {
    encode gzip zstd

    # Client-body limit roughly matches FILE_MAX_SIZE_BYTES above.
    request_body {
        max_size 110MB
    }

    # Security headers.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        -Server
    }

    # Cache-Control for CDN origin pulls (CloudFront — see docs/cdn.md).
    # Caddy emits these on the origin response so the edge caches with the
    # right TTL. They are correct even with no CDN in front (browsers
    # cache the immutable hashed bundles locally too).
    @nextStatic path /_next/static/* /static/*
    header @nextStatic Cache-Control "public, max-age=31536000, immutable"

    @nextImage path /_next/image*
    header @nextImage Cache-Control "public, max-age=2592000"

    # Everything else (HTML shell + /api/*) carries auth context — never
    # cache it at the edge or in shared caches.
    @dynamic not path /_next/static/* /static/* /_next/image*
    header @dynamic Cache-Control "no-store"

    reverse_proxy app:3000 {
        # Ride out the brief unavailability window during a Watchtower image
        # swap (the new container runs `prisma migrate deploy` + the
        # self-assessment seed before `next start` listens on :3000). Without
        # this, Caddy returns 502 "connection refused" for those few seconds;
        # with it, Caddy retries the dial for up to 30s so deploys don't blip.
        lb_try_duration 30s
        lb_try_interval 250ms
        # Next.js sits behind the proxy — forward the original host so
        # NextAuth + server-side redirects resolve to the public URL.
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}
