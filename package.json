{
  "name": "inflect-compliance",
  "version": "1.402.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "postinstall": "patch-package",
    "prepare": "husky",
    "secret-scan": "bash scripts/detect-secrets.sh",
    "dev": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next dev",
    "build": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 tsx scripts/validate-env.ts && next build",
    "build:worker": "node scripts/build-worker.mjs",
    "start": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next start",
    "migrate:deploy": "prisma migrate deploy",
    "prod:local": "npm run migrate:deploy && npm run build && npm start",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed.ts",
    "db:bootstrap-owners": "tsx scripts/bootstrap-tenant-owners.ts",
    "db:backfill-org-widgets": "tsx scripts/backfill-org-dashboard-widgets.ts",
    "framework:import": "tsx scripts/framework-import.ts",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test tests/e2e/a11y.spec.ts",
    "test:ci": "jest --runInBand --no-coverage",
    "test:coverage": "jest --coverage",
    "test:all": "jest && playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=true eslint .",
    "count-any": "node scripts/count-any.js",
    "ci:local": "node scripts/ci-local.mjs",
    "e2e:local": "node scripts/e2e-local.mjs",
    "db:test:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "db:test:down": "docker compose -f docker-compose.test.yml down -v",
    "seed:staging": "tsx scripts/seed-staging.ts",
    "staging:up": "docker compose -f docker-compose.staging.yml up -d --build",
    "staging:down": "docker compose -f docker-compose.staging.yml down",
    "smoke:staging": "node scripts/smoke-staging.mjs",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "load:auth": "k6 run tests/load/auth.js",
    "load:lists": "k6 run tests/load/lists.js",
    "load:auth:50": "k6 run -e VUS=50 -e DURATION=2m tests/load/auth.js",
    "load:auth:100": "k6 run -e VUS=100 -e DURATION=2m tests/load/auth.js",
    "load:auth:200": "k6 run -e VUS=200 -e DURATION=2m tests/load/auth.js",
    "load:lists:50": "k6 run -e VUS=50 -e DURATION=2m tests/load/lists.js",
    "load:lists:100": "k6 run -e VUS=100 -e DURATION=2m tests/load/lists.js",
    "load:lists:200": "k6 run -e VUS=200 -e DURATION=2m tests/load/lists.js",
    "load:mutations": "k6 run tests/load/mutations.js",
    "load:mutations:smoke": "k6 run -e VUS=10 -e DURATION=30s -e RAMP_UP=5s -e RAMP_DOWN=5s tests/load/mutations.js",
    "load:mutations:50": "k6 run -e VUS=50 -e DURATION=2m tests/load/mutations.js",
    "load:mutations:100": "k6 run -e VUS=100 -e DURATION=2m tests/load/mutations.js",
    "load:mutations:200": "k6 run -e VUS=200 -e DURATION=2m tests/load/mutations.js",
    "load:smoke": "k6 run -e VUS=5 -e DURATION=30s tests/load/auth.js && k6 run -e VUS=5 -e DURATION=30s tests/load/lists.js",
    "prod:up": "docker compose -f docker-compose.prod.yml up -d --build",
    "prod:down": "docker compose -f docker-compose.prod.yml down"
  },
