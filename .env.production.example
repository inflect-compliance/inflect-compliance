# ─── Production Environment Variables ───────────────────────
# Copy to .env.production and fill in real values.
# Generate secrets: openssl rand -base64 32
# ────────────────────────────────────────────────────────────

# ── Database (Docker Compose sets DATABASE_URL from these) ──
POSTGRES_USER=inflect
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=inflect_production

# ── App ──
APP_PORT=3000
NEXTAUTH_URL=https://your-domain.com
AUTH_URL=https://your-domain.com

# ── Secrets (min 16 chars each, generate with openssl rand -base64 32) ──
AUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ── OAuth Providers ──
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common

# ── File Storage (set by Docker Compose, don't change) ──
UPLOAD_DIR=/data/uploads
FILE_STORAGE_ROOT=/data/uploads

# ── Data Encryption — REQUIRED (GAP-03) ──
# Master KEK that wraps every per-tenant DEK. Production boot will
# `process.exit(1)` if this is unset, shorter than 32 chars, or equal
# to the documented dev-fallback string.
# Generate with: openssl rand -base64 48
DATA_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_48
# Set ONLY during a master-KEK rotation (alongside the new
# DATA_ENCRYPTION_KEY). Remove once the rotation job reports zero
# remaining v1 rows under the previous key.
# DATA_ENCRYPTION_KEY_PREVIOUS=

# ── CORS (comma-separated origins) ──
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ── Redis — REQUIRED (GAP-13) ──
# Production cannot boot without a reachable Redis. Two layers
# enforce this:
#   1. Env-schema check in src/env.ts refuses to start the process
#      when REDIS_URL is unset under NODE_ENV=production. The same
#      check ALSO rejects an unauthenticated REDIS_URL — the URL
#      must carry a non-empty password.
#   2. /api/readyz (and the legacy /api/health alias) PING Redis on
#      every probe; a missing/broken Redis returns 503 → orchestrator
#      stops routing traffic.
#
# Why mandatory: rate limits (login brute-force, invite redemption,
# email dispatch), BullMQ job queue, and session/cache coordination
# all live in this Redis. Running production without it silently
# strips real security controls.
#
# ── REDIS_PASSWORD — REQUIRED for production-like compose ──
# docker-compose.prod.yml / .staging.yml run a local Redis container
# with `--requirepass "${REDIS_PASSWORD:?…}"`. Compose ABORTS at
# `up` time if this is unset — you MUST set it before deploying.
# The compose files build REDIS_URL from it automatically as
# redis://:${REDIS_PASSWORD}@redis:6379, so you do not normally
# also set REDIS_URL below in the compose path.
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=change-me

# Format: redis://:PASSWORD@HOST:6379  (or rediss:// for TLS).
# In the compose path the `app` service's `environment:` block builds
# REDIS_URL from REDIS_PASSWORD and overrides this value — leave it as
# is. Override it here ONLY when connecting to an EXTERNAL Redis
# (managed ElastiCache, Upstash) instead of the bundled container; in
# production it MUST be authenticated (carry a non-empty password).
REDIS_URL=redis://:CHANGE_ME@redis:6379

# ── Optional ──
# RATE_LIMIT_ENABLED=true   (default — keep ON in production)
# UPSTASH_REDIS_REST_URL=   (only when using Upstash REST instead of REDIS_URL)
# UPSTASH_REDIS_REST_TOKEN=

# ── Task-due notifications timezone ──
# IANA zone (DST-aware) for the daily task-due deadline cron. Sets
# BOTH the 08:00 firing time AND the "due today / tomorrow / in a
# week" calendar-day classification — one zone so a task due near
# local midnight is bucketed by the local day. Defaults to
# Europe/London if unset; must be a valid IANA zone name.
NOTIFICATIONS_TZ=Europe/London
