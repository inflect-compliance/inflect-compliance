# ─── Staging Environment Variables ──────────────────────────
# Copy this to .env.staging and fill in real values.
# ⚠️  Do NOT commit .env.staging — it contains secrets.
# ────────────────────────────────────────────────────────────

# ── Database (auto-configured by docker-compose.staging.yml) ──
# DATABASE_URL is set automatically via docker-compose environment.
# Only uncomment if connecting to an external DB:
# DATABASE_URL=postgresql://inflect:staging_password_change_me@localhost:5435/inflect_staging?schema=public

# ── Postgres container config ──
POSTGRES_USER=inflect
POSTGRES_PASSWORD=staging_password_change_me
POSTGRES_DB=inflect_staging

# ── Auth (REQUIRED — generate real secrets for staging) ──
# Generate with: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_staging_auth_secret_min_16_chars
JWT_SECRET=CHANGE_ME_staging_jwt_secret_min_16_chars
NEXTAUTH_SECRET=CHANGE_ME_staging_auth_secret_min_16_chars

# ── URLs ──
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# ── OAuth Providers (REQUIRED — use staging app credentials) ──
GOOGLE_CLIENT_ID=your-staging-google-client-id
GOOGLE_CLIENT_SECRET=your-staging-google-client-secret
MICROSOFT_CLIENT_ID=your-staging-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-staging-microsoft-client-secret
MICROSOFT_TENANT_ID=common

# ── File Storage (auto-configured as /data/uploads in Docker) ──
UPLOAD_DIR=/data/uploads
FILE_STORAGE_ROOT=/data/uploads

# ── Data Encryption — REQUIRED (GAP-03) ──
# Staging runs NODE_ENV=production and is treated as production for
# encryption-at-rest. Use a key DISTINCT from prod so a leak in one
# environment doesn't cascade.
# Generate with: openssl rand -base64 48
DATA_ENCRYPTION_KEY=CHANGE_ME_staging_data_encryption_key_distinct_from_prod
# Set ONLY during a master-KEK rotation.
# DATA_ENCRYPTION_KEY_PREVIOUS=

# ── Security ──
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Redis password — REQUIRED for the staging compose stack ──
# docker-compose.staging.yml runs Redis with
# `--requirepass "${REDIS_PASSWORD:?…}"` and builds REDIS_URL from it
# as redis://:${REDIS_PASSWORD}@redis:6379. Compose ABORTS at `up`
# time if this is unset — set it before deploying staging.
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=change-me

# ── Rate Limiting (optional) ──
# RATE_LIMIT_ENABLED=1
# RATE_LIMIT_MODE=memory

# ── Task-due notifications timezone (optional) ──
# IANA zone (DST-aware) for the daily task-due deadline cron — sets
# both the 08:00 firing time and the calendar-day classification.
# Defaults to Europe/London if unset.
NOTIFICATIONS_TZ=Europe/London

# ── Ports (optional overrides) ──
APP_PORT=3000
DB_PORT=5435

# ── Staging Seed ──
# Token for POST /api/staging/seed endpoint (generate with: openssl rand -hex 32)
STAGING_SEED_TOKEN=CHANGE_ME_generate_with_openssl_rand_hex_32
