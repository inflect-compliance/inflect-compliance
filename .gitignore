# Credential / sensitive dumps (should NEVER be versioned)
cred-list.txt

# V8 / Node profiling
*.heapsnapshot
*.cpuprofile
*.pid

# Claude Code runtime state
.claude/

# Terraform — runtime/state/plan artefacts must never land in git.
# The full set lives in infra/terraform/.gitignore; these root-level
# globs are a defence-in-depth against an operator running terraform
# commands from outside infra/terraform/ by mistake.
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
*.tfplan.*
*.secret.tfvars
*.secret.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# k6 load-test output (generated by `npm run load:*`).
# Summaries are also written to /tmp during CI; the local
# ./tests/load/results/ directory is purely a developer artefact
# and must never land in git.
tests/load/results/
