# Test outputs
# `/coverage/` root-anchored so it only matches Jest's coverage output
# directory. A bare `coverage/` rule would also swallow the real app
# feature directories `src/app/t/[tenantSlug]/(app)/coverage/` and
# `src/app/api/t/[tenantSlug]/coverage/` — which is how this file
# shadowing was masking a real build in CI.
/coverage/
test-results/
tests/load/results/
playwright-report/
blob-report/
# GAP-23: Playwright tenant-tracker (created by createIsolatedTenant,
# consumed by tests/e2e/global-teardown.ts). Per-run artefact.
tests/e2e/.tenant-tracker.jsonl
jest_out.json
jest_out_utf8.txt
jest-debug.txt
test-output*.json
test-out.txt
test-login.js
test_output.txt
test_result.json
test-results.json
test-results-json.txt
testall*.txt

# Playwright debug artifacts
pw-debug.json
pw-debug.txt
pw-*.json
pw-*.txt

# TSC / lint output dumps
tsc-*.txt
ts_check.txt
lint_output.txt

