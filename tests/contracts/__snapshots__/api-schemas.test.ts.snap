exports[`API contract — per-schema snapshots schema: ControlCreateRequest 1`] = `
"{
  "type": "object",
  "properties": {
    "code": {
      "type": [
        "string",
        "null"
      ]
    },
    "annexId": {
      "type": [
        "string",
        "null"
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "intent": {
      "type": [
        "string",
        "null"
      ]
    },
    "category": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "NOT_STARTED",
        "IN_PROGRESS",
        "IMPLEMENTED",
        "NEEDS_REVIEW"
      ],
      "default": "NOT_STARTED"
    },
    "frequency": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "AD_HOC",
        "DAILY",
        "WEEKLY",
        "MONTHLY",
        "QUARTERLY",
        "ANNUALLY",
        null
      ]
    },
    "ownerUserId": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidenceSource": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "MANUAL",
        "INTEGRATION",
        null
      ]
    },
    "automationKey": {
      "type": [
        "string",
        "null"
      ]
    },
    "automationType": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "AUTOMATED",
        "MANUAL",
        "IT_DEPENDENT_MANUAL",
        null
      ]
    },
    "mitigationType": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "PREVENTIVE",
        "DETECTIVE",
        "DETERRENT",
        "CORRECTIVE",
        "COMPENSATING",
        null
      ]
    },
    "isCustom": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name"
  ],
  "description": "Payload for creating a control. Status defaults to NOT_STARTED. annexId references the framework annex catalogue (e.g. ISO 27001:2022 A.5.1). Custom controls (isCustom=true) are tenant-specific; framework-shipped controls install via the templates endpoint instead."
}"
`;

