      "allOf": [
        {
          "$ref": "#/components/schemas/UserRefShort"
        },
        {
          "type": [
            "object",
            "null"
          ]
        }
      ]
    }
  },
  "required": [
    "id",
    "action",
    "details",
    "createdAt"
  ],
  "additionalProperties": {},
  "description": "A single audit-log row. Hash-chained at the DB layer; this DTO is the read view exposed via the audit/activity endpoints."
}"
`;

exports[`API contract — per-schema snapshots schema: AuditUpdateRequest 1`] = `
"{
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string"
    },
    "criteria": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "PLANNED",
        "IN_PROGRESS",
        "COMPLETED",
        "CANCELLED"
      ]
    },
    "auditors": {
      "type": [
        "string",
        "null"
      ]
    },
    "auditees": {
      "type": [
        "string",
        "null"
      ]
    },
    "checklistUpdates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": [
              "string",
              "null"
            ]
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "id"
        ]
      }
    }
  },
  "description": "Update an audit cycle including status transitions and checklist-row updates (per-row result + notes via checklistUpdates)."
}"
`;

