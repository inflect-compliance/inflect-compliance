// findings.prisma — Audit observation (Finding) + its risk/evidence junctions.
// Split from compliance.prisma (2026-07-10) — pure reorg, no datamodel change.
// Enums live in enums.prisma; relations resolve across the schema folder.

model Finding {
  id                    String            @id @default(cuid())
  tenantId              String
  auditId               String?
  severity              FindingSeverity
  type                  FindingType
  title                 String
  description           String
  rootCause             String?
  correctiveAction      String?
  // Free-text analyst notes / commentary on the finding. Encrypted at
  // rest (see encrypted-fields manifest).
  analysis              String?
  owner                 String?
  // Assignee — a tenant member accountable for the finding (supersedes
  // the legacy free-text `owner`).
  assigneeUserId        String?
  // The control this finding is raised against.
  controlId             String?
  // A compensating control that mitigates the finding.
  compensatingControlId String?
  dueDate               DateTime?
  status                FindingStatus     @default(OPEN)
  verificationNotes     String?
  verifiedBy            String?
  verifiedAt            DateTime?
  // Generic provenance tag — identifies findings auto-materialized from
  // a derived source (e.g. sourceKind='NIS2_SELF_ASSESSMENT',
  // sourceRef=<questionId>) so re-running the materializer is idempotent
  // and can reconcile (close on now-passing answers). NULL for
  // hand-raised findings.
  sourceKind            String?
  sourceRef             String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  deletedAt             DateTime?
  deletedByUserId       String?
  audit                 Audit?            @relation(fields: [auditId], references: [id])
  tenant                Tenant            @relation(fields: [tenantId], references: [id])
  assignee              User?             @relation("FindingAssignee", fields: [assigneeUserId], references: [id])
  control               Control?          @relation("FindingControl", fields: [controlId], references: [id], onDelete: SetNull)
  compensatingControl   Control?          @relation("FindingCompensatingControl", fields: [compensatingControlId], references: [id], onDelete: SetNull)
  evidenceLinks         FindingEvidence[]
  riskLinks             FindingRisk[]
  assetLinks            FindingAsset[]
  // TP-3 — remediation tasks auto-created from this finding (audit
  // checklist / NIS2 gap materializers). SetNull on this side.
  tasks                 Task[]            @relation("FindingTasks")

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, deletedAt])
  @@index([tenantId, auditId])
  @@index([tenantId, assigneeUserId])
  @@index([tenantId, controlId])
  @@index([tenantId, compensatingControlId])
  // Idempotent materializer lookup: findings for one derived source.
  @@index([tenantId, sourceKind, sourceRef])
}

// Many-to-many: a finding can implicate several risks. Composite parent
// FKs to (id, tenantId) guarantee both sides share this row's tenant —
// the FindingEvidence pattern. RLS + indexes mirror that junction.
model FindingRisk {
  id        String   @id @default(cuid())
  tenantId  String
  findingId String
  riskId    String
  createdAt DateTime @default(now())
  finding   Finding  @relation(fields: [findingId, tenantId], references: [id, tenantId], onDelete: Cascade)
  risk      Risk     @relation(fields: [riskId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([findingId, riskId])
  @@index([tenantId])
  @@index([tenantId, findingId])
  @@index([tenantId, riskId])
}

model FindingEvidence {
  // denorm-tenantId — Phase 2: junction with two composite parent
  // FKs. Each FK references its parent's (id, tenantId) unique
  // constraint, which transitively guarantees both parents share
  // this row's tenantId — strictly stronger than the previous
  // chained-RLS WITH CHECK (which was bypass-able by SECURITY
  // DEFINER paths or admin migrations).
  id         String   @id @default(cuid())
  tenantId   String
  findingId  String
  evidenceId String
  evidence   Evidence @relation(fields: [evidenceId, tenantId], references: [id, tenantId], onDelete: Cascade)
  finding    Finding  @relation(fields: [findingId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([findingId, evidenceId])
  @@index([tenantId])
  @@index([tenantId, findingId])
  @@index([tenantId, evidenceId])
}
