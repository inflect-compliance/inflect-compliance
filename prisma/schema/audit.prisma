// ─────────────────────────────────────────────────────────────────
//  GAP-09 — multi-file schema: AUDIT (cycles, packs, log)
//
//  Owns:
//    • AuditCycle + AuditPack + AuditPackItem + AuditPackShare
//    • AuditorAccess (external auditor RBAC tier)
//    • AuditLog (hash-chained immutable audit trail — Epic A.1)
//    • AuditStreamConfig (Epic C.4 — outbound webhook config per tenant)
//
//  Note: this is the EXTERNAL-AUDITOR domain — readiness scoring,
//  evidence packs shared with auditors, hash-chained event log.
//  Internal "audit-of-controls" tasks live with `Control*` in
//  `compliance.prisma` because they're written and read by the
//  compliance team, not auditors.
//
//  AuditLog policy:
//    • Append-only at the application layer (`logEvent`). Direct
//      writes are blocked by guard tests and DB triggers.
//    • Hash-chained (each row's hash includes the previous row's
//      hash). Schema changes here MUST preserve the chain layout.
//
//  This file is currently empty. Models will land here in a focused
//  follow-up PR.
// ─────────────────────────────────────────────────────────────────

model AuditLog {
  id                  String               @id @default(cuid())
  tenantId            String
  userId              String?
  entity              String
  entityId            String
  action              String
  details             String?
  createdAt           DateTime             @default(now())
  metadataJson        Json?
  recordIds           Json?
  requestId           String?
  diffJson            Json?
  actorType           String               @default("USER")
  detailsJson         Json?
  entryHash           String?
  previousHash        String?
  version             Int                  @default(1)
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  user                User?                @relation(fields: [userId], references: [id])
  /// Verified agent-action receipts linked to this hash-chained entry (Epic:
  /// agent-action-receipts). Back-relation only — adds no column to AuditLog.
  agentActionReceipts AgentActionReceipt[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, entity])
  @@index([tenantId, action])
  @@index([tenantId, entryHash])
}

// ─────────────────────────────────────────────────────────────────
// Epic B — Org Audit Trail & Compliance Integrity (SOC 2 CC6.1)
//
// Immutable, hash-chained ledger for org-level privilege changes.
// Distinct from AuditLog because:
//   • org events are NOT tenant-scoped — AuditLog requires tenantId
//     and uses a per-tenant chain anchored on
//     pg_advisory_xact_lock(hashtext(tenantId)). Forcing tenantId
//     nullable to host org events would break the load-bearing
//     chain semantics, the audit-stream batching, and the tenant
//     RLS policies on AuditLog.
//   • org chain is per-organization (one chain per org), keyed
//     independently from tenant chains.
//
// Append-only:
//   • DB trigger forbids UPDATE/DELETE (mirrors AuditLog).
//   • REVOKE UPDATE,DELETE FROM app_user; GRANT SELECT,INSERT.
//
// Hash chain:
//   • SHA-256(canonical(actorType, actorUserId, action, detailsJson,
//     occurredAt, organizationId, previousHash, targetUserId, version))
//   • previousHash links to entryHash of the prior row in this org's
//     chain. First entry per org has previousHash = null.
//
// Action taxonomy (OrgAuditAction enum):
//   ORG_MEMBER_ADDED                   — addOrgMember
//   ORG_MEMBER_REMOVED                 — removeOrgMember
//   ORG_MEMBER_ROLE_CHANGED            — changeOrgMemberRole
//   ORG_ADMIN_PROVISIONED_TO_TENANTS   — fan-out summary (one row,
//                                        not per tenant noise)
//   ORG_ADMIN_DEPROVISIONED_FROM_TENANTS — fan-in summary
//
// Provisioning fan-out is summarized as ONE org audit row carrying
// `{ tenantCount, tenantIds[], role: 'AUDITOR' }` in detailsJson.
// Per-tenant rows still land in AuditLog (existing behaviour) so
// each tenant's own ledger remains complete.
model OrgAuditLog {
  id             String         @id @default(cuid())
  organizationId String
  actorUserId    String?
  actorType      String         @default("USER")
  action         OrgAuditAction
  targetUserId   String?
  detailsJson    Json?
  requestId      String?
  occurredAt     DateTime       @default(now())
  entryHash      String
  previousHash   String?
  version        Int            @default(1)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation("OrgAuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  target       User?        @relation("OrgAuditLogTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, occurredAt])
  @@index([organizationId, action])
  @@index([organizationId, entryHash])
}

model Audit {
  id              String               @id @default(cuid())
  tenantId        String
  title           String
  // B8 — framework linkage. Audits now declare which compliance
  // framework they assess (ISO27001, NIS2, …). The string is the
  // Framework.key (not the FK id) so an Audit can survive a global
  // framework re-key without dangling. Nullable for legacy rows +
  // ad-hoc audits that span multiple frameworks. The Audit page
  // surfaces the linked Framework as a clickable header chip.
  frameworkKey    String?
  // feat/audit-cycle-unify — an Audit is a fieldwork phase WITHIN an
  // AuditCycle (the cycle is the spine). NULLABLE: standalone / ad-hoc
  // audits with no cycle must still work. Deleting a cycle SetNulls its
  // fieldwork audits (they survive as unattached audits, not cascade-
  // deleted). Mirrors AuditPack.cycle's single-key reference to
  // AuditCycle(id).
  auditCycleId    String?
  auditScope      String?
  criteria        String?
  schedule        DateTime?
  auditors        String?
  auditees        String?
  departments     String?
  status          AuditStatus          @default(PLANNED)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  auditCycle      AuditCycle?          @relation(fields: [auditCycleId], references: [id], onDelete: SetNull)
  checklist       AuditChecklistItem[]
  findings        Finding[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, frameworkKey])
  @@index([tenantId, auditCycleId])
  @@index([tenantId, deletedAt])
}

model AuditChecklistItem {
  // denorm-tenantId — Phase 2: see EvidenceReview for the shape.
  // Composite parent FK (auditId, tenantId) → Audit(id, tenantId).
  id          String          @id @default(cuid())
  tenantId    String
  auditId     String
  prompt      String
  result      ChecklistResult @default(NOT_TESTED)
  notes       String?
  evidenceRef String?
  sortOrder   Int             @default(0)
  audit       Audit           @relation(fields: [auditId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenant      Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, auditId])
}

model AuditCycle {
  id                 String              @id @default(cuid())
  tenantId           String
  frameworkKey       String
  frameworkVersion   String
  name               String
  periodStartAt      DateTime?
  periodEndAt        DateTime?
  status             AuditCycleStatus    @default(PLANNING)
  createdByUserId    String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  deletedByUserId    String?
  createdBy          User                @relation(fields: [createdByUserId], references: [id])
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  packs              AuditPack[]
  // feat/audit-cycle-unify — fieldwork audits attached to this cycle.
  audits             Audit[]
  readinessSnapshots ReadinessSnapshot[]

  @@index([tenantId, frameworkKey, status])
  @@index([tenantId, deletedAt])
}

model AuditPack {
  id              String                  @id @default(cuid())
  tenantId        String
  auditCycleId    String
  name            String
  status          AuditPackStatus         @default(DRAFT)
  frozenAt        DateTime?
  frozenByUserId  String?
  notes           String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  /// SP-5 — last SharePoint export of this (frozen) pack.
  spExportItemId  String?
  spExportWebUrl  String?
  spExportedAt    DateTime?
  cycle           AuditCycle              @relation(fields: [auditCycleId], references: [id])
  frozenBy        User?                   @relation("AuditPackFrozenBy", fields: [frozenByUserId], references: [id])
  tenant          Tenant                  @relation(fields: [tenantId], references: [id])
  items           AuditPackItem[]
  shares          AuditPackShare[]
  auditorAccess   AuditorPackAccess[]
  shareComments   AuditPackShareComment[]

  @@unique([id, tenantId])
  @@index([tenantId, auditCycleId])
  @@index([tenantId, deletedAt])
}

model AuditPackItem {
  id            String                  @id @default(cuid())
  tenantId      String
  auditPackId   String
  entityType    AuditPackItemEntityType
  entityId      String
  snapshotJson  String
  sortOrder     Int                     @default(0)
  createdAt     DateTime                @default(now())
  pack          AuditPack               @relation(fields: [auditPackId], references: [id], onDelete: Cascade)
  tenant        Tenant                  @relation(fields: [tenantId], references: [id])
  shareComments AuditPackShareComment[]

  @@unique([auditPackId, entityType, entityId])
  @@index([tenantId, auditPackId])
}

model AuditPackShare {
  id              String                  @id @default(cuid())
  tenantId        String
  auditPackId     String
  tokenHash       String
  expiresAt       DateTime?
  createdByUserId String
  revokedAt       DateTime?
  createdAt       DateTime                @default(now())
  pack            AuditPack               @relation(fields: [auditPackId], references: [id])
  createdBy       User                    @relation(fields: [createdByUserId], references: [id])
  tenant          Tenant                  @relation(fields: [tenantId], references: [id])
  comments        AuditPackShareComment[]

  @@index([tokenHash])
  @@index([tenantId, auditPackId])
}

// feat/auditor-return-channel — the RETURN CHANNEL that closes the
// audit-pack sharing loop. Today an external auditor opens a shared
// pack read-only via a token; this table lets them send messages BACK
// to the tenant (comment / request more evidence / raise a finding or
// question). A single table with a `kind` discriminator serves all four.
//
//   • `body` is auditor-authored FREE TEXT → encrypted at rest via the
//     Epic B manifest (`src/lib/security/encrypted-fields.ts`) and
//     sanitised on write via `sanitizePlainText`.
//   • `authorLabel` is the external auditor's self-supplied display
//     name/email captured from the share session — NOT a User FK
//     (the auditor has no platform account).
//   • `auditPackShareId` records WHICH share session produced the row.
//   • `auditPackItemId` is optional — set when the auditor comments on a
//     specific pack item rather than the pack as a whole.
//   • `status` is OPEN until a tenant user resolves an actionable row
//     (EVIDENCE_REQUEST / FINDING / QUESTION); `resolvedByUserId` is the
//     tenant user who did so.
model AuditPackShareComment {
  id               String                  @id @default(cuid())
  tenantId         String
  auditPackId      String
  auditPackShareId String
  auditPackItemId  String?
  kind             AuditShareCommentKind   @default(COMMENT)
  body             String
  authorLabel      String
  status           AuditShareCommentStatus @default(OPEN)
  createdAt        DateTime                @default(now())
  resolvedAt       DateTime?
  resolvedByUserId String?

  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  pack       AuditPack      @relation(fields: [auditPackId], references: [id], onDelete: Cascade)
  share      AuditPackShare @relation(fields: [auditPackShareId], references: [id], onDelete: Cascade)
  item       AuditPackItem? @relation(fields: [auditPackItemId], references: [id], onDelete: SetNull)
  resolvedBy User?          @relation("AuditPackShareCommentResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, auditPackId])
  @@index([auditPackId])
  @@index([auditPackShareId])
  @@index([auditPackItemId])
}

model AuditorAccount {
  id         String              @id @default(cuid())
  tenantId   String
  // GAP-21: stored encrypted at rest. Lookup uniqueness is enforced
  // on (tenantId, emailHash) — the random-IV ciphertext column
  // cannot anchor uniqueness on its own.
  // `emailHash` is nullable in TS (middleware populates) / NOT NULL
  // in DB (migration enforced). Same drift pattern as User.emailHash
  // — see that comment for rationale.
  email      String              @map("emailEncrypted")
  emailHash  String?
  name       String?             @map("nameEncrypted")
  status     AuditorStatus       @default(INVITED)
  createdAt  DateTime            @default(now())
  tenant     Tenant              @relation(fields: [tenantId], references: [id])
  packAccess AuditorPackAccess[]

  @@unique([id, tenantId])
  @@unique([tenantId, emailHash])
}

model AuditorPackAccess {
  // denorm-tenantId — Phase 2: junction with two composite parent
  // FKs. See FindingEvidence for the rationale.
  id          String         @id @default(cuid())
  tenantId    String
  auditorId   String
  auditPackId String
  grantedAt   DateTime       @default(now())
  pack        AuditPack      @relation(fields: [auditPackId, tenantId], references: [id, tenantId])
  auditor     AuditorAccount @relation(fields: [auditorId, tenantId], references: [id, tenantId])
  tenant      Tenant         @relation(fields: [tenantId], references: [id])

  @@unique([auditorId, auditPackId])
  @@index([tenantId])
  @@index([tenantId, auditPackId])
  @@index([tenantId, auditorId])
}

/// Persisted time-series snapshot of a readiness computation
/// (Audit Coherence S5, 2026-05-22). Every `computeReadiness` call
/// writes one row so auditors can see the trend over time
/// ("readiness improved from 62% → 84% over 6 months").
///
/// Pre-this-model, readiness was a point-in-time computation only;
/// historic scores existed only inside audit packs (a heavy
/// artefact, not a chartable time series). This model gives the
/// dashboard a cheap source for the readiness-over-time chart.
model ReadinessSnapshot {
  id               String   @id @default(cuid())
  tenantId         String
  /// Which framework was scored. Free string so custom frameworks
  /// (handled by the GENERIC fallback in `audit-readiness-scoring.ts`)
  /// can persist their key here too.
  frameworkKey     String
  /// Audit cycle the snapshot was computed for. NULL when computed
  /// outside a cycle (a tenant-admin "current state" pull).
  auditCycleId     String?
  /// 0-100 weighted score (rounded to integer to match the API).
  score            Int
  /// Full ReadinessBreakdown payload as written by the scoring
  /// engine. Read-side joins this for the trend chart's tooltips.
  breakdownJson    Json
  /// Count of gaps at snapshot time — surfaces in the chart's
  /// per-point tooltip without re-loading the breakdown.
  gapCount         Int      @default(0)
  computedAt       DateTime @default(now())
  /// Caller — NULL for cron-driven sweeps (none today; reserved).
  computedByUserId String?

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  auditCycle AuditCycle? @relation(fields: [auditCycleId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, frameworkKey, computedAt])
  @@index([tenantId, auditCycleId])
}
