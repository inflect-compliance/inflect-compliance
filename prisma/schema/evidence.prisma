// evidence.prisma — Evidence hub, its backing file records, and reviews.
// Split from compliance.prisma (2026-07-10) — pure reorg, no datamodel change.
// Enums live in enums.prisma; relations resolve across the schema folder.

model Evidence {
  id                  String                    @id @default(cuid())
  tenantId            String
  // EP-3 — evidence↔control is now many-to-many via EvidenceControlLink.
  // Re-uploading the same artifact to N controls used to clone N Evidence
  // rows (singular `controlId`); one Evidence + N join rows is the fix.
  // Source task — set when this evidence was uploaded/linked from a
  // task's Evidence tab. Powers the task Evidence tab AND the
  // "uploaded from" back-reference on the evidence detail surface.
  taskId              String?
  // Source risk / asset — same pattern as taskId: set when uploaded
  // from that entity's Evidence tab; powers the attached-evidence tab
  // + the "uploaded from" back-reference.
  riskId              String?
  assetId             String?
  type                EvidenceType
  title               String
  content             String?
  fileName            String?
  fileSize            Int?
  category            String?
  dateCollected       DateTime                  @default(now())
  owner               String? // Legacy free-text — kept for backward compat
  ownerUserId         String? // Real user FK — used for due-item routing & notifications
  reviewCycle         ReviewCadence?
  nextReviewDate      DateTime?
  status              EvidenceStatus            @default(DRAFT)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  deletedAt           DateTime?
  deletedByUserId     String?
  fileRecordId        String?
  // EP-3 Part 4 — file-version lineage. `replaceEvidenceFile` points
  // `fileRecordId` at a fresh FileRecord and bumps `fileVersion` so the
  // Evidence row (status/review/retention/links) is preserved instead of
  // spawning a new record. Prior FileRecords chain via
  // FileRecord.previousFileRecordId.
  fileVersion         Int                       @default(1)
  expiredAt           DateTime?
  isArchived          Boolean                   @default(false)
  retentionDays       Int?
  retentionPolicy     RetentionPolicy           @default(NONE)
  retentionUntil      DateTime?
  /// B8 follow-up — free-text folder label (e.g. "SOC2/2026" or
  /// "Quarterly access reviews"). Mirrors the `VendorDocument.folder`
  /// pattern. Nullable; null/empty maps to "no folder" in the UI.
  /// Sanitised + trimmed at the usecase boundary.
  folder              String?
  testEvidenceLinks   ControlTestEvidenceLink[]
  policyEvidenceItems PolicyEvidenceItem[]
  // Epic G-3 — vendor questionnaire FILE_UPLOAD answers attach
  // their proof here.
  vendorAnswers       VendorAssessmentAnswer[]  @relation("VendorAnswerEvidence")
  // EP-3 — the join replaces the singular `control` relation.
  evidenceControlLinks EvidenceControlLink[]
  task                Task?                     @relation(fields: [taskId], references: [id])
  risk                Risk?                     @relation(fields: [riskId], references: [id])
  asset               Asset?                    @relation(fields: [assetId], references: [id])
  fileRecord          FileRecord?               @relation(fields: [fileRecordId], references: [id])
  ownerUser           User?                     @relation("EvidenceOwner", fields: [ownerUserId], references: [id])
  tenant              Tenant                    @relation(fields: [tenantId], references: [id])
  reviews             EvidenceReview[]
  findingLinks        FindingEvidence[]
  incidentLinks       IncidentEvidence[]
  reminderHistories   ReminderHistory[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, deletedAt])
  @@index([tenantId, retentionUntil])
  @@index([tenantId, isArchived])
  @@index([tenantId, ownerUserId])
  // GAP-perf — supports `status` filter (DRAFT|SUBMITTED|APPROVED|REJECTED).
  @@index([tenantId, status])
  // EP-4 — backs the tenant-wide retention/KPI aggregate
  // (getEvidenceRetentionMetrics): groupBy(status) + the expiry/freshness
  // bucket counts keyed on status + expiredAt over the FULL dataset.
  @@index([tenantId, status, expiredAt])
  // Supports the task Evidence tab ("evidence for task X") + the
  // evidence "uploaded from" back-reference lookup.
  @@index([tenantId, taskId])
  // Same, for the risk + asset Evidence tabs.
  @@index([tenantId, riskId])
  @@index([tenantId, assetId])
  // GAP-perf — supports `type` filter (FILE|LINK|TEXT|SCREENSHOT).
  @@index([tenantId, type])
  // B8 follow-up — supports folder filter + group-by reads. Same
  // shape as VendorDocument's folder index.
  @@index([tenantId, folder])
}

model FileRecord {
  id               String           @id @default(cuid())
  tenantId         String
  pathKey          String           @unique
  originalName     String
  mimeType         String
  sizeBytes        Int
  sha256           String
  status           FileRecordStatus @default(PENDING)
  uploadedByUserId String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  storedAt         DateTime?
  bucket           String?
  domain           String           @default("general")
  scanStatus       String           @default("PENDING")
  storageProvider  String           @default("local")
  scanDetails      String?
  scannedAt        DateTime?
  deletedAt        DateTime?
  deletedByUserId  String?
  retentionUntil   DateTime?
  // EP-3 Part 4 — file-version lineage. When evidence's file is replaced
  // the new FileRecord points back at the one it superseded, so a doc's
  // history is a walkable chain rather than an orphaned unrelated row.
  previousFileRecordId String?
  previousFileRecord   FileRecord?  @relation("FileRecordVersion", fields: [previousFileRecordId], references: [id])
  supersededBy         FileRecord[] @relation("FileRecordVersion")
  evidence         Evidence[]
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  uploadedBy       User             @relation("FileUploader", fields: [uploadedByUserId], references: [id])
  // Epic G-4 — campaigns whose evidence PDF this row carries.
  accessReviews    AccessReview[]   @relation("AccessReviewEvidence")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, scanStatus])
  @@index([tenantId, deletedAt])
  @@index([tenantId, previousFileRecordId])
}

model EvidenceReview {
  // denorm-tenantId — Phase 2: tenantId is NOT NULL and the parent
  // relation is composite (evidenceId, tenantId) → Evidence(id,
  // tenantId), which structurally guarantees this row's tenantId
  // matches its parent's. Phase 3 swaps the chained RLS policy for
  // the trivial direct form.
  id         String       @id @default(cuid())
  tenantId   String
  evidenceId String
  reviewerId String
  action     ReviewAction
  comment    String?
  createdAt  DateTime     @default(now())
  evidence   Evidence     @relation(fields: [evidenceId, tenantId], references: [id, tenantId], onDelete: Cascade)
  reviewer   User         @relation(fields: [reviewerId], references: [id])
  tenant     Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, evidenceId])
}

// EP-3 — many-to-many join between an Evidence record and the Controls it
// satisfies. Replaces the singular `Evidence.controlId` (which cloned an
// Evidence row per control). The Evidence entity is the single source of
// truth for evidence-entity↔control associations; ControlEvidenceLink
// (controls.prisma) is retained ONLY for non-Evidence artifacts
// (url / integrationResult / bia). The composite FK to Evidence(id,
// tenantId) chains RLS through the parent, matching EvidenceReview.
model EvidenceControlLink {
  id              String   @id @default(cuid())
  tenantId        String
  evidenceId      String
  controlId       String
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  evidence        Evidence @relation(fields: [evidenceId, tenantId], references: [id, tenantId], onDelete: Cascade)
  control         Control  @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy       User?    @relation("EvidenceControlLinkCreator", fields: [createdByUserId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, evidenceId, controlId])
  @@index([tenantId, controlId])
  @@index([tenantId, evidenceId])
}
