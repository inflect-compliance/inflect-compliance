// ─────────────────────────────────────────────────────────────────
//  GAP-09 — multi-file schema: COMPLIANCE
//
//  Core compliance domain. Owns:
//    • Control + ControlEvidenceLink + ControlContributor +
//      ControlTask + ControlTest models
//    • Risk + RiskTemplate + RiskControl (M:N risk↔control)
//    • Evidence + EvidenceLink + EvidencePackage
//    • Framework + FrameworkRequirement + FrameworkMapping
//    • Clause + ClauseEvidence
//    • Policy + PolicyVersion + PolicyApproval + PolicyContributor
//    • Asset + AssetEvidence + AssetCoverage
//    • Issue + IssueComment + Finding + FindingTask
//    • Task (work-item — distinct from ControlTask) + TaskLink +
//      TaskComment + TaskWatcher
//    • TraceabilityLink (cross-entity weave)
//
//  Note: Audit models (AuditCycle, AuditPack, …) live in
//  `audit.prisma`. Vendor risk lives in `vendor.prisma`. They are
//  separated because each has a distinct API surface, separate
//  RLS policies, and tends to evolve on its own cadence.
//
//  This file is currently empty. Models will land here in focused
//  follow-up PRs.
// ─────────────────────────────────────────────────────────────────

model Clause {
  id          String           @id @default(cuid())
  number      String           @unique
  title       String
  description String?
  artifacts   String?
  sortOrder   Int              @default(0)
  progress    ClauseProgress[]
}

model ClauseProgress {
  id        String       @id @default(cuid())
  tenantId  String
  clauseId  String
  status    ClauseStatus @default(NOT_STARTED)
  notes     String?
  updatedAt DateTime     @updatedAt
  clause    Clause       @relation(fields: [clauseId], references: [id])
  tenant    Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, clauseId])
}

model Task {
  id              String           @id @default(cuid())
  tenantId        String
  type            WorkItemType     @default(TASK)
  title           String
  description     String?
  severity        WorkItemSeverity @default(MEDIUM)
  priority        WorkItemPriority @default(P2)
  status          WorkItemStatus   @default(OPEN)
  source          WorkItemSource?  @default(MANUAL)
  key             String?
  resolution      String?
  dueAt           DateTime?
  completedAt     DateTime?
  createdByUserId String
  assigneeUserId  String?
  reviewerUserId  String?
  controlId       String?
  metadataJson    Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?
  assignee        User?            @relation("TaskAssignee", fields: [assigneeUserId], references: [id])
  control         Control?         @relation(fields: [controlId], references: [id])
  createdBy       User             @relation("TaskCreator", fields: [createdByUserId], references: [id])
  reviewer        User?            @relation("TaskReviewer", fields: [reviewerUserId], references: [id])
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  comments        TaskComment[]
  links           TaskLink[]
  watchers        TaskWatcher[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, severity])
  @@index([tenantId, assigneeUserId])
  @@index([tenantId, controlId])
  // #102 item 4 — the control-detail Tasks tab filters by both
  // controlId AND status; this composite serves that hot path.
  @@index([tenantId, controlId, status])
  @@index([tenantId, deletedAt])
  @@index([tenantId, priority, createdAt])
  // #102 item 4 — `[tenantId, dueAt]` dropped: it is a strict
  // prefix of `[tenantId, dueAt, status]` below, so the planner
  // never needs both.
  @@index([tenantId, dueAt, status])
}

/// Per-tenant monotonic counter for minting `TSK-N` work-item keys.
///
/// #102 item 2 — replaces the `db.task.count()` derivation in
/// `WorkItemRepository.create`, which raced against the unique
/// `[tenantId, key]` index under concurrent imports and scaled
/// linearly with tenant size. `upsert` with an atomic `increment`
/// (native `INSERT … ON CONFLICT DO UPDATE`) is race-free.
///
/// RLS: tenant-scoped (Class A — `tenant_isolation` USING +
/// `tenant_isolation_insert` WITH CHECK + `superuser_bypass`,
/// `FORCE ROW LEVEL SECURITY`). See the companion migration.
model TaskKeySequence {
  tenantId  String @id
  lastValue Int    @default(0)
}

model TaskLink {
  id         String             @id @default(cuid())
  tenantId   String
  taskId     String
  entityType TaskLinkEntityType
  entityId   String
  relation   TaskLinkRelation   @default(RELATES_TO)
  createdAt  DateTime           @default(now())
  task       Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant     Tenant             @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, taskId, entityType, entityId])
  @@index([tenantId, taskId])
  @@index([tenantId, entityType, entityId])
}

model TaskComment {
  id              String   @id @default(cuid())
  tenantId        String
  taskId          String
  body            String
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       User     @relation("TaskCommentCreator", fields: [createdByUserId], references: [id])
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, taskId])
}

model TaskWatcher {
  id       String @id @default(cuid())
  tenantId String
  taskId   String
  userId   String
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@index([tenantId, taskId])
}

model Asset {
  id                  String               @id @default(cuid())
  tenantId            String
  /// Generated per-tenant short key (`AST-1`, `AST-2`, …) so the
  /// Assets list page can lead with a scannable Code column.
  /// Mints atomically via `AssetKeySequence.upsert` (same race-
  /// free pattern Task / Risk use). Nullable to keep historic
  /// rows renderable; the create-path generates a key for every
  /// new row.
  key                 String?
  name                String
  type                AssetType
  classification      String?
  owner               String?
  location            String?
  confidentiality     Int?                 @default(3)
  integrity           Int?                 @default(3)
  availability        Int?                 @default(3)
  dependencies        String?
  businessProcesses   String?
  dataResidency       String?
  retention           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  ownerUserId         String?
  criticality         Criticality?
  status              AssetStatus          @default(ACTIVE)
  externalRef         String?
  tags                String?
  deletedAt           DateTime?
  deletedByUserId     String?
  retentionUntil      DateTime?
  ownerUser           User?                @relation("AssetOwner", fields: [ownerUserId], references: [id])
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  risks               AssetRiskLink[]
  controls            ControlAsset[]
  riskSuggestionItems RiskSuggestionItem[]

  @@index([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, type])
  @@index([tenantId, criticality])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  /// Unique within a tenant — `AST-N` collisions are race-free
  /// via the AssetKeySequence counter.
  @@unique([tenantId, key])
}

/// Per-tenant monotonic counter for minting `AST-N` asset keys.
/// Mirrors `TaskKeySequence` / `RiskKeySequence` — `upsert` with
/// an atomic `increment` is race-free under concurrent imports.
model AssetKeySequence {
  tenantId  String @id
  lastValue Int    @default(0)
}

model Risk {
  id              String              @id @default(cuid())
  tenantId        String
  /// PR-B — generated per-tenant short key (RSK-1, RSK-2, …) so the
  /// Risk list page can lead with a scannable identifier column.
  /// Mints atomically via `RiskKeySequence.upsert` mirroring the
  /// TaskKeySequence pattern. Nullable to keep historic rows
  /// renderable; the create-path generates fresh values for every
  /// new row.
  key             String?
  title           String
  description     String?
  category        String?
  threat          String?
  vulnerability   String?
  likelihood      Int                 @default(3)
  impact          Int                 @default(3)
  score           Int                 @default(9)
  inherentScore   Int                 @default(9)
  /// Residual risk score after treatment-plan completion. Distinct
  /// from `inherentScore` (set at create-time, never overwritten by
  /// plan completion) and `score` (the live "current" value that
  /// already moves on every likelihood/impact edit). Residual is
  /// the auditor's "after controls implemented" view.
  ///
  /// NULL until the first treatment plan completes on this risk;
  /// thereafter it reflects the strategy-specific reduction
  /// (MITIGATE → 1/5 of score, TRANSFER → ~0, AVOID → 0,
  /// ACCEPT → score unchanged). See `completePlan` in
  /// risk-treatment-plan.ts for the formula.
  ///
  /// Audit Coherence S1 (2026-05-22).
  residualScore   Int?
  residualScoreSetAt DateTime?
  /// B10 — Quantitative risk assessment (SLE × ARO = ALE).
  ///
  /// `sleAmount` — Single Loss Expectancy: the monetary impact of
  ///               ONE realised incident. Nullable until the risk
  ///               owner quantifies; null risks keep the existing
  ///               qualitative score-only view.
  /// `aroAmount` — Annualised Rate of Occurrence: incidents/year.
  ///               Float so 0.25 (= once per 4 years) is expressible
  ///               without coercing to weird rationals. The audit
  ///               UI will surface percentage equivalents.
  ///
  /// ALE is derived (`sleAmount * aroAmount`), not stored — both
  /// inputs are nullable so a stored derived would have to be
  /// `null OR sleAmount * aroAmount` everywhere, doubling the
  /// invariants without buying query benefit. The analytics
  /// usecase materialises ALE per-row at read time.
  sleAmount       Float?
  aroAmount       Float?
  status          RiskStatus          @default(OPEN)
  treatment       TreatmentDecision?
  treatmentOwner  String?
  treatmentNotes  String?
  ownerUserId     String?
  createdByUserId String?
  targetDate      DateTime?
  nextReviewAt    DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?
  assetLinks      AssetRiskLink[]
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  controls        RiskControl[]
  // Epic G-7 — structured treatment plans (replaces free-text
  // `treatmentNotes` for ISO 27001 6.1.3 conformance).
  treatmentPlans  RiskTreatmentPlan[]

  /// Composite parent key — supports the
  /// `RiskTreatmentPlan.(riskId, tenantId) → Risk.(id, tenantId)`
  /// FK shape so cross-tenant treatment plans are impossible at the
  /// DB level. Same denorm-tenantId Phase-2 pattern Audit uses.
  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([tenantId, deletedAt])
  // GAP-perf — supports `ownerUserId` filter in RiskFilters
  @@index([tenantId, ownerUserId])
  // GAP-perf — supports `scoreMin`/`scoreMax` range filter
  @@index([tenantId, score])
  // GAP-perf — backs the default unpaginated `list()` orderBy:
  // `inherentScore desc`. Without this Postgres sorts the full
  // tenant result set per call.
  @@index([tenantId, inherentScore])
  // PR-B — unique within a tenant so `RSK-1` can't collide. Allows
  // `@@unique` on a nullable column (Postgres treats NULLs as
  // distinct), so historic NULL rows don't clash with each other.
  @@unique([tenantId, key])
}

/// Per-tenant monotonic counter for minting `RSK-N` risk keys.
/// Mirrors `TaskKeySequence` — `upsert` with an atomic `increment`
/// is race-free under concurrent imports and scales O(1) regardless
/// of tenant size.
model RiskKeySequence {
  tenantId  String @id
  lastValue Int    @default(0)
}

/// Per-tenant monotonic counter for minting `CTL-N` custom-control
/// keys (the framework-installed controls keep their canonical
/// annexId / supplied code). Only the `createControl` path that
/// lacks an explicit code consumes this sequence; framework imports
/// supply their own code/annexId and bypass the counter entirely.
model ControlKeySequence {
  tenantId  String @id
  lastValue Int    @default(0)
}

model RiskTemplate {
  id                String   @id @default(cuid())
  title             String
  description       String?
  category          String?
  defaultLikelihood Int      @default(3)
  defaultImpact     Int      @default(3)
  frameworkTag      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// Tenant-scoped risk-matrix configuration (Epic 44).
///
/// Drives the dimensions, axis labels, per-level labels, and severity
/// bands of the likelihood × impact matrix the UI renders. Existing
/// tenants resolve to the canonical 5×5 default until an admin
/// customises it via the admin UI — the row is absent in that case;
/// the read usecase centralises the fallback so callers don't have
/// to know about presence.
///
/// `levelLabels` and `bands` are JSON because the per-level
/// vocabulary varies (operational vs. clinical vs. supply-chain
/// risks all want different scale legends) and forcing a side table
/// would buy nothing — the rows are deeply tenant-specific and
/// validated end-to-end by Zod before write. Schema invariants:
///   - `likelihoodLevels`, `impactLevels` ∈ [2, 10]
///   - `levelLabels.likelihood` length === likelihoodLevels (when set)
///   - `levelLabels.impact`     length === impactLevels (when set)
///   - `bands` cover [1, likelihoodLevels * impactLevels] without gaps
///     or overlaps; each entry has { name, minScore, maxScore, color }
///
/// One row per tenant (`@@unique([tenantId])`).
model RiskMatrixConfig {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  /// Number of likelihood levels (matrix rows). Default 5.
  likelihoodLevels    Int      @default(5)
  /// Number of impact levels (matrix columns). Default 5.
  impactLevels        Int      @default(5)
  /// Y-axis title (default "Likelihood").
  axisLikelihoodLabel String   @default("Likelihood")
  /// X-axis title (default "Impact").
  axisImpactLabel     String   @default("Impact")
  /// Per-level human labels keyed by axis. Falls back to numeric labels when absent.
  levelLabels         Json?
  /// Ordered severity bands. See doc above for the contract.
  bands               Json     @default("[]")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  tenant              Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model RiskSuggestionSession {
  id              String                  @id @default(cuid())
  tenantId        String
  createdByUserId String
  status          SuggestionSessionStatus @default(DRAFT)
  inputJson       String
  modelName       String?
  provider        String                  @default("stub")
  errorMessage    String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  items           RiskSuggestionItem[]
  createdBy       User                    @relation("SuggestionSessionCreator", fields: [createdByUserId], references: [id])
  tenant          Tenant                  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

model RiskSuggestionItem {
  id                    String                @id @default(cuid())
  sessionId             String
  tenantId              String
  assetId               String?
  title                 String
  description           String?
  category              String?
  threat                String?
  vulnerability         String?
  likelihoodSuggested   Int?
  impactSuggested       Int?
  rationale             String?
  suggestedControlsJson String?
  status                SuggestionItemStatus  @default(PENDING)
  editedJson            String?
  createdRiskId         String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  asset                 Asset?                @relation(fields: [assetId], references: [id])
  suggestionSession     RiskSuggestionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  session               Tenant                @relation(fields: [tenantId], references: [id])

  @@index([sessionId])
  @@index([tenantId])
  @@index([tenantId, sessionId])
}

model Control {
  id                           String                   @id @default(cuid())
  tenantId                     String?
  code                         String?
  annexId                      String?                  @unique
  name                         String
  description                  String?
  intent                       String?
  category                     String?
  status                       ControlStatus            @default(NOT_STARTED)
  effectiveness                Int?
  lastTested                   DateTime?
  reviewCadence                ReviewCadence?
  isCustom                     Boolean                  @default(false)
  ownerUserId                  String?
  createdByUserId              String?
  frequency                    ControlFrequency?
  nextDueAt                    DateTime?
  evidenceSource               EvidenceSourceType?
  automationKey                String?
  applicability                Applicability            @default(APPLICABLE)
  applicabilityJustification   String?
  applicabilityDecidedByUserId String?
  applicabilityDecidedAt       DateTime?
  createdAt                    DateTime                 @default(now())
  updatedAt                    DateTime                 @updatedAt
  deletedAt                    DateTime?
  deletedByUserId              String?
  retentionUntil               DateTime?
  applicabilityDecidedBy       User?                    @relation("ControlApplicabilityDecider", fields: [applicabilityDecidedByUserId], references: [id])
  createdBy                    User?                    @relation("ControlCreator", fields: [createdByUserId], references: [id])
  owner                        User?                    @relation("ControlOwner", fields: [ownerUserId], references: [id])
  tenant                       Tenant?                  @relation(fields: [tenantId], references: [id])
  assets                       ControlAsset[]
  contributors                 ControlContributor[]
  evidenceLinks                ControlEvidenceLink[]
  requirementLinks             ControlRequirementLink[]
  controlTasks                 ControlTask[]
  testPlans                    ControlTestPlan[]
  testRuns                     ControlTestRun[]
  evidence                     Evidence[]
  frameworkMappings            FrameworkMapping[]
  integrationExecutions        IntegrationExecution[]
  policyLinks                  PolicyControlLink[]
  risks                        RiskControl[]
  tasks                        Task[]
  // Epic G-5 — control exception register. Two reverse relations:
  // (a) exceptions registered against THIS control,
  // (b) exceptions that name THIS control as their compensating
  //     control (i.e. "we mitigate the gap by doing this").
  exceptions                   ControlException[]       @relation("ControlExceptionAffected")
  compensatingForExceptions    ControlException[]       @relation("ControlExceptionCompensating")

  /// Composite parent key — supports the
  /// `ControlException.(controlId, tenantId) → Control.(id, tenantId)`
  /// FK shape, so a cross-tenant exception link is impossible at
  /// the DB level. Same denorm-tenantId Phase-2 pattern used by
  /// AuditChecklistItem → Audit.
  @@unique([id, tenantId])
  @@index([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, applicability])
  @@index([ownerUserId])
  @@index([nextDueAt])
  @@index([tenantId, deletedAt])
  // GAP-perf — supports `ownerUserId` filter in tenant scope.
  // `[ownerUserId]` alone exists but isn't tenant-prefixed, so
  // Postgres can't selectively scan one tenant's slice for a
  // specific owner without an additional filter pass.
  @@index([tenantId, ownerUserId])
  // GAP-perf — supports `category` filter (free-text exact match).
  @@index([tenantId, category])
}

model RiskControl {
  id              String   @id @default(cuid())
  riskId          String
  controlId       String
  tenantId        String
  rationale       String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  control         Control  @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy       User?    @relation("RiskControlCreator", fields: [createdByUserId], references: [id])
  risk            Risk     @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, riskId, controlId])
  @@index([tenantId, controlId])
  @@index([tenantId])
}

model ControlAsset {
  id              String       @id @default(cuid())
  controlId       String
  assetId         String
  tenantId        String
  coverageType    CoverageType @default(UNKNOWN)
  rationale       String?
  createdByUserId String?
  createdAt       DateTime     @default(now())
  asset           Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  control         Control      @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy       User?        @relation("ControlAssetCreator", fields: [createdByUserId], references: [id])
  tenant          Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, controlId, assetId])
  @@index([tenantId, assetId])
  @@index([tenantId])
}

model AssetRiskLink {
  id              String        @id @default(cuid())
  tenantId        String
  assetId         String
  riskId          String
  exposureLevel   ExposureLevel @default(MEDIUM)
  rationale       String?
  createdByUserId String?
  createdAt       DateTime      @default(now())
  asset           Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdBy       User?         @relation("AssetRiskCreator", fields: [createdByUserId], references: [id])
  risk            Risk          @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, assetId, riskId])
  @@index([tenantId, riskId])
  @@index([tenantId])
}

model ControlContributor {
  id        String   @id @default(cuid())
  tenantId  String
  controlId String
  userId    String
  createdAt DateTime @default(now())
  control   Control  @relation(fields: [controlId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([controlId, userId])
  @@index([tenantId])
}

model ControlTask {
  id             String            @id @default(cuid())
  tenantId       String
  controlId      String
  title          String
  description    String?
  status         ControlTaskStatus @default(OPEN)
  assigneeUserId String?
  dueAt          DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  assignee       User?             @relation("ControlTaskAssignee", fields: [assigneeUserId], references: [id])
  control        Control           @relation(fields: [controlId], references: [id], onDelete: Cascade)
  tenant         Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([controlId])
  @@index([status])
  @@index([dueAt])
  // GAP-perf — backs the dashboard "overdue tasks" query
  // (status IN ('OPEN','IN_PROGRESS') AND dueAt < now()) and the
  // refactored `runConsistencyCheck` overdue lookup. The
  // single-column `[status]` and `[dueAt]` indexes can't satisfy
  // the combined predicate efficiently.
  @@index([tenantId, status, dueAt])
}

model ControlEvidenceLink {
  id                  String           @id @default(cuid())
  tenantId            String
  controlId           String
  kind                EvidenceLinkKind
  fileId              String?
  url                 String?
  integrationResultId String?
  note                String?
  createdByUserId     String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  control             Control          @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy           User?            @relation("ControlEvidenceCreator", fields: [createdByUserId], references: [id])
  tenant              Tenant           @relation(fields: [tenantId], references: [id])

  @@unique([controlId, kind, fileId])
  @@unique([controlId, kind, url])
  @@index([tenantId])
  @@index([controlId])
}

model ControlTemplate {
  id               String                           @id @default(cuid())
  code             String                           @unique
  title            String
  description      String?
  category         String?
  defaultFrequency ControlFrequency?
  defaultOwnerHint String?
  isGlobal         Boolean                          @default(true)
  createdAt        DateTime                         @default(now())
  requirementLinks ControlTemplateRequirementLink[]
  tasks            ControlTemplateTask[]
  packLinks        PackTemplateLink[]
}

model ControlTemplateTask {
  id          String          @id @default(cuid())
  templateId  String
  title       String
  description String?
  template    ControlTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ControlTemplateRequirementLink {
  id            String               @id @default(cuid())
  templateId    String
  requirementId String
  requirement   FrameworkRequirement @relation(fields: [requirementId], references: [id])
  template      ControlTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, requirementId])
}

model Evidence {
  id                String                    @id @default(cuid())
  tenantId          String
  controlId         String?
  type              EvidenceType
  title             String
  content           String?
  fileName          String?
  fileSize          Int?
  category          String?
  dateCollected     DateTime                  @default(now())
  owner             String? // Legacy free-text — kept for backward compat
  ownerUserId       String? // Real user FK — used for due-item routing & notifications
  reviewCycle       ReviewCadence?
  nextReviewDate    DateTime?
  status            EvidenceStatus            @default(DRAFT)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  deletedAt         DateTime?
  deletedByUserId   String?
  fileRecordId      String?
  expiredAt         DateTime?
  isArchived        Boolean                   @default(false)
  retentionDays     Int?
  retentionPolicy   RetentionPolicy           @default(NONE)
  retentionUntil    DateTime?
  /// B8 follow-up — free-text folder label (e.g. "SOC2/2026" or
  /// "Quarterly access reviews"). Mirrors the `VendorDocument.folder`
  /// pattern. Nullable; null/empty maps to "no folder" in the UI.
  /// Sanitised + trimmed at the usecase boundary.
  folder            String?
  testEvidenceLinks ControlTestEvidenceLink[]
  // Epic G-3 — vendor questionnaire FILE_UPLOAD answers attach
  // their proof here.
  vendorAnswers     VendorAssessmentAnswer[]  @relation("VendorAnswerEvidence")
  control           Control?                  @relation(fields: [controlId], references: [id])
  fileRecord        FileRecord?               @relation(fields: [fileRecordId], references: [id])
  ownerUser         User?                     @relation("EvidenceOwner", fields: [ownerUserId], references: [id])
  tenant            Tenant                    @relation(fields: [tenantId], references: [id])
  reviews           EvidenceReview[]
  findingLinks      FindingEvidence[]
  reminderHistories ReminderHistory[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, deletedAt])
  @@index([tenantId, retentionUntil])
  @@index([tenantId, isArchived])
  @@index([tenantId, ownerUserId])
  // GAP-perf — supports `status` filter (DRAFT|SUBMITTED|APPROVED|REJECTED).
  @@index([tenantId, status])
  // GAP-perf — supports `controlId` filter ("evidence for control X").
  // Already a heavily-used UI surface — every control detail page
  // pulls evidence by controlId.
  @@index([tenantId, controlId])
  // GAP-perf — supports `type` filter (FILE|LINK|TEXT|SCREENSHOT).
  @@index([tenantId, type])
  // B8 follow-up — supports folder filter + group-by reads. Same
  // shape as VendorDocument's folder index.
  @@index([tenantId, folder])
}

model FileRecord {
