// ─────────────────────────────────────────────────────────────────
// Epic G-5 — Control Exception Register.
//
// Formal record of a control that cannot be implemented as designed,
// covering the auditor's required artifact: who accepted the risk,
// what compensating control (if any) is in place, when it expires,
// and the chain of renewals over time.
//
// Lifecycle is REQUESTED → (APPROVED | REJECTED) → (EXPIRED). A
// renewal is a brand-new row in REQUESTED state with `renewedFromId`
// pointing at the prior (typically EXPIRED or near-expiry APPROVED)
// row — the renewal lineage is intentionally a per-row link, not a
// status mutation, so each acceptance has its own approver +
// expiry + audit trail.
//
// `compensatingControlId` is optional but heavily used: most
// exceptions carry a "we mitigate by doing X with Control Y"
// rationale that auditors expect to see linked.
//
// Tenant scoping: Class-A direct-scoped (own `tenantId` column);
// canonical RLS trio + FORCE in the migration. The control FK is
// composite (controlId, tenantId) → Control(id, tenantId) so a
// cross-tenant link is impossible at the DB level. Compensating
// control + renewal-from FK use the same composite shape.
// ─────────────────────────────────────────────────────────────────

model ControlException {
  id                    String                 @id @default(cuid())
  tenantId              String
  /// FK target — the control that cannot be implemented as designed.
  controlId             String
  status                ControlExceptionStatus @default(REQUESTED)
  /// Required free-text rationale for the exception. Surfaced
  /// verbatim in audit packs; encrypted at rest via the manifest.
  justification         String
  /// Optional FK to the control that mitigates this exception
  /// ("we don't enforce X because we instead do Y via control Z").
  compensatingControlId String?
  /// User who carries the risk-acceptance authority. Required at
  /// creation — auditors want to know up-front who would sign off.
  riskAcceptedByUserId  String
  /// Set when status transitions to APPROVED.
  approvedAt            DateTime?
  approvedByUserId      String?
  /// Set when status transitions to REJECTED.
  rejectedAt            DateTime?
  rejectedByUserId      String?
  rejectionReason       String?
  /// Required deadline at which the exception expires. The expiry
  /// monitor reminds approvers in the 30 → 7 → 1 day windows.
  /// Nullable for REQUESTED rows that haven't been formally
  /// scoped yet; required (CHECK) once status moves to APPROVED.
  expiresAt             DateTime?
  /// Renewal lineage — points at the prior row this one supersedes.
  /// Self-referential composite FK (renewedFromId, tenantId) →
  /// ControlException(id, tenantId) so renewals can never reference
  /// a prior row in another tenant.
  renewedFromId         String?
  createdByUserId       String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  /// Soft-delete columns — same convention as AuditCycle.
  deletedAt             DateTime?
  deletedByUserId       String?

  tenant              Tenant             @relation(fields: [tenantId], references: [id])
  control             Control            @relation("ControlExceptionAffected", fields: [controlId, tenantId], references: [id, tenantId])
  compensatingControl Control?           @relation("ControlExceptionCompensating", fields: [compensatingControlId, tenantId], references: [id, tenantId])
  renewedFrom         ControlException?  @relation("ControlExceptionRenewalChain", fields: [renewedFromId, tenantId], references: [id, tenantId])
  renewals            ControlException[] @relation("ControlExceptionRenewalChain")
  createdBy           User               @relation("ControlExceptionCreatedBy", fields: [createdByUserId], references: [id])
  riskAcceptedBy      User               @relation("ControlExceptionRiskAcceptedBy", fields: [riskAcceptedByUserId], references: [id])
  approvedBy          User?              @relation("ControlExceptionApprovedBy", fields: [approvedByUserId], references: [id])
  rejectedBy          User?              @relation("ControlExceptionRejectedBy", fields: [rejectedByUserId], references: [id])
  deletedBy           User?              @relation("ControlExceptionDeletedBy", fields: [deletedByUserId], references: [id])

  /// Composite parent key. Used by the self-referential FK above
  /// AND by any future child entity (audit packs, approval logs).
  @@unique([id, tenantId])
  @@index([tenantId, status])
  @@index([tenantId, expiresAt])
  @@index([tenantId, controlId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, createdAt])
  @@index([renewedFromId])
}

// ─────────────────────────────────────────────────────────────────
// Epic G-7 — Risk Treatment Plans (ISO 27001 6.1.3).
//
// Replaces the free-text `Risk.treatmentNotes` field with a
// structured plan: explicit strategy + owner + target date +
// ordered milestones, each with its own due date and completion
// state. Auditors expect to walk the milestone sequence on
// every MITIGATE plan; the ordered list (sortOrder) makes that
// reconstructible without a JSON blob.
//
// Lifecycle is DRAFT → ACTIVE → (COMPLETED | OVERDUE). OVERDUE is
// set by the monitor job, not user paths — operators who want to
// close a plan past its target date go through "complete plan"
// (transitions to COMPLETED with a closing remark recorded in the
// audit log).
//
// Tenant scoping: Class-A direct-scoped (own `tenantId` column);
// canonical RLS trio + FORCE in the migration. The risk FK is
// composite (riskId, tenantId) → Risk(id, tenantId) so cross-
// tenant plans are impossible by construction. Milestones use the
// same composite shape against the parent plan.
// ─────────────────────────────────────────────────────────────────

model RiskTreatmentPlan {
  id                String              @id @default(cuid())
  tenantId          String
  riskId            String
  /// Strategy chosen for this plan. Parallel to (but more
  /// vocabulary-current than) the legacy `Risk.treatment` field —
  /// see `TreatmentStrategy` enum docstring.
  strategy          TreatmentStrategy
  /// Plan owner — the user accountable for execution. Required
  /// because auditors will ask "who runs this plan?".
  ownerUserId       String
  /// SLA target — surfaced in the dashboard + drives the
  /// overdue-monitor job's flip to OVERDUE.
  targetDate        DateTime
  status            TreatmentPlanStatus @default(DRAFT)
  /// Set when status transitions to COMPLETED. Audit-visible
  /// timestamp + the user who closed the plan.
  completedAt       DateTime?
  completedByUserId String?
  /// Free-text closing remark — encrypted at rest because the
  /// rationale may name internal users / systems.
  closingRemark     String?
  /// Soft-delete columns — same convention as AuditCycle.
  createdByUserId   String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  deletedByUserId   String?

  tenant      Tenant               @relation(fields: [tenantId], references: [id])
  risk        Risk                 @relation(fields: [riskId, tenantId], references: [id, tenantId])
  owner       User                 @relation("RiskTreatmentPlanOwner", fields: [ownerUserId], references: [id])
  createdBy   User                 @relation("RiskTreatmentPlanCreator", fields: [createdByUserId], references: [id])
  completedBy User?                @relation("RiskTreatmentPlanCompleter", fields: [completedByUserId], references: [id])
  deletedBy   User?                @relation("RiskTreatmentPlanDeleter", fields: [deletedByUserId], references: [id])
  milestones  TreatmentMilestone[]

  /// Composite parent key — supports the
  /// `TreatmentMilestone.(treatmentPlanId, tenantId) →
  /// RiskTreatmentPlan.(id, tenantId)` FK shape.
  @@unique([id, tenantId])
  @@index([tenantId, status])
  @@index([tenantId, riskId])
  @@index([tenantId, ownerUserId, status])
  @@index([tenantId, targetDate])
  @@index([tenantId, deletedAt])
  @@index([tenantId, createdAt])
}

model TreatmentMilestone {
  id                String    @id @default(cuid())
  tenantId          String
  treatmentPlanId   String
  title             String
  /// Free-text milestone description (e.g. "Procure new SIEM
  /// licences"). Encrypted at rest because the description may
  /// name internal systems / vendors.
  description       String?
  dueDate           DateTime
  /// Set when the milestone is marked complete.
  completedAt       DateTime?
  completedByUserId String?
  /// Optional reference to evidence backing this milestone —
  /// String? rather than a typed FK so it can carry a URL, a
  /// FileRecord id, or an internal Evidence id without a fan-out
  /// in the schema. The future `attachEvidence` usecase will
  /// migrate this to a typed relation.
  evidence          String?
  /// Manual ordering. Plans render milestones in this order; the
  /// reorder usecase mutates the column in a single tx.
  sortOrder         Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  treatmentPlan RiskTreatmentPlan @relation(fields: [treatmentPlanId, tenantId], references: [id, tenantId], onDelete: Cascade)
  completedBy   User?             @relation("TreatmentMilestoneCompleter", fields: [completedByUserId], references: [id])

  @@index([tenantId, treatmentPlanId])
  @@index([tenantId, dueDate])
  @@index([tenantId, completedAt])
  @@index([treatmentPlanId, sortOrder])
}
