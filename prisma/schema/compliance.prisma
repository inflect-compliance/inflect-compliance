// ─────────────────────────────────────────────────────────────────
//  GAP-09 — multi-file schema: COMPLIANCE
//
//  Core compliance domain. Owns:
//    • Control + ControlEvidenceLink + ControlContributor +
//      ControlTask + ControlTest models
//    • Risk + RiskTemplate + RiskControl (M:N risk↔control)
//    • Evidence + EvidenceLink + EvidencePackage
//    • Framework + FrameworkRequirement + FrameworkMapping
//    • Clause + ClauseEvidence
//    • Policy + PolicyVersion + PolicyApproval + PolicyContributor
//    • Asset + AssetEvidence + AssetCoverage
//    • Issue + IssueComment + Finding + FindingTask
//    • Task (work-item — distinct from ControlTask) + TaskLink +
//      TaskComment + TaskWatcher
//    • TraceabilityLink (cross-entity weave)
//
//  Note: Audit models (AuditCycle, AuditPack, …) live in
//  `audit.prisma`. Vendor risk lives in `vendor.prisma`. They are
//  separated because each has a distinct API surface, separate
//  RLS policies, and tends to evolve on its own cadence.
//
//  This file is currently empty. Models will land here in focused
//  follow-up PRs.
// ─────────────────────────────────────────────────────────────────

model Clause {
  id          String           @id @default(cuid())
  number      String           @unique
  title       String
  description String?
  artifacts   String?
  sortOrder   Int              @default(0)
  progress    ClauseProgress[]
}

model ClauseProgress {
  id        String       @id @default(cuid())
  tenantId  String
  clauseId  String
  status    ClauseStatus @default(NOT_STARTED)
  notes     String?
  updatedAt DateTime     @updatedAt
  clause    Clause       @relation(fields: [clauseId], references: [id])
  tenant    Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, clauseId])
}

model Task {
  id              String           @id @default(cuid())
  tenantId        String
  type            WorkItemType     @default(TASK)
  title           String
  description     String?
  severity        WorkItemSeverity @default(MEDIUM)
  priority        WorkItemPriority @default(P2)
  status          WorkItemStatus   @default(OPEN)
  source          WorkItemSource?  @default(MANUAL)
  key             String?
  resolution      String?
  dueAt           DateTime?
  completedAt     DateTime?
  createdByUserId String
  assigneeUserId  String?
  reviewerUserId  String?
  controlId       String?
  metadataJson    Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?
  assignee        User?            @relation("TaskAssignee", fields: [assigneeUserId], references: [id])
  control         Control?         @relation(fields: [controlId], references: [id])
  createdBy       User             @relation("TaskCreator", fields: [createdByUserId], references: [id])
  reviewer        User?            @relation("TaskReviewer", fields: [reviewerUserId], references: [id])
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  comments        TaskComment[]
  links           TaskLink[]
  watchers        TaskWatcher[]
  // Evidence attached directly to this task — the task Evidence tab
  // mirrors the control Evidence tab. `Evidence.taskId` is the source
  // pointer that also powers the "uploaded from" back-reference on the
  // evidence detail surface.
  evidence        Evidence[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, severity])
  @@index([tenantId, assigneeUserId])
  @@index([tenantId, controlId])
  // #102 item 4 — the control-detail Tasks tab filters by both
  // controlId AND status; this composite serves that hot path.
  @@index([tenantId, controlId, status])
  @@index([tenantId, deletedAt])
  @@index([tenantId, priority, createdAt])
  // #102 item 4 — `[tenantId, dueAt]` dropped: it is a strict
  // prefix of `[tenantId, dueAt, status]` below, so the planner
  // never needs both.
  @@index([tenantId, dueAt, status])
}

/// Per-tenant monotonic counter for minting `TSK-N` work-item keys.
///
/// #102 item 2 — replaces the `db.task.count()` derivation in
/// `WorkItemRepository.create`, which raced against the unique
/// `[tenantId, key]` index under concurrent imports and scaled
/// linearly with tenant size. `upsert` with an atomic `increment`
/// (native `INSERT … ON CONFLICT DO UPDATE`) is race-free.
///
/// RLS: tenant-scoped (Class A — `tenant_isolation` USING +
/// `tenant_isolation_insert` WITH CHECK + `superuser_bypass`,
/// `FORCE ROW LEVEL SECURITY`). See the companion migration.
model TaskKeySequence {
  tenantId  String @id
  lastValue Int    @default(0)
}

model TaskLink {
  id         String             @id @default(cuid())
  tenantId   String
  taskId     String
  entityType TaskLinkEntityType
  entityId   String
  relation   TaskLinkRelation   @default(RELATES_TO)
  createdAt  DateTime           @default(now())
  task       Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant     Tenant             @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, taskId, entityType, entityId])
  @@index([tenantId, taskId])
  @@index([tenantId, entityType, entityId])
}

model TaskComment {
  id              String   @id @default(cuid())
  tenantId        String
  taskId          String
  body            String
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       User     @relation("TaskCommentCreator", fields: [createdByUserId], references: [id])
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, taskId])
}

model TaskWatcher {
  id       String @id @default(cuid())
  tenantId String
  taskId   String
  userId   String
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@index([tenantId, taskId])
}

model Asset {
  id                  String               @id @default(cuid())
  tenantId            String
  /// Generated per-tenant short key (`AST-1`, `AST-2`, …) so the
  /// Assets list page can lead with a scannable Code column.
  /// Mints atomically via `AssetKeySequence.upsert` (same race-
  /// free pattern Task / Risk use). Nullable to keep historic
  /// rows renderable; the create-path generates a key for every
  /// new row.
  key                 String?
  name                String
  type                AssetType
  classification      String?
  owner               String?
  location            String?
  confidentiality     Int?                 @default(3)
  integrity           Int?                 @default(3)
  availability        Int?                 @default(3)
  dependencies        String?
  businessProcesses   String?
  dataResidency       String?
  retention           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  ownerUserId         String?
  criticality         Criticality?
  status              AssetStatus          @default(ACTIVE)
  externalRef         String?
  tags                String?
  deletedAt           DateTime?
  deletedByUserId     String?
  retentionUntil      DateTime?
  ownerUser           User?                @relation("AssetOwner", fields: [ownerUserId], references: [id])
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  risks               AssetRiskLink[]
  controls            ControlAsset[]
  riskSuggestionItems RiskSuggestionItem[]
  // Evidence attached directly to this asset (Evidence Library tag +
  // the asset Evidence tab). Mirrors Control/Task.
  evidence            Evidence[]

  /// Unique within a tenant — `AST-N` collisions are race-free
  /// via the AssetKeySequence counter.
  @@unique([tenantId, key])
  @@index([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, type])
  @@index([tenantId, criticality])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
}

/// Per-tenant monotonic counter for minting `AST-N` asset keys.
/// Mirrors `TaskKeySequence` / `RiskKeySequence` — `upsert` with
/// an atomic `increment` is race-free under concurrent imports.
model AssetKeySequence {
  tenantId  String @id
  lastValue Int    @default(0)
}

model Risk {
  id                 String    @id @default(cuid())
  tenantId           String
  /// PR-B — generated per-tenant short key (RSK-1, RSK-2, …) so the
  /// Risk list page can lead with a scannable identifier column.
  /// Mints atomically via `RiskKeySequence.upsert` mirroring the
  /// TaskKeySequence pattern. Nullable to keep historic rows
  /// renderable; the create-path generates fresh values for every
  /// new row.
  key                String?
  title              String
  description        String?
  category           String?
  threat             String?
  vulnerability      String?
  likelihood         Int       @default(3)
  impact             Int       @default(3)
  score              Int       @default(9)
  /// The CURRENT inherent assessment (likelihood × impact at the
  /// latest edit) — moves together with `score` on every L/I update.
  /// NOT a frozen creation-time value; the full change history lives
  /// in `RiskScoreEvent` (RQ2-1).
  inherentScore      Int       @default(9)
  /// Residual risk score — the auditor's "after controls implemented"
  /// view. Distinct from `inherentScore` and `score` (both of which
  /// move together on every likelihood/impact edit — the "current
  /// inherent assessment", NOT a frozen creation-time value; RQ2-1
  /// fixed this doc to match the long-standing behavior of
  /// `updateRisk`).
  ///
  /// NULL until the first residual assessment lands. Written by:
  ///   (a) treatment-plan completion (`completePlan`,
  ///       source: PLAN — strategy-based until RQ2-2 replaces the
  ///       divisors with control-effectiveness derivation), or
  ///   (b) a direct residual assessment via `updateRisk` with
  ///       `residualLikelihood`/`residualImpact` (RQ2-1,
  ///       source: USER) — in which case residualScore is DERIVED
  ///       from those two dimensions via `calculateRiskScore`.
  ///
  /// Every change is recorded as a `RiskScoreEvent` (RQ2-1) with
  /// full provenance.
  residualScore      Int?
  residualScoreSetAt DateTime?
  /// RQ2-1 — residual decomposed into its dimensions, mirroring the
  /// inherent likelihood/impact pair. Nullable: legacy rows carry
  /// only the rolled-up `residualScore` (divisor-era, provenance
  /// flagged MIGRATION). When present, the invariant
  /// `residualScore === calculateRiskScore(residualLikelihood,
  /// residualImpact, maxScale)` holds and is enforced at the
  /// usecase layer.
  residualLikelihood Int?
  residualImpact     Int?
  /// B10 — Quantitative risk assessment (SLE × ARO = ALE).
  ///
  /// `sleAmount` — Single Loss Expectancy: the monetary impact of
  ///               ONE realised incident. Nullable until the risk
  ///               owner quantifies; null risks keep the existing
  ///               qualitative score-only view.
  /// `aroAmount` — Annualised Rate of Occurrence: incidents/year.
  ///               Float so 0.25 (= once per 4 years) is expressible
  ///               without coercing to weird rationals. The audit
  ///               UI will surface percentage equivalents.
  ///
  /// ALE is derived (`sleAmount * aroAmount`), not stored — both
  /// inputs are nullable so a stored derived would have to be
  /// `null OR sleAmount * aroAmount` everywhere, doubling the
  /// invariants without buying query benefit. The analytics
  /// usecase materialises ALE per-row at read time.
  sleAmount          Float?
  aroAmount          Float?

  // ── RQ-1 FAIR taxonomy decomposition ──
  // All nullable + additive: risks with only sleAmount/aroAmount keep
  // working via `resolveALE` (prefers fairAle → SLE×ARO → null).
  // Threat Event Frequency (events/year) + its sub-factors.
  threatEventFrequency        Float?
  contactFrequency            Float?
  probabilityOfAction         Float?
  // Vulnerability (probability a threat event becomes a loss, 0..1) + sub-factors.
  vulnerabilityProbability    Float?
  threatCapability            Float?
  controlStrength             Float?
  // Primary Loss Magnitude (cost of one loss event) + components.
  primaryLossMagnitude        Float?
  productivityLoss            Float?
  responseCost                Float?
  replacementCost             Float?
  // Secondary loss.
  secondaryLossEventFrequency Float?
  secondaryLossMagnitude      Float?
  regulatoryFineEstimate      Float?
  reputationDamageEstimate    Float?
  competitiveAdvantageLoss    Float?
  // Derived (stored for query perf; recomputed on FAIR input change).
  lossEventFrequency          Float?
  fairAle                     Float?
  // Metadata.
  fairConfidence              FairConfidence?
  /// PERT distribution triples per factor for Monte Carlo (RQ-3).
  fairInputsJson              Json?
  fairComputedAt              DateTime?

  // ── RQ-10 — Business Impact Analysis ──
  /// Recovery Time Objective: max acceptable downtime (hours).
  rtoHours          Int?
  /// Recovery Point Objective: max acceptable data-loss window (hours).
  rpoHours          Int?
  /// Maximum Tolerable Period of Disruption (hours).
  mtpdHours         Int?
  /// Impact scores — financial / operational / regulatory / reputational, each 1-5.
  biaImpactJson     Json?
  /// Business process(es) this risk could disrupt (comma-separated).
  affectedProcesses String?
  /// Estimated annual revenue at risk if this risk materialises.
  revenueAtRisk     Float?

  status           RiskStatus           @default(OPEN)
  treatment        TreatmentDecision?
  treatmentOwner   String?
  treatmentNotes   String?
  ownerUserId      String?
  createdByUserId  String?
  targetDate       DateTime?
  nextReviewAt     DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime?
  deletedByUserId  String?
  retentionUntil   DateTime?
  assetLinks       AssetRiskLink[]
  tenant           Tenant               @relation(fields: [tenantId], references: [id])
  controls         RiskControl[]
  // Epic G-7 — structured treatment plans (replaces free-text
  // `treatmentNotes` for ISO 27001 6.1.3 conformance).
  treatmentPlans   RiskTreatmentPlan[]
  findingLinks     FindingRisk[]
  // Evidence attached directly to this risk (Evidence Library tag +
  // the risk Evidence tab). Mirrors Control/Task.
  evidence         Evidence[]
  // RQ-2 — appetite breaches attributed to this risk.
  appetiteBreaches RiskAppetiteBreach[]
  // RQ-5 — hierarchy node memberships.
  hierarchyLinks   RiskHierarchyLink[]
  // RQ-6 — key risk indicators linked to this risk.
  kris             KeyRiskIndicator[]
  // RQ-8 — pairwise correlations (this risk on either side of the pair).
  correlationsA    RiskCorrelation[]    @relation("CorrelationA")
  correlationsB    RiskCorrelation[]    @relation("CorrelationB")
  // RQ-9 — historical snapshots.
  snapshots        RiskSnapshot[]
  // RQ2-1 — per-mutation score provenance ledger.
  scoreEvents      RiskScoreEvent[]

  /// Composite parent key — supports the
  /// `RiskTreatmentPlan.(riskId, tenantId) → Risk.(id, tenantId)`
  /// FK shape so cross-tenant treatment plans are impossible at the
  /// DB level. Same denorm-tenantId Phase-2 pattern Audit uses.
  @@unique([id, tenantId])
  // PR-B — unique within a tenant so `RSK-1` can't collide. Allows
  // `@@unique` on a nullable column (Postgres treats NULLs as
  // distinct), so historic NULL rows don't clash with each other.
  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([tenantId, deletedAt])
  // GAP-perf — supports `ownerUserId` filter in RiskFilters
  @@index([tenantId, ownerUserId])
  // GAP-perf — supports `scoreMin`/`scoreMax` range filter
  @@index([tenantId, score])
  // RQ-1 FAIR — quantitative ranking + filtering
  @@index([tenantId, fairAle])
  @@index([tenantId, lossEventFrequency])
  @@index([tenantId, fairConfidence])
  // GAP-perf — backs the default unpaginated `list()` orderBy:
  // `inherentScore desc`. Without this Postgres sorts the full
  // tenant result set per call.
  @@index([tenantId, inherentScore])
}

/// Per-tenant monotonic counter for minting `RSK-N` risk keys.
/// Mirrors `TaskKeySequence` — `upsert` with an atomic `increment`
/// is race-free under concurrent imports and scales O(1) regardless
/// of tenant size.
model RiskKeySequence {
  tenantId  String @id
  lastValue Int    @default(0)
}

/// Per-tenant monotonic counter for minting `CTL-N` custom-control
/// keys (the framework-installed controls keep their canonical
/// annexId / supplied code). Only the `createControl` path that
/// lacks an explicit code consumes this sequence; framework imports
/// supply their own code/annexId and bypass the counter entirely.
model ControlKeySequence {
  tenantId  String @id
  lastValue Int    @default(0)
}

model RiskTemplate {
  id                String   @id @default(cuid())
  title             String
  description       String?
  category          String?
  defaultLikelihood Int      @default(3)
  defaultImpact     Int      @default(3)
  frameworkTag      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// Tenant-scoped risk-matrix configuration (Epic 44).
///
/// Drives the dimensions, axis labels, per-level labels, and severity
/// bands of the likelihood × impact matrix the UI renders. Existing
/// tenants resolve to the canonical 5×5 default until an admin
/// customises it via the admin UI — the row is absent in that case;
/// the read usecase centralises the fallback so callers don't have
/// to know about presence.
///
/// `levelLabels` and `bands` are JSON because the per-level
/// vocabulary varies (operational vs. clinical vs. supply-chain
/// risks all want different scale legends) and forcing a side table
/// would buy nothing — the rows are deeply tenant-specific and
/// validated end-to-end by Zod before write. Schema invariants:
///   - `likelihoodLevels`, `impactLevels` ∈ [2, 10]
///   - `levelLabels.likelihood` length === likelihoodLevels (when set)
///   - `levelLabels.impact`     length === impactLevels (when set)
///   - `bands` cover [1, likelihoodLevels * impactLevels] without gaps
///     or overlaps; each entry has { name, minScore, maxScore, color }
///
/// One row per tenant (`@@unique([tenantId])`).
model RiskMatrixConfig {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  /// Number of likelihood levels (matrix rows). Default 5.
  likelihoodLevels    Int      @default(5)
  /// Number of impact levels (matrix columns). Default 5.
  impactLevels        Int      @default(5)
  /// Y-axis title (default "Likelihood").
  axisLikelihoodLabel String   @default("Likelihood")
  /// X-axis title (default "Impact").
  axisImpactLabel     String   @default("Impact")
  /// Per-level human labels keyed by axis. Falls back to numeric labels when absent.
  levelLabels         Json?
  /// Ordered severity bands. See doc above for the contract.
  bands               Json     @default("[]")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  tenant              Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

/// RQ-2 — board-approved risk appetite. One row per tenant; absent row
/// means no appetite configured (UI shows a "Configure" CTA).
model RiskAppetiteConfig {
  id                    String        @id @default(cuid())
  tenantId              String        @unique
  /// Max acceptable total ALE across all active risks (Σ ALE/year).
  totalAleThreshold     Float?
  /// Max acceptable ALE for any single risk.
  singleRiskAleMax      Float?
  /// Max acceptable qualitative score (likelihood × impact).
  qualScoreMax          Int?
  /// category → { totalAleMax, singleAleMax, qualScoreMax } overrides.
  categoryOverridesJson Json?
  /// Board-approved narrative statement.
  appetiteStatement     String?
  approvedByUserId      String?
  approvedAt            DateTime?
  reviewCadence         ReviewCadence @default(ANNUALLY)
  nextReviewAt          DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  tenant                Tenant        @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

/// RQ-2 — a point-in-time record of an appetite threshold breach.
/// Created by the monitor job / write-path checks; resolved when the
/// value drops back under threshold.
model RiskAppetiteBreach {
  id                  String    @id @default(cuid())
  tenantId            String
  breachType          String // PORTFOLIO_ALE | SINGLE_RISK_ALE | QUAL_SCORE | CATEGORY_ALE
  riskId              String?
  category            String?
  thresholdValue      Float
  actualValue         Float
  notifiedUserIds     Json?
  detectedAt          DateTime  @default(now())
  resolvedAt          DateTime?
  acknowledgedAt      DateTime?
  acknowledgedBy      String?
  acknowledgementNote String?
  tenant              Tenant    @relation(fields: [tenantId], references: [id])
  risk                Risk?     @relation(fields: [riskId], references: [id])

  @@index([tenantId, detectedAt])
  @@index([tenantId, breachType])
  @@index([tenantId, resolvedAt])
  @@index([riskId])
}

/// RQ-3 — a single Monte Carlo simulation execution. Immutable after
/// completion; re-running creates a new row.
model RiskSimulationRun {
  id                 String    @id @default(cuid())
  tenantId           String
  triggeredBy        String    @default("manual") // manual | scheduled | scenario
  createdByUserId    String?
  iterations         Int       @default(10000)
  confidenceLevels   Json      @default("[0.90, 0.95, 0.99]")
  seed               Int?
  riskFilterJson     Json?
  correlationId      String?
  // ── Results ──
  portfolioMean      Float?
  portfolioP50       Float?
  portfolioP90       Float?
  portfolioP95       Float?
  portfolioP99       Float?
  portfolioStdDev    Float?
  perRiskResultsJson Json?
  lecPointsJson      Json?
  convergenceDelta   Float?
  executionMs        Int?
  status             String    @default("RUNNING") // RUNNING | COMPLETED | FAILED
  errorMessage       String?
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  tenant             Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

/// RQ-4 — a hypothetical "what-if" scenario that patches the portfolio
/// before re-running the Monte Carlo simulation. Clone to iterate.
model RiskScenario {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  createdByUserId String
  /// "Before" run (null = current live portfolio is the baseline).
  baselineRunId   String?
  /// Array<ScenarioOverride> applied before simulation.
  overridesJson   Json
  /// The run executed WITH overrides applied (null until simulated).
  resultRunId     String?
  status          String   @default("DRAFT") // DRAFT | SIMULATED | ARCHIVED
  investmentCost  Float?
  computedRoi     Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

/// RQ-5 — a node in a tenant-defined org hierarchy for risk aggregation.
/// Parallel trees per `type` (BU / geography / asset class / custom).
model RiskHierarchyNode {
  id           String              @id @default(cuid())
  tenantId     String
  name         String
  type         String // BUSINESS_UNIT | GEOGRAPHY | ASSET_CLASS | CUSTOM
  parentId     String?
  sortOrder    Int                 @default(0)
  metadataJson Json?
  parent       RiskHierarchyNode?  @relation("HierarchyTree", fields: [parentId], references: [id])
  children     RiskHierarchyNode[] @relation("HierarchyTree")
  riskLinks    RiskHierarchyLink[]
  tenant       Tenant              @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, type, name])
  @@index([tenantId, type])
  @@index([tenantId, parentId])
  @@index([parentId])
}

/// RQ-5 — M:N join: a risk can sit in multiple hierarchy nodes.
model RiskHierarchyLink {
  id        String            @id @default(cuid())
  tenantId  String
  riskId    String
  nodeId    String
  createdAt DateTime          @default(now())
  risk      Risk              @relation(fields: [riskId], references: [id], onDelete: Cascade)
  node      RiskHierarchyNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  tenant    Tenant            @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, riskId, nodeId])
  @@index([tenantId, nodeId])
  @@index([tenantId, riskId])
  @@index([nodeId])
}

/// RQ-6 — a leading/lagging indicator that signals whether a risk is
/// trending toward materialisation. RAG-thresholded; readings tracked.
model KeyRiskIndicator {
  id               String       @id @default(cuid())
  tenantId         String
  riskId           String?
  name             String
  description      String?
  unit             String?
  direction        String       @default("HIGHER_IS_WORSE") // HIGHER_IS_WORSE | LOWER_IS_WORSE
  greenMax         Float?
  amberMax         Float?
  frequency        String       @default("MONTHLY") // DAILY | WEEKLY | MONTHLY | QUARTERLY
  ownerUserId      String?
  isActive         Boolean      @default(true)
  automationRuleId String?
  targetValue      Float?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  tenant           Tenant       @relation(fields: [tenantId], references: [id])
  risk             Risk?        @relation(fields: [riskId], references: [id])
  owner            User?        @relation("KriOwner", fields: [ownerUserId], references: [id])
  readings         KriReading[]

  @@index([tenantId])
  @@index([tenantId, riskId])
  @@index([tenantId, isActive])
  @@index([riskId])
  @@index([ownerUserId])
}

/// RQ-6 — a single KRI measurement; RAG computed at write time.
model KriReading {
  id         String           @id @default(cuid())
  tenantId   String
  kriId      String
  value      Float
  ragStatus  String? // GREEN | AMBER | RED
  recordedAt DateTime         @default(now())
  recordedBy String?
  note       String?
  kri        KeyRiskIndicator @relation(fields: [kriId], references: [id], onDelete: Cascade)
  tenant     Tenant           @relation(fields: [tenantId], references: [id])

  @@index([kriId, recordedAt])
  @@index([tenantId, recordedAt])
  @@index([tenantId, kriId])
}

/// RQ-8 — pairwise correlation between two risks, used by the Monte
/// Carlo engine (RQ-3) to generate correlated loss samples via Cholesky.
/// Normalised so riskAId < riskBId (one row per unordered pair).
model RiskCorrelation {
  id              String   @id @default(cuid())
  tenantId        String
  riskAId         String
  riskBId         String
  /// Pearson coefficient (-1.0 .. 1.0). Positive = co-materialise.
  coefficient     Float
  rationale       String?
  source          String   @default("MANUAL") // MANUAL | AUTO_SUGGESTED | HISTORICAL
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  riskA           Risk     @relation("CorrelationA", fields: [riskAId], references: [id], onDelete: Cascade)
  riskB           Risk     @relation("CorrelationB", fields: [riskBId], references: [id], onDelete: Cascade)

  @@unique([tenantId, riskAId, riskBId])
  @@index([tenantId])
  @@index([riskAId])
  @@index([riskBId])
}

/// RQ-9 — daily point-in-time capture of a risk's key metrics for
/// trend + velocity analysis. Created by the `risk-snapshot` cron.
model RiskSnapshot {
  id                   String   @id @default(cuid())
  tenantId             String
  riskId               String
  score                Int
  inherentScore        Int
  residualScore        Int?
  likelihood           Int
  impact               Int
  status               String
  ale                  Float?
  fairAle              Float?
  sleAmount            Float?
  aroAmount            Float?
  tef                  Float?
  vulnerability        Float?
  plm                  Float?
  activeTreatmentPlans Int      @default(0)
  snapshotAt           DateTime @default(now())
  risk                 Risk     @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tenant               Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, riskId, snapshotAt])
  @@index([tenantId, snapshotAt])
  @@index([riskId, snapshotAt])
}

/// RQ2-1 — per-mutation score provenance ledger.
///
/// Boundary vs RQ-9's `RiskSnapshot`: RiskSnapshot is a CADENCE
/// record (one row per risk per day, written by the snapshot cron,
/// for trend charts). RiskScoreEvent is a MUTATION record — exactly
/// one row per score-changing write, carrying WHO changed WHAT, from
/// what SOURCE (user edit / system derivation / plan completion / AI
/// acceptance / migration backfill), and an optional justification.
/// Trends read snapshots; explainability + audit narrative read
/// events. Neither substitutes for the other.
///
/// Written transactionally with the score write itself (same
/// `runInTenantContext` transaction) so the ledger can never drift
/// from the row state.
model RiskScoreEvent {
  id              String               @id @default(cuid())
  tenantId        String
  riskId          String
  kind            RiskScoreEventKind
  likelihood      Int
  impact          Int
  score           Int
  source          RiskScoreEventSource
  /// Free-text rationale (override reasons, plan ids, AI rationale).
  /// Plain metadata — deliberately NOT in the encryption manifest:
  /// no business content beyond what AuditLog.details already
  /// carries for the same mutations.
  justification   String?
  /// Nullable: PLAN/MIGRATION events may have no acting user.
  createdByUserId String?
  createdAt       DateTime             @default(now())
  risk            Risk                 @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tenant          Tenant               @relation(fields: [tenantId], references: [id])

  @@index([tenantId, riskId, createdAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, kind, createdAt])
}

/// RQ-9 — daily aggregate snapshot of the whole portfolio (one per
/// tenant per day) for portfolio trend charts.
model PortfolioSnapshot {
  id               String   @id @default(cuid())
  tenantId         String
  totalRiskCount   Int
  openRiskCount    Int
  quantifiedCount  Int
  totalAle         Float?
  avgAle           Float?
  maxSingleAle     Float?
  totalScore       Int
  avgScore         Float
  appetiteBreached Boolean  @default(false)
  snapshotAt       DateTime @default(now())
  tenant           Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, snapshotAt])
  @@index([tenantId, snapshotAt])
}

/// RQ-10 — a reusable report template (structure + data sources).
model ReportTemplate {
  id          String           @id @default(cuid())
  tenantId    String
  name        String
  description String?
  type        String // PORTFOLIO_SUMMARY | RISK_DEEP_DIVE | BIA | CUSTOM
  configJson  Json
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  runs        ReportRun[]
  schedules   ReportSchedule[]

  @@index([tenantId])
  @@index([tenantId, type])
}

/// RQ-10 — a single report generation execution.
model ReportRun {
  id              String         @id @default(cuid())
  tenantId        String
  templateId      String
  parametersJson  Json
  format          String // PDF | CSV
  outputPath      String?
  outputSizeBytes Int?
  status          String         @default("QUEUED") // QUEUED | GENERATING | COMPLETED | FAILED
  errorMessage    String?
  requestedBy     String?
  deliverToJson   Json?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  template        ReportTemplate @relation(fields: [templateId], references: [id])
  tenant          Tenant         @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([templateId])
}

/// RQ-10 — scheduled report delivery configuration.
model ReportSchedule {
  id                 String         @id @default(cuid())
  tenantId           String
  templateId         String
  parametersJson     Json
  format             String         @default("PDF")
  cadence            String // WEEKLY | MONTHLY | QUARTERLY
  deliveryDay        Int?
  recipientsJson     Json
  sharePointDriveId  String?
  sharePointFolderId String?
  isActive           Boolean        @default(true)
  nextRunAt          DateTime?
  lastRunAt          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  template           ReportTemplate @relation(fields: [templateId], references: [id])
  tenant             Tenant         @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([nextRunAt, isActive])
  @@index([templateId])
}

model RiskSuggestionSession {
  id              String                  @id @default(cuid())
  tenantId        String
  createdByUserId String
  status          SuggestionSessionStatus @default(DRAFT)
  inputJson       String
  modelName       String?
  provider        String                  @default("stub")
  errorMessage    String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  items           RiskSuggestionItem[]
  createdBy       User                    @relation("SuggestionSessionCreator", fields: [createdByUserId], references: [id])
  tenant          Tenant                  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

model RiskSuggestionItem {
  id                    String                @id @default(cuid())
  sessionId             String
  tenantId              String
  assetId               String?
  title                 String
  description           String?
  category              String?
  threat                String?
  vulnerability         String?
  likelihoodSuggested   Int?
  impactSuggested       Int?
  rationale             String?
  suggestedControlsJson String?
  status                SuggestionItemStatus  @default(PENDING)
  editedJson            String?
  createdRiskId         String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  asset                 Asset?                @relation(fields: [assetId], references: [id])
  suggestionSession     RiskSuggestionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  session               Tenant                @relation(fields: [tenantId], references: [id])

  @@index([sessionId])
  @@index([tenantId])
  @@index([tenantId, sessionId])
}

model Control {
  id                           String                   @id @default(cuid())
  tenantId                     String?
  code                         String?
  annexId                      String?                  @unique
  name                         String
  description                  String?
  intent                       String?
  category                     String?
  status                       ControlStatus            @default(NOT_STARTED)
  effectiveness                Int?
  lastTested                   DateTime?
  reviewCadence                ReviewCadence?
  isCustom                     Boolean                  @default(false)
  ownerUserId                  String?
  createdByUserId              String?
  frequency                    ControlFrequency?
  nextDueAt                    DateTime?
  evidenceSource               EvidenceSourceType?
  automationKey                String?
  automationType               ControlAutomationType?
  mitigationType               ControlMitigationType?
  applicability                Applicability            @default(APPLICABLE)
  applicabilityJustification   String?
  applicabilityDecidedByUserId String?
  applicabilityDecidedAt       DateTime?
  createdAt                    DateTime                 @default(now())
  updatedAt                    DateTime                 @updatedAt
  deletedAt                    DateTime?
  deletedByUserId              String?
  retentionUntil               DateTime?
  applicabilityDecidedBy       User?                    @relation("ControlApplicabilityDecider", fields: [applicabilityDecidedByUserId], references: [id])
  createdBy                    User?                    @relation("ControlCreator", fields: [createdByUserId], references: [id])
  owner                        User?                    @relation("ControlOwner", fields: [ownerUserId], references: [id])
  tenant                       Tenant?                  @relation(fields: [tenantId], references: [id])
  assets                       ControlAsset[]
  contributors                 ControlContributor[]
  evidenceLinks                ControlEvidenceLink[]
  requirementLinks             ControlRequirementLink[]
  controlTasks                 ControlTask[]
  testPlans                    ControlTestPlan[]
  testRuns                     ControlTestRun[]
  evidence                     Evidence[]
  frameworkMappings            FrameworkMapping[]
  findings                     Finding[]                @relation("FindingControl")
  compensatingForFindings      Finding[]                @relation("FindingCompensatingControl")
  integrationExecutions        IntegrationExecution[]
  policyLinks                  PolicyControlLink[]
  risks                        RiskControl[]
  tasks                        Task[]
  // Epic G-5 — control exception register. Two reverse relations:
  // (a) exceptions registered against THIS control,
  // (b) exceptions that name THIS control as their compensating
  //     control (i.e. "we mitigate the gap by doing this").
  exceptions                   ControlException[]       @relation("ControlExceptionAffected")
  compensatingForExceptions    ControlException[]       @relation("ControlExceptionCompensating")

  /// Composite parent key — supports the
  /// `ControlException.(controlId, tenantId) → Control.(id, tenantId)`
  /// FK shape, so a cross-tenant exception link is impossible at
  /// the DB level. Same denorm-tenantId Phase-2 pattern used by
  /// AuditChecklistItem → Audit.
  @@unique([id, tenantId])
  @@index([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, applicability])
  @@index([ownerUserId])
  @@index([nextDueAt])
  @@index([tenantId, deletedAt])
  // GAP-perf — supports `ownerUserId` filter in tenant scope.
  // `[ownerUserId]` alone exists but isn't tenant-prefixed, so
  // Postgres can't selectively scan one tenant's slice for a
  // specific owner without an additional filter pass.
  @@index([tenantId, ownerUserId])
  // GAP-perf — supports `category` filter (free-text exact match).
  @@index([tenantId, category])
}

model RiskControl {
  id              String   @id @default(cuid())
  riskId          String
  controlId       String
  tenantId        String
  rationale       String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  control         Control  @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy       User?    @relation("RiskControlCreator", fields: [createdByUserId], references: [id])
  risk            Risk     @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, riskId, controlId])
  @@index([tenantId, controlId])
  @@index([tenantId])
}

model ControlAsset {
  id              String       @id @default(cuid())
  controlId       String
  assetId         String
  tenantId        String
  coverageType    CoverageType @default(UNKNOWN)
  rationale       String?
  createdByUserId String?
  createdAt       DateTime     @default(now())
  asset           Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  control         Control      @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy       User?        @relation("ControlAssetCreator", fields: [createdByUserId], references: [id])
  tenant          Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, controlId, assetId])
  @@index([tenantId, assetId])
  @@index([tenantId])
}

model AssetRiskLink {
  id              String        @id @default(cuid())
  tenantId        String
  assetId         String
  riskId          String
  exposureLevel   ExposureLevel @default(MEDIUM)
  rationale       String?
  createdByUserId String?
  createdAt       DateTime      @default(now())
  asset           Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdBy       User?         @relation("AssetRiskCreator", fields: [createdByUserId], references: [id])
  risk            Risk          @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, assetId, riskId])
  @@index([tenantId, riskId])
  @@index([tenantId])
}

model ControlContributor {
  id        String   @id @default(cuid())
  tenantId  String
  controlId String
  userId    String
  createdAt DateTime @default(now())
  control   Control  @relation(fields: [controlId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([controlId, userId])
  @@index([tenantId])
}

model ControlTask {
  id             String            @id @default(cuid())
  tenantId       String
  controlId      String
  title          String
  description    String?
  status         ControlTaskStatus @default(OPEN)
  assigneeUserId String?
  dueAt          DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  assignee       User?             @relation("ControlTaskAssignee", fields: [assigneeUserId], references: [id])
  control        Control           @relation(fields: [controlId], references: [id], onDelete: Cascade)
  tenant         Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([controlId])
  @@index([status])
  @@index([dueAt])
  // GAP-perf — backs the dashboard "overdue tasks" query
  // (status IN ('OPEN','IN_PROGRESS') AND dueAt < now()) and the
  // refactored `runConsistencyCheck` overdue lookup. The
  // single-column `[status]` and `[dueAt]` indexes can't satisfy
  // the combined predicate efficiently.
  @@index([tenantId, status, dueAt])
}

model ControlEvidenceLink {
  id                  String           @id @default(cuid())
  tenantId            String
  controlId           String
  kind                EvidenceLinkKind
  fileId              String?
  url                 String?
  integrationResultId String?
  note                String?
  createdByUserId     String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  control             Control          @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy           User?            @relation("ControlEvidenceCreator", fields: [createdByUserId], references: [id])
  tenant              Tenant           @relation(fields: [tenantId], references: [id])

  @@unique([controlId, kind, fileId])
  @@unique([controlId, kind, url])
  @@index([tenantId])
  @@index([controlId])
}

model ControlTemplate {
  id               String                           @id @default(cuid())
  code             String                           @unique
  title            String
  description      String?
  category         String?
  defaultFrequency ControlFrequency?
  defaultOwnerHint String?
  isGlobal         Boolean                          @default(true)
  createdAt        DateTime                         @default(now())
  requirementLinks ControlTemplateRequirementLink[]
  tasks            ControlTemplateTask[]
  packLinks        PackTemplateLink[]
}

model ControlTemplateTask {
  id          String          @id @default(cuid())
  templateId  String
  title       String
  description String?
  template    ControlTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ControlTemplateRequirementLink {
  id            String               @id @default(cuid())
  templateId    String
  requirementId String
  requirement   FrameworkRequirement @relation(fields: [requirementId], references: [id])
  template      ControlTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, requirementId])
}

model Evidence {
  id                String                    @id @default(cuid())
  tenantId          String
  controlId         String?
  // Source task — set when this evidence was uploaded/linked from a
  // task's Evidence tab. Powers the task Evidence tab AND the
  // "uploaded from" back-reference on the evidence detail surface.
  taskId            String?
  // Source risk / asset — same pattern as taskId: set when uploaded
  // from that entity's Evidence tab; powers the attached-evidence tab
  // + the "uploaded from" back-reference.
  riskId            String?
  assetId           String?
  type              EvidenceType
  title             String
  content           String?
  fileName          String?
  fileSize          Int?
  category          String?
  dateCollected     DateTime                  @default(now())
  owner             String? // Legacy free-text — kept for backward compat
  ownerUserId       String? // Real user FK — used for due-item routing & notifications
  reviewCycle       ReviewCadence?
  nextReviewDate    DateTime?
  status            EvidenceStatus            @default(DRAFT)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  deletedAt         DateTime?
  deletedByUserId   String?
  fileRecordId      String?
  expiredAt         DateTime?
  isArchived        Boolean                   @default(false)
  retentionDays     Int?
  retentionPolicy   RetentionPolicy           @default(NONE)
  retentionUntil    DateTime?
  /// B8 follow-up — free-text folder label (e.g. "SOC2/2026" or
  /// "Quarterly access reviews"). Mirrors the `VendorDocument.folder`
  /// pattern. Nullable; null/empty maps to "no folder" in the UI.
  /// Sanitised + trimmed at the usecase boundary.
  folder            String?
  testEvidenceLinks ControlTestEvidenceLink[]
  // Epic G-3 — vendor questionnaire FILE_UPLOAD answers attach
  // their proof here.
  vendorAnswers     VendorAssessmentAnswer[]  @relation("VendorAnswerEvidence")
  control           Control?                  @relation(fields: [controlId], references: [id])
  task              Task?                     @relation(fields: [taskId], references: [id])
  risk              Risk?                     @relation(fields: [riskId], references: [id])
  asset             Asset?                    @relation(fields: [assetId], references: [id])
  fileRecord        FileRecord?               @relation(fields: [fileRecordId], references: [id])
  ownerUser         User?                     @relation("EvidenceOwner", fields: [ownerUserId], references: [id])
  tenant            Tenant                    @relation(fields: [tenantId], references: [id])
  reviews           EvidenceReview[]
  findingLinks      FindingEvidence[]
  reminderHistories ReminderHistory[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, deletedAt])
  @@index([tenantId, retentionUntil])
  @@index([tenantId, isArchived])
  @@index([tenantId, ownerUserId])
  // GAP-perf — supports `status` filter (DRAFT|SUBMITTED|APPROVED|REJECTED).
  @@index([tenantId, status])
  // GAP-perf — supports `controlId` filter ("evidence for control X").
  // Already a heavily-used UI surface — every control detail page
  // pulls evidence by controlId.
  @@index([tenantId, controlId])
  // Supports the task Evidence tab ("evidence for task X") + the
  // evidence "uploaded from" back-reference lookup.
  @@index([tenantId, taskId])
  // Same, for the risk + asset Evidence tabs.
  @@index([tenantId, riskId])
  @@index([tenantId, assetId])
  // GAP-perf — supports `type` filter (FILE|LINK|TEXT|SCREENSHOT).
  @@index([tenantId, type])
  // B8 follow-up — supports folder filter + group-by reads. Same
  // shape as VendorDocument's folder index.
  @@index([tenantId, folder])
}

model FileRecord {
  id               String           @id @default(cuid())
  tenantId         String
  pathKey          String           @unique
  originalName     String
  mimeType         String
  sizeBytes        Int
  sha256           String
  status           FileRecordStatus @default(PENDING)
  uploadedByUserId String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  storedAt         DateTime?
  bucket           String?
  domain           String           @default("general")
  scanStatus       String           @default("PENDING")
  storageProvider  String           @default("local")
  scanDetails      String?
  scannedAt        DateTime?
  deletedAt        DateTime?
  deletedByUserId  String?
  retentionUntil   DateTime?
  evidence         Evidence[]
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  uploadedBy       User             @relation("FileUploader", fields: [uploadedByUserId], references: [id])
  // Epic G-4 — campaigns whose evidence PDF this row carries.
  accessReviews    AccessReview[]   @relation("AccessReviewEvidence")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, scanStatus])
  @@index([tenantId, deletedAt])
}

model EvidenceReview {
  // denorm-tenantId — Phase 2: tenantId is NOT NULL and the parent
  // relation is composite (evidenceId, tenantId) → Evidence(id,
  // tenantId), which structurally guarantees this row's tenantId
  // matches its parent's. Phase 3 swaps the chained RLS policy for
  // the trivial direct form.
  id         String       @id @default(cuid())
  tenantId   String
  evidenceId String
  reviewerId String
  action     ReviewAction
  comment    String?
  createdAt  DateTime     @default(now())
  evidence   Evidence     @relation(fields: [evidenceId, tenantId], references: [id, tenantId], onDelete: Cascade)
  reviewer   User         @relation(fields: [reviewerId], references: [id])
  tenant     Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, evidenceId])
}

model Policy {
  id                   String              @id @default(cuid())
  tenantId             String
  slug                 String
  title                String
  description          String?
  category             String?
  status               PolicyStatus        @default(DRAFT)
  currentVersionId     String?             @unique
  ownerUserId          String?
  reviewFrequencyDays  Int?
  nextReviewAt         DateTime?
  language             String?             @default("en")
  /// Lifecycle version counter (matches CISO-Assistant editing_version).
  /// 1 = initial content, 2+ = published. Incremented only on publish.
  lifecycleVersion     Int                 @default(1)
  /// Persisted history of prior published snapshots as JSON array.
  /// Matches CISO-Assistant editing_history. Entries have fields:
  /// version, payload, publishedAt, publishedBy, changeSummary (optional)
  lifecycleHistoryJson Json?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  deletedAt            DateTime?
  deletedByUserId      String?
  retentionUntil       DateTime?
  /// SP-4 — SharePoint document link (bidirectional policy sync).
  spDriveId            String?
  spItemId             String?
  /// Last known SharePoint eTag — drives conflict detection on push/pull.
  spItemETag           String?
  spWebUrl             String?
  /// Active Graph change-notification subscription id (null when unlinked).
  spSubscriptionId     String?
  /// SP-F1 — the IntegrationConnection backing this link (multi-connection
  /// tenants). Null on pre-SP-F1 links → resolve the tenant's first connection.
  spConnectionId       String?
  currentVersion       PolicyVersion?      @relation("CurrentVersion", fields: [currentVersionId], references: [id])
  owner                User?               @relation("PolicyOwner", fields: [ownerUserId], references: [id])
  tenant               Tenant              @relation(fields: [tenantId], references: [id])
  approvals            PolicyApproval[]
  controlLinks         PolicyControlLink[]
  versions             PolicyVersion[]     @relation("PolicyVersions")

  @@unique([id, tenantId])
  @@index([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([nextReviewAt])
  @@index([tenantId, deletedAt])
}

model PolicyVersion {
  id               String                  @id @default(cuid())
  policyId         String
  versionNumber    Int
  contentType      PolicyContentType       @default(MARKDOWN)
  contentText      String?
  externalUrl      String?
  changeSummary    String?
  createdById      String
  createdAt        DateTime                @default(now())
  tenantId         String
  currentOfPolicy  Policy?                 @relation("CurrentVersion")
  acknowledgements PolicyAcknowledgement[]
  approvals        PolicyApproval[]
  createdBy        User                    @relation("PolicyVersionCreator", fields: [createdById], references: [id])
  policy           Policy                  @relation("PolicyVersions", fields: [policyId], references: [id], onDelete: Cascade)
  tenant           Tenant                  @relation(fields: [tenantId], references: [id])

  @@unique([policyId, versionNumber])
  @@index([tenantId])
}

model PolicyApproval {
  id                String               @id @default(cuid())
  tenantId          String
  policyId          String
  policyVersionId   String
  requestedByUserId String
  approvedByUserId  String?
  status            PolicyApprovalStatus @default(PENDING)
  decidedAt         DateTime?
  comment           String?
  createdAt         DateTime             @default(now())
  approvedBy        User?                @relation("PolicyApprover", fields: [approvedByUserId], references: [id])
  policy            Policy               @relation(fields: [policyId], references: [id], onDelete: Cascade)
  policyVersion     PolicyVersion        @relation(fields: [policyVersionId], references: [id], onDelete: Cascade)
  requestedBy       User                 @relation("PolicyApprovalRequester", fields: [requestedByUserId], references: [id])
  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // FK reverse-lookup indexes. PolicyApproval is now first-class
  // tenant-scoped (carries its own tenantId — direct RLS, not
  // ownership-chained), so the FK reverse lookups ride tenant-leading
  // composites. tenantId leads both, so no separate @@index([tenantId]).
  @@index([tenantId, policyId])
  @@index([tenantId, policyVersionId])
}

model PolicyAcknowledgement {
