  // Policy side. The Control side stays single-column because
  // Control.tenantId is intentionally nullable (library-derived
  // controls are global). The pre-denorm chained RLS only walked
  // via Policy too, so this matches the existing protection model
  // and additionally lifts read perf into the trivial RLS path.
  id        String  @id @default(cuid())
  tenantId  String
  policyId  String
  controlId String
  control   Control @relation(fields: [controlId], references: [id], onDelete: Cascade)
  policy    Policy  @relation(fields: [policyId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenant    Tenant  @relation(fields: [tenantId], references: [id])

  @@unique([policyId, controlId])
  @@index([tenantId])
  @@index([tenantId, policyId])
  @@index([tenantId, controlId])
}

model PolicyTemplate {
