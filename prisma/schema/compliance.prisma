// ─────────────────────────────────────────────────────────────────
//  GAP-09 — multi-file schema: COMPLIANCE
//
//  Core compliance domain. Owns:
//    • Control + ControlEvidenceLink + ControlContributor +
//      ControlTask + ControlTest models
//    • Risk + RiskTemplate + RiskControl (M:N risk↔control)
//    • Evidence + EvidenceLink + EvidencePackage
//    • Framework + FrameworkRequirement + FrameworkMapping
//    • Clause + ClauseEvidence
//    • Policy + PolicyVersion + PolicyApproval + PolicyContributor
//    • Asset + AssetEvidence + AssetCoverage
//    • Issue + IssueComment + Finding + FindingTask
//    • Task (work-item — distinct from ControlTask) + TaskLink +
//      TaskComment + TaskWatcher
//    • TraceabilityLink (cross-entity weave)
//
//  Note: Audit models (AuditCycle, AuditPack, …) live in
//  `audit.prisma`. Vendor risk lives in `vendor.prisma`. They are
//  separated because each has a distinct API surface, separate
//  RLS policies, and tends to evolve on its own cadence.
//
//  This file is currently empty. Models will land here in focused
//  follow-up PRs.
// ─────────────────────────────────────────────────────────────────

model Clause {
  id          String           @id @default(cuid())
  number      String           @unique
  title       String
  description String?
  artifacts   String?
  sortOrder   Int              @default(0)
  progress    ClauseProgress[]
}

model ClauseProgress {
  id        String       @id @default(cuid())
  tenantId  String
  clauseId  String
  status    ClauseStatus @default(NOT_STARTED)
  notes     String?
  updatedAt DateTime     @updatedAt
  clause    Clause       @relation(fields: [clauseId], references: [id])
  tenant    Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, clauseId])
}

model Task {
  id              String           @id @default(cuid())
  tenantId        String
  type            WorkItemType     @default(TASK)
  title           String
  description     String?
  severity        WorkItemSeverity @default(MEDIUM)
  priority        WorkItemPriority @default(P2)
  status          WorkItemStatus   @default(OPEN)
  source          WorkItemSource?  @default(MANUAL)
  key             String?
  resolution      String?
  dueAt           DateTime?
  completedAt     DateTime?
  createdByUserId String
  assigneeUserId  String?
  reviewerUserId  String?
  controlId       String?
  metadataJson    Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?
  assignee        User?            @relation("TaskAssignee", fields: [assigneeUserId], references: [id])
  control         Control?         @relation(fields: [controlId], references: [id])
  createdBy       User             @relation("TaskCreator", fields: [createdByUserId], references: [id])
  reviewer        User?            @relation("TaskReviewer", fields: [reviewerUserId], references: [id])
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  comments        TaskComment[]
  links           TaskLink[]
  watchers        TaskWatcher[]
  // Evidence attached directly to this task — the task Evidence tab
  // mirrors the control Evidence tab. `Evidence.taskId` is the source
  // pointer that also powers the "uploaded from" back-reference on the
  // evidence detail surface.
  evidence        Evidence[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, severity])
  @@index([tenantId, assigneeUserId])
  @@index([tenantId, controlId])
  // #102 item 4 — the control-detail Tasks tab filters by both
  // controlId AND status; this composite serves that hot path.
  @@index([tenantId, controlId, status])
  @@index([tenantId, deletedAt])
  @@index([tenantId, priority, createdAt])
  // #102 item 4 — `[tenantId, dueAt]` dropped: it is a strict
  // prefix of `[tenantId, dueAt, status]` below, so the planner
  // never needs both.
  @@index([tenantId, dueAt, status])
}

/// Per-tenant monotonic counter for minting `TSK-N` work-item keys.
///
/// #102 item 2 — replaces the `db.task.count()` derivation in
/// `WorkItemRepository.create`, which raced against the unique
/// `[tenantId, key]` index under concurrent imports and scaled
/// linearly with tenant size. `upsert` with an atomic `increment`
/// (native `INSERT … ON CONFLICT DO UPDATE`) is race-free.
///
/// RLS: tenant-scoped (Class A — `tenant_isolation` USING +
/// `tenant_isolation_insert` WITH CHECK + `superuser_bypass`,
/// `FORCE ROW LEVEL SECURITY`). See the companion migration.
model TaskKeySequence {
  tenantId  String @id
  lastValue Int    @default(0)
}

model TaskLink {
  id         String             @id @default(cuid())
  tenantId   String
  taskId     String
  entityType TaskLinkEntityType
  entityId   String
  relation   TaskLinkRelation   @default(RELATES_TO)
  createdAt  DateTime           @default(now())
  task       Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant     Tenant             @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, taskId, entityType, entityId])
  @@index([tenantId, taskId])
  @@index([tenantId, entityType, entityId])
}

model TaskComment {
  id              String   @id @default(cuid())
  tenantId        String
  taskId          String
  body            String
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       User     @relation("TaskCommentCreator", fields: [createdByUserId], references: [id])
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, taskId])
}

model TaskWatcher {
  id       String @id @default(cuid())
  tenantId String
  taskId   String
  userId   String
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@index([tenantId, taskId])
}

model Asset {
  id                  String               @id @default(cuid())
  tenantId            String
  /// Generated per-tenant short key (`AST-1`, `AST-2`, …) so the
  /// Assets list page can lead with a scannable Code column.
  /// Mints atomically via `AssetKeySequence.upsert` (same race-
  /// free pattern Task / Risk use). Nullable to keep historic
  /// rows renderable; the create-path generates a key for every
  /// new row.
  key                 String?
  name                String
  type                AssetType
  classification      String?
  owner               String?
  location            String?
  confidentiality     Int?                 @default(3)
  integrity           Int?                 @default(3)
  availability        Int?                 @default(3)
  dependencies        String?
  businessProcesses   String?
  dataResidency       String?
  retention           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  ownerUserId         String?
  criticality         Criticality?
  status              AssetStatus          @default(ACTIVE)
  externalRef         String?
  tags                String?
  /// Structured product identity for CVE matching (vuln integration).
  /// Optional + best-effort: tenants populate these to turn the global
  /// CVE catalog into a targeted "you are affected" signal. Without
  /// them, CVE→asset matching degrades to manual linking. `cpe` is a
  /// CPE 2.3 string (e.g. cpe:2.3:a:openssl:openssl:3.0.0:*:*:*:*:*:*:*);
  /// vendor/product/version are the human-friendly fallback used when
  /// no full CPE is recorded.
  cpe                 String?
  vendor              String?
  product             String?
  version             String?
  deletedAt           DateTime?
  deletedByUserId     String?
  retentionUntil      DateTime?
  ownerUser           User?                @relation("AssetOwner", fields: [ownerUserId], references: [id])
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  risks               AssetRiskLink[]
  controls            ControlAsset[]
  vulnerabilities     AssetVulnerability[]
  riskSuggestionItems RiskSuggestionItem[]
  // Evidence attached directly to this asset (Evidence Library tag +
  // the asset Evidence tab). Mirrors Control/Task.
  evidence            Evidence[]

  /// Unique within a tenant — `AST-N` collisions are race-free
  /// via the AssetKeySequence counter.
  @@unique([tenantId, key])
  @@index([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, type])
  @@index([tenantId, criticality])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
}

/// Per-tenant monotonic counter for minting `AST-N` asset keys.
/// Mirrors `TaskKeySequence` / `RiskKeySequence` — `upsert` with
/// an atomic `increment` is race-free under concurrent imports.
model AssetKeySequence {
  tenantId  String @id
  lastValue Int    @default(0)
}

/// Global CVE catalog — shared reference data, NOT tenant-scoped (like
/// the framework/clause reference tables). Has no `tenantId`, so it is
/// RLS-exempt by construction: `TENANT_SCOPED_MODELS` is DMMF-derived
/// from the presence of a `tenantId` field, and the rls-coverage
/// guardrail only enforces RLS on that set. Populated by the daily
/// `nvd-cve-sync` job from the NIST NVD 2.0 API. Read-only to tenants.
model Cve {
  /// The CVE id itself, e.g. `CVE-2026-1234`.
  id             String   @id
  publishedAt    DateTime
  lastModifiedAt DateTime
  /// CVSS v3.1 base score (0.0–10.0) when NVD provides one.
  cvssScore      Float?
  /// LOW | MEDIUM | HIGH | CRITICAL (CVSS v3.1 base severity).
  cvssSeverity   String?
  summary        String
  /// Affected CPE 2.3 match strings extracted from the NVD configurations.
  cpeMatches     String[]
  references     String[]
  fetchedAt      DateTime @default(now())

  vulnerabilities AssetVulnerability[]

  // Backs the catalog list + the incremental-sync cursor
  // (max(lastModifiedAt)) and the severity-filtered surfacing.
  @@index([cvssSeverity, publishedAt])
  @@index([lastModifiedAt])
}

/// Tenant-scoped: a CVE matched (or manually linked) to one of the
/// tenant's assets. Full RLS + Epic B encryption (`note`) + Epic D
/// sanitisation + index coverage (it carries a `tenantId`, so the
/// rls-coverage / schema-index guardrails enforce all three).
model AssetVulnerability {
  id         String   @id @default(cuid())
  tenantId   String
  assetId    String
  cveId      String
  /// OPEN | MITIGATING | MITIGATED | ACCEPTED | FALSE_POSITIVE
  status     String   @default("OPEN")
  matchedAt  DateTime @default(now())
  /// How the link was made: 'CPE' (automatic) | 'MANUAL' (tenant-linked).
  matchedVia String
  /// Free-text analyst note — encrypted at rest (Epic B manifest) and
  /// sanitised on write (Epic D).
  note       String?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  asset  Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  cve    Cve    @relation(fields: [cveId], references: [id], onDelete: Cascade)

  /// One link per (asset, cve) within a tenant — re-matching is idempotent.
  @@unique([tenantId, assetId, cveId])
  @@index([tenantId, status])
  @@index([tenantId, assetId])
  @@index([tenantId, cveId])
  @@index([cveId])
  @@index([assetId])
}

/// Tenant-scoped: one DevSecOps scanner execution (SAST/SCA/DAST/SECRETS/
/// IAC) ingested into IC. The FIRST connector of the "external security
/// signal → compliance graph" subsystem — a sibling to Cve /
/// AssetVulnerability, NOT a parallel path. A PASSING run is materialised
/// as automated control evidence (ControlEvidenceLink, kind
/// INTEGRATION_RESULT); FAILING findings reconcile into `Finding` rows
/// (sourceKind='SCANNER'). Full RLS + index coverage (tenantId present).
model ScannerRun {
  id           String           @id @default(cuid())
  tenantId     String
  /// 'SEMGREP'|'TRIVY'|'ZAP'|'GITLEAKS'|'CHECKOV'|'CODEQL'|'OTHER'.
  source       String
  /// 'SAST'|'SCA'|'DAST'|'SECRETS'|'IAC'.
  scanType     String
  ranAt        DateTime
  /// 'PASS'|'FAIL'|'ERROR' — the gate outcome (reported by CI or derived
  /// from the max finding severity vs the configured threshold).
  outcome      String
  /// Repo / project the scan ran against (free-text ref, e.g.
  /// `owner/repo@<sha>`). NOT encrypted — a project identifier, not content.
  repoRef      String?
  findingCount Int              @default(0)
  /// 'API'|'WEBHOOK'|'UPLOAD' — how the SARIF reached IC.
  ingestedVia  String
  createdAt    DateTime         @default(now())

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  findings ScannerFinding[]

  @@index([tenantId, source, ranAt])
  @@index([tenantId, scanType, ranAt])
  @@index([tenantId])
}

/// A user account discovered in a connected directory / identity provider
/// (Okta, Google Workspace — PR-2). Synced idempotently by the
/// `identity-sync` job and joined against Personnel (PR-4) for
/// offboarded-access checks. `groupsJson` is a string[] of group names.
/// Not encrypted — directory metadata (email + status flags), not content.
model ConnectedIdentityAccount {
  id             String                 @id @default(cuid())
  tenantId       String
  /// Provider prefix — 'okta' | 'google-workspace'. Matches the
  /// ScheduledCheckProvider id so `{provider}.{check}` routing lines up.
  provider       String
  /// Stable id of the user in the provider's directory.
  externalUserId String
  email          String
  displayName    String?
  status         ConnectedAccountStatus @default(ACTIVE)
  isAdmin        Boolean                @default(false)
  mfaEnrolled    Boolean                @default(false)
  /// string[] of group / role names the account belongs to.
  groupsJson     Json                   @default("[]")
  lastActiveAt   DateTime?
  syncedAt       DateTime
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  tenant           Tenant                          @relation(fields: [tenantId], references: [id])
  reviewDecisions  AccessReviewConnectedDecision[]

  @@unique([tenantId, provider, externalUserId])
  @@index([tenantId, provider])
  @@index([tenantId, status])
}

/// A security-awareness training course (PR-6). Provider-synced (KnowBe4) or
/// manual. `cadenceDays` drives the annual-completion check.
model TrainingCourse {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  provider    String?
  cadenceDays Int?     @default(365)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant               @relation(fields: [tenantId], references: [id])
  assignments TrainingAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// A training assignment to an employee (PR-6).
model TrainingAssignment {
  id          String         @id @default(cuid())
  tenantId    String
  employeeId  String
  courseId    String
  status      TrainingStatus @default(ASSIGNED)
  assignedAt  DateTime       @default(now())
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  employee Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  course   TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@index([tenantId, courseId])
}

/// A background check for an employee (PR-6). `resultSummary` is encrypted at
/// rest (Epic B manifest) — it can quote adverse-action detail.
model BackgroundCheck {
  id            String                @id @default(cuid())
  tenantId      String
  employeeId    String
  provider      String?
  status        BackgroundCheckStatus @default(PENDING)
  requestedAt   DateTime?
  completedAt   DateTime?
  resultSummary String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
}

/// A managed endpoint / device (PR-5). Reported by an MDM or a per-tenant
/// device agent (token-authed) or entered manually. Optionally linked to an
/// Employee. The boolean posture fields are THREE-STATE: true (pass), false
/// (fail), null (NOT_APPLICABLE — e.g. LINUX has no screen-lock check). Never
/// treat null as fail.
model Device {
  id                    String         @id @default(cuid())
  tenantId              String
  employeeId            String?
  serialNumber          String?
  hostname              String?
  platform              DevicePlatform
  /// 'MDM' | 'AGENT' | 'MANUAL'.
  source                String         @default("MANUAL")
  diskEncrypted         Boolean?
  screenLockEnabled     Boolean?
  antivirusRunning      Boolean?
  passwordManagerPresent Boolean?
  lastCheckIn           DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@unique([tenantId, serialNumber])
  @@index([tenantId, employeeId])
  @@index([tenantId, platform])
}

/// A personnel record (PR-4). The people-layer hub — PR-5 devices + PR-6
/// training/background attach here. Synced from an HRIS or entered manually;
/// idempotent by (tenantId, workEmail). TERMINATED employees whose identity
/// account is still ACTIVE are the offboarded_access_removed gap signal.
model Employee {
  id                String           @id @default(cuid())
  tenantId          String
  /// Stable id in the source HRIS (null for manual records).
  externalId        String?
  fullName          String
  workEmail         String
  status            EmploymentStatus @default(ACTIVE)
  department        String?
  jobTitle          String?
  /// Self-reference to the manager's Employee row.
  managerEmployeeId String?
  startDate         DateTime?
  endDate           DateTime?
  /// 'HRIS' | 'MANUAL'.
  source            String           @default("MANUAL")
  syncedAt          DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  manager  Employee?  @relation("EmployeeManager", fields: [managerEmployeeId], references: [id], onDelete: SetNull)
  reports  Employee[] @relation("EmployeeManager")
  devices  Device[]
  trainingAssignments TrainingAssignment[]
  backgroundChecks    BackgroundCheck[]

  @@unique([tenantId, workEmail])
  @@index([tenantId, status])
  @@index([tenantId, managerEmployeeId])
}

/// Tenant-scoped normalised finding from a ScannerRun. Deduped across
/// re-scans by `fingerprint` (SHA-256 of ruleId+location+message), so a
/// recurring finding stays one row (the unique constraint makes ingest
/// idempotent). `description` is Epic B-encrypted + Epic D-sanitised —
/// scanner messages can quote source snippets / secrets.
model ScannerFinding {
  id           String     @id @default(cuid())
  scannerRunId String
  tenantId     String
  /// SHA-256 fingerprint of (ruleId, location, message). Re-scans upsert
  /// on (tenantId, fingerprint) — one row per distinct finding per tenant.
  fingerprint  String
  ruleId       String
  /// 'LOW'|'MEDIUM'|'HIGH'|'CRITICAL' — mapped from SARIF `level` + the
  /// tool's own severity via the documented matrix (sarif.ts).
  severity     String
  title        String
  /// Encrypted at rest (Epic B manifest) + sanitised on write (Epic D).
  description  String?
  /// 'file:line' the finding points at.
  location     String?
  /// CWE refs (e.g. 'CWE-79') from the SARIF rule metadata — drive the
  /// CWE → OWASP/SSDF framework cross-walk.
  cweIds       String[]   @default([])
  /// OPEN|TRIAGED|FIXED|FALSE_POSITIVE|ACCEPTED — triage lifecycle.
  status       String     @default("OPEN")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  scannerRun ScannerRun @relation(fields: [scannerRunId], references: [id], onDelete: Cascade)

  /// Idempotent ingest: re-scanning the same issue updates this one row.
  @@unique([tenantId, fingerprint])
  @@index([tenantId, scannerRunId, status])
  @@index([tenantId, status, severity])
  @@index([scannerRunId])
}

model Risk {
  id                 String    @id @default(cuid())
  tenantId           String
  /// PR-B — generated per-tenant short key (RSK-1, RSK-2, …) so the
  /// Risk list page can lead with a scannable identifier column.
  /// Mints atomically via `RiskKeySequence.upsert` mirroring the
  /// TaskKeySequence pattern. Nullable to keep historic rows
  /// renderable; the create-path generates fresh values for every
  /// new row.
  key                String?
  title              String
  description        String?
  category           String?
  threat             String?
  vulnerability      String?
  likelihood         Int       @default(3)
  impact             Int       @default(3)
  score              Int       @default(9)
  /// The CURRENT inherent assessment (likelihood × impact at the
  /// latest edit) — moves together with `score` on every L/I update.
  /// NOT a frozen creation-time value; the full change history lives
  /// in `RiskScoreEvent` (RQ2-1).
  inherentScore      Int       @default(9)
  /// Residual risk score — the auditor's "after controls implemented"
  /// view. Distinct from `inherentScore` and `score` (both of which
  /// move together on every likelihood/impact edit — the "current
  /// inherent assessment", NOT a frozen creation-time value; RQ2-1
  /// fixed this doc to match the long-standing behavior of
  /// `updateRisk`).
  ///
  /// NULL until the first residual assessment lands. Written by:
  ///   (a) treatment-plan completion (`completePlan`,
  ///       source: PLAN — strategy-based until RQ2-2 replaces the
  ///       divisors with control-effectiveness derivation), or
  ///   (b) a direct residual assessment via `updateRisk` with
  ///       `residualLikelihood`/`residualImpact` (RQ2-1,
  ///       source: USER) — in which case residualScore is DERIVED
  ///       from those two dimensions via `calculateRiskScore`.
  ///
  /// Every change is recorded as a `RiskScoreEvent` (RQ2-1) with
  /// full provenance.
  residualScore      Int?
  residualScoreSetAt DateTime?
  /// RQ2-1 — residual decomposed into its dimensions, mirroring the
  /// inherent likelihood/impact pair. Nullable: legacy rows carry
  /// only the rolled-up `residualScore` (divisor-era, provenance
  /// flagged MIGRATION). When present, the invariant
  /// `residualScore === calculateRiskScore(residualLikelihood,
  /// residualImpact, maxScale)` holds and is enforced at the
  /// usecase layer.
  residualLikelihood Int?
  residualImpact     Int?
  /// B10 — Quantitative risk assessment (SLE × ARO = ALE).
  ///
  /// `sleAmount` — Single Loss Expectancy: the monetary impact of
  ///               ONE realised incident. Nullable until the risk
  ///               owner quantifies; null risks keep the existing
  ///               qualitative score-only view.
  /// `aroAmount` — Annualised Rate of Occurrence: incidents/year.
  ///               Float so 0.25 (= once per 4 years) is expressible
  ///               without coercing to weird rationals. The audit
  ///               UI will surface percentage equivalents.
  ///
  /// ALE is derived (`sleAmount * aroAmount`), not stored — both
  /// inputs are nullable so a stored derived would have to be
  /// `null OR sleAmount * aroAmount` everywhere, doubling the
  /// invariants without buying query benefit. The analytics
  /// usecase materialises ALE per-row at read time.
  sleAmount          Float?
  aroAmount          Float?

  // ── RQ-1 FAIR taxonomy decomposition ──
  // All nullable + additive: risks with only sleAmount/aroAmount keep
  // working via `resolveALE` (prefers fairAle → SLE×ARO → null).
  // Threat Event Frequency (events/year) + its sub-factors.
  threatEventFrequency        Float?
  contactFrequency            Float?
  probabilityOfAction         Float?
  // Vulnerability (probability a threat event becomes a loss, 0..1) + sub-factors.
  vulnerabilityProbability    Float?
  threatCapability            Float?
  controlStrength             Float?
  // Primary Loss Magnitude (cost of one loss event) + components.
  primaryLossMagnitude        Float?
  productivityLoss            Float?
  responseCost                Float?
  replacementCost             Float?
  // Secondary loss.
  secondaryLossEventFrequency Float?
  secondaryLossMagnitude      Float?
  regulatoryFineEstimate      Float?
  reputationDamageEstimate    Float?
  competitiveAdvantageLoss    Float?
  // Derived (stored for query perf; recomputed on FAIR input change).
  lossEventFrequency          Float?
  fairAle                     Float?
  // Metadata.
  fairConfidence              FairConfidence?
  /// PERT distribution triples per factor for Monte Carlo (RQ-3).
  fairInputsJson              Json?
  fairComputedAt              DateTime?

  // ── RQ-10 — Business Impact Analysis ──
  /// Recovery Time Objective: max acceptable downtime (hours).
  rtoHours          Int?
  /// Recovery Point Objective: max acceptable data-loss window (hours).
  rpoHours          Int?
  /// Maximum Tolerable Period of Disruption (hours).
  mtpdHours         Int?
  /// Impact scores — financial / operational / regulatory / reputational, each 1-5.
  biaImpactJson     Json?
  /// Optional LINDDUN privacy-threat classification — a JSON array of
  /// category codes (e.g. ["DD","L"]) tagging this risk with the privacy
  /// threats it embodies, ALONGSIDE the existing `category`. A LENS over the
  /// existing risk machinery, not a parallel engine. See
  /// `src/lib/privacy/linddun.ts` for the 7-category taxonomy (LINDDUN,
  /// KU Leuven) + the advisory PET treatment hints.
  linddunCategories Json?
  /// Business process(es) this risk could disrupt (comma-separated).
  affectedProcesses String?
  /// Estimated annual revenue at risk if this risk materialises.
  revenueAtRisk     Float?

  status           RiskStatus           @default(OPEN)
  treatment        TreatmentDecision?
  treatmentOwner   String?
  treatmentNotes   String?
  ownerUserId      String?
  createdByUserId  String?
  targetDate       DateTime?
  nextReviewAt     DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime?
  deletedByUserId  String?
  retentionUntil   DateTime?
  assetLinks       AssetRiskLink[]
  tenant           Tenant               @relation(fields: [tenantId], references: [id])
  controls         RiskControl[]
  // Epic G-7 — structured treatment plans (replaces free-text
  // `treatmentNotes` for ISO 27001 6.1.3 conformance).
  treatmentPlans   RiskTreatmentPlan[]
  findingLinks     FindingRisk[]
  // Evidence attached directly to this risk (Evidence Library tag +
  // the risk Evidence tab). Mirrors Control/Task.
  evidence         Evidence[]
  // RQ-2 — appetite breaches attributed to this risk.
  appetiteBreaches RiskAppetiteBreach[]
  // RQ-5 — hierarchy node memberships.
  hierarchyLinks   RiskHierarchyLink[]
  // RQ-6 — key risk indicators linked to this risk.
  kris             KeyRiskIndicator[]
  // RQ-8 — pairwise correlations (this risk on either side of the pair).
  correlationsA    RiskCorrelation[]    @relation("CorrelationA")
  correlationsB    RiskCorrelation[]    @relation("CorrelationB")
  // RQ-9 — historical snapshots.
  snapshots        RiskSnapshot[]
  // RQ2-1 — per-mutation score provenance ledger.
  scoreEvents      RiskScoreEvent[]
  lossEvents       LossEvent[]

  /// Composite parent key — supports the
  /// `RiskTreatmentPlan.(riskId, tenantId) → Risk.(id, tenantId)`
  /// FK shape so cross-tenant treatment plans are impossible at the
  /// DB level. Same denorm-tenantId Phase-2 pattern Audit uses.
  @@unique([id, tenantId])
  // PR-B — unique within a tenant so `RSK-1` can't collide. Allows
  // `@@unique` on a nullable column (Postgres treats NULLs as
  // distinct), so historic NULL rows don't clash with each other.
  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([tenantId, deletedAt])
  // GAP-perf — supports `ownerUserId` filter in RiskFilters
  @@index([tenantId, ownerUserId])
  // GAP-perf — supports `scoreMin`/`scoreMax` range filter
  @@index([tenantId, score])
  // RQ-1 FAIR — quantitative ranking + filtering
  @@index([tenantId, fairAle])
  @@index([tenantId, lossEventFrequency])
  @@index([tenantId, fairConfidence])
  // GAP-perf — backs the default unpaginated `list()` orderBy:
  // `inherentScore desc`. Without this Postgres sorts the full
  // tenant result set per call.
  @@index([tenantId, inherentScore])
}

/// Per-tenant monotonic counter for minting `RSK-N` risk keys.
/// Mirrors `TaskKeySequence` — `upsert` with an atomic `increment`
/// is race-free under concurrent imports and scales O(1) regardless
/// of tenant size.
model RiskKeySequence {
  tenantId  String @id
  lastValue Int    @default(0)
}

/// Per-tenant monotonic counter for minting `CTL-N` custom-control
/// keys (the framework-installed controls keep their canonical
/// annexId / supplied code). Only the `createControl` path that
/// lacks an explicit code consumes this sequence; framework imports
/// supply their own code/annexId and bypass the counter entirely.
model ControlKeySequence {
  tenantId  String @id
  lastValue Int    @default(0)
}

model RiskTemplate {
  id                String   @id @default(cuid())
  title             String
  description       String?
  category          String?
  defaultLikelihood Int      @default(3)
  defaultImpact     Int      @default(3)
  frameworkTag      String?
  /// Optional LINDDUN privacy-threat classification — a JSON array of
  /// category codes (e.g. ["DD","L"]). A privacy LENS alongside `category`;
  /// copied to the created Risk by `createRiskFromTemplate`. See
  /// `src/lib/privacy/linddun.ts` for the taxonomy + advisory PET hints.
  linddunCategories Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// Tenant-scoped risk-matrix configuration (Epic 44).
///
/// Drives the dimensions, axis labels, per-level labels, and severity
/// bands of the likelihood × impact matrix the UI renders. Existing
/// tenants resolve to the canonical 5×5 default until an admin
/// customises it via the admin UI — the row is absent in that case;
/// the read usecase centralises the fallback so callers don't have
/// to know about presence.
///
/// `levelLabels` and `bands` are JSON because the per-level
/// vocabulary varies (operational vs. clinical vs. supply-chain
/// risks all want different scale legends) and forcing a side table
/// would buy nothing — the rows are deeply tenant-specific and
/// validated end-to-end by Zod before write. Schema invariants:
///   - `likelihoodLevels`, `impactLevels` ∈ [2, 10]
///   - `levelLabels.likelihood` length === likelihoodLevels (when set)
///   - `levelLabels.impact`     length === impactLevels (when set)
///   - `bands` cover [1, likelihoodLevels * impactLevels] without gaps
///     or overlaps; each entry has { name, minScore, maxScore, color }
///
/// One row per tenant (`@@unique([tenantId])`).
model RiskMatrixConfig {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  /// Number of likelihood levels (matrix rows). Default 5.
  likelihoodLevels    Int      @default(5)
  /// Number of impact levels (matrix columns). Default 5.
  impactLevels        Int      @default(5)
  /// Y-axis title (default "Likelihood").
  axisLikelihoodLabel String   @default("Likelihood")
  /// X-axis title (default "Impact").
  axisImpactLabel     String   @default("Impact")
  /// Per-level human labels keyed by axis. Falls back to numeric labels when absent.
  levelLabels         Json?
  /// Ordered severity bands. See doc above for the contract.
  bands               Json     @default("[]")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  tenant              Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

/// RQ-2 — board-approved risk appetite. One row per tenant; absent row
/// means no appetite configured (UI shows a "Configure" CTA).
model RiskAppetiteConfig {
  id                    String        @id @default(cuid())
  tenantId              String        @unique
  /// Max acceptable total ALE across all active risks (Σ ALE/year).
  totalAleThreshold     Float?
  /// Max acceptable ALE for any single risk.
  singleRiskAleMax      Float?
  /// Max acceptable qualitative score (likelihood × impact).
  qualScoreMax          Int?
  /// RQ3-3 — which simulated portfolio percentile the ceiling is
  /// tested at (board-level policy). Breach detection reads the
  /// latest run's portfolioP<NN>; falls back to Σ(mean ALE) when no
  /// simulation exists. Supported: 50 / 80 / 90 / 95 / 99.
  testedPercentile      Int           @default(80)
  /// category → { totalAleMax, singleAleMax, qualScoreMax } overrides.
  categoryOverridesJson Json?
  /// Board-approved narrative statement.
  appetiteStatement     String?
  approvedByUserId      String?
  approvedAt            DateTime?
  reviewCadence         ReviewCadence @default(ANNUALLY)
  nextReviewAt          DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  tenant                Tenant        @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

/// RQ-2 — a point-in-time record of an appetite threshold breach.
/// Created by the monitor job / write-path checks; resolved when the
/// value drops back under threshold.
model RiskAppetiteBreach {
  id                  String    @id @default(cuid())
  tenantId            String
  breachType          String // PORTFOLIO_ALE | SINGLE_RISK_ALE | QUAL_SCORE | CATEGORY_ALE
  riskId              String?
  category            String?
  thresholdValue      Float
  actualValue         Float
  notifiedUserIds     Json?
  detectedAt          DateTime  @default(now())
  resolvedAt          DateTime?
  acknowledgedAt      DateTime?
  acknowledgedBy      String?
  acknowledgementNote String?
  /// RQ2-6 — the remediation task spawned from this breach (one per
  /// breach, claimed via conditional update). Soft reference by
  /// design: deleting the task leaves a dangling id the UI treats
  /// as "no task"; breach telemetry never blocks task lifecycle.
  remediationTaskId   String?
  tenant              Tenant    @relation(fields: [tenantId], references: [id])
  risk                Risk?     @relation(fields: [riskId], references: [id])

  @@index([tenantId, detectedAt])
  @@index([tenantId, breachType])
  @@index([tenantId, resolvedAt])
  @@index([riskId])
}

/// RQ-3 — a single Monte Carlo simulation execution. Immutable after
/// completion; re-running creates a new row.
model RiskSimulationRun {
  id                 String    @id @default(cuid())
  tenantId           String
  triggeredBy        String    @default("manual") // manual | scheduled | scenario
  createdByUserId    String?
  iterations         Int       @default(10000)
  confidenceLevels   Json      @default("[0.90, 0.95, 0.99]")
  seed               Int?
  riskFilterJson     Json?
  correlationId      String?
  // ── Results ──
  portfolioMean      Float?
  portfolioP50       Float?
  /// RQ3-1 — VaR-80: the "likely bad year" marker on the simulated LEC.
  portfolioP80       Float?
  portfolioP90       Float?
  portfolioP95       Float?
  portfolioP99       Float?
  portfolioStdDev    Float?
  perRiskResultsJson Json?
  lecPointsJson      Json?
  convergenceDelta   Float?
  executionMs        Int?
  status             String    @default("RUNNING") // RUNNING | COMPLETED | FAILED
  errorMessage       String?
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  tenant             Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

/// RQ-4 — a hypothetical "what-if" scenario that patches the portfolio
/// before re-running the Monte Carlo simulation. Clone to iterate.
model RiskScenario {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  createdByUserId String
  /// "Before" run (null = current live portfolio is the baseline).
  baselineRunId   String?
  /// Array<ScenarioOverride> applied before simulation.
  overridesJson   Json
  /// The run executed WITH overrides applied (null until simulated).
  resultRunId     String?
  status          String   @default("DRAFT") // DRAFT | SIMULATED | ARCHIVED
  investmentCost  Float?
  computedRoi     Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

/// RQ-5 — a node in a tenant-defined org hierarchy for risk aggregation.
/// Parallel trees per `type` (BU / geography / asset class / custom).
model RiskHierarchyNode {
  id           String              @id @default(cuid())
  tenantId     String
  name         String
  type         String // BUSINESS_UNIT | GEOGRAPHY | ASSET_CLASS | CUSTOM
  parentId     String?
  sortOrder    Int                 @default(0)
  metadataJson Json?
  parent       RiskHierarchyNode?  @relation("HierarchyTree", fields: [parentId], references: [id])
  children     RiskHierarchyNode[] @relation("HierarchyTree")
  riskLinks    RiskHierarchyLink[]
  tenant       Tenant              @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, type, name])
  @@index([tenantId, type])
  @@index([tenantId, parentId])
  @@index([parentId])
}

/// RQ-5 — M:N join: a risk can sit in multiple hierarchy nodes.
model RiskHierarchyLink {
  id        String            @id @default(cuid())
  tenantId  String
  riskId    String
  nodeId    String
  createdAt DateTime          @default(now())
  risk      Risk              @relation(fields: [riskId], references: [id], onDelete: Cascade)
  node      RiskHierarchyNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  tenant    Tenant            @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, riskId, nodeId])
  @@index([tenantId, nodeId])
  @@index([tenantId, riskId])
  @@index([nodeId])
}

/// RQ-6 — a leading/lagging indicator that signals whether a risk is
/// trending toward materialisation. RAG-thresholded; readings tracked.
model KeyRiskIndicator {
  id               String       @id @default(cuid())
  tenantId         String
  riskId           String?
  name             String
  description      String?
  unit             String?
  direction        String       @default("HIGHER_IS_WORSE") // HIGHER_IS_WORSE | LOWER_IS_WORSE
  greenMax         Float?
  amberMax         Float?
  frequency        String       @default("MONTHLY") // DAILY | WEEKLY | MONTHLY | QUARTERLY
  ownerUserId      String?
  isActive         Boolean      @default(true)
  automationRuleId String?
  targetValue      Float?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  tenant           Tenant       @relation(fields: [tenantId], references: [id])
  risk             Risk?        @relation(fields: [riskId], references: [id])
  owner            User?        @relation("KriOwner", fields: [ownerUserId], references: [id])
  readings         KriReading[]

  @@index([tenantId])
  @@index([tenantId, riskId])
  @@index([tenantId, isActive])
  @@index([riskId])
  @@index([ownerUserId])
}

/// RQ-6 — a single KRI measurement; RAG computed at write time.
model KriReading {
  id         String           @id @default(cuid())
  tenantId   String
  kriId      String
  value      Float
  ragStatus  String? // GREEN | AMBER | RED
  recordedAt DateTime         @default(now())
  recordedBy String?
  note       String?
  kri        KeyRiskIndicator @relation(fields: [kriId], references: [id], onDelete: Cascade)
  tenant     Tenant           @relation(fields: [tenantId], references: [id])

  @@index([kriId, recordedAt])
  @@index([tenantId, recordedAt])
  @@index([tenantId, kriId])
}

/// RQ-8 — pairwise correlation between two risks, used by the Monte
/// Carlo engine (RQ-3) to generate correlated loss samples via Cholesky.
/// Normalised so riskAId < riskBId (one row per unordered pair).
model RiskCorrelation {
  id              String   @id @default(cuid())
  tenantId        String
  riskAId         String
  riskBId         String
  /// Pearson coefficient (-1.0 .. 1.0). Positive = co-materialise.
  coefficient     Float
  rationale       String?
  source          String   @default("MANUAL") // MANUAL | AUTO_SUGGESTED | HISTORICAL
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  riskA           Risk     @relation("CorrelationA", fields: [riskAId], references: [id], onDelete: Cascade)
  riskB           Risk     @relation("CorrelationB", fields: [riskBId], references: [id], onDelete: Cascade)

  @@unique([tenantId, riskAId, riskBId])
  @@index([tenantId])
  @@index([riskAId])
  @@index([riskBId])
}

/// RQ-9 — daily point-in-time capture of a risk's key metrics for
/// trend + velocity analysis. Created by the `risk-snapshot` cron.
model RiskSnapshot {
  id                   String   @id @default(cuid())
  tenantId             String
  riskId               String
  score                Int
  inherentScore        Int
  residualScore        Int?
  likelihood           Int
  impact               Int
  status               String
  ale                  Float?
  fairAle              Float?
  sleAmount            Float?
  aroAmount            Float?
  tef                  Float?
  vulnerability        Float?
  plm                  Float?
  activeTreatmentPlans Int      @default(0)
  snapshotAt           DateTime @default(now())
  risk                 Risk     @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tenant               Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, riskId, snapshotAt])
  @@index([tenantId, snapshotAt])
  @@index([riskId, snapshotAt])
}

/// RQ2-1 — per-mutation score provenance ledger.
///
/// Boundary vs RQ-9's `RiskSnapshot`: RiskSnapshot is a CADENCE
/// record (one row per risk per day, written by the snapshot cron,
/// for trend charts). RiskScoreEvent is a MUTATION record — exactly
/// one row per score-changing write, carrying WHO changed WHAT, from
/// what SOURCE (user edit / system derivation / plan completion / AI
/// acceptance / migration backfill), and an optional justification.
/// Trends read snapshots; explainability + audit narrative read
/// events. Neither substitutes for the other.
///
/// Written transactionally with the score write itself (same
/// `runInTenantContext` transaction) so the ledger can never drift
/// from the row state.
model RiskScoreEvent {
  id              String               @id @default(cuid())
  tenantId        String
  riskId          String
  kind            RiskScoreEventKind
  likelihood      Int
  impact          Int
  score           Int
  source          RiskScoreEventSource
  /// Free-text rationale (override reasons, plan ids, AI rationale).
  /// Plain metadata — deliberately NOT in the encryption manifest:
  /// no business content beyond what AuditLog.details already
  /// carries for the same mutations.
  justification   String?
  /// Nullable: PLAN/MIGRATION events may have no acting user.
  createdByUserId String?
  createdAt       DateTime             @default(now())
  risk            Risk                 @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tenant          Tenant               @relation(fields: [tenantId], references: [id])

  @@index([tenantId, riskId, createdAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, kind, createdAt])
}

/// RQ3-6 — recorded loss event ("an actual"). The system predicts
/// losses everywhere (FAIR ALE, Monte Carlo P50/P90, LEC); this
/// model is where the world's answer comes back, so the forecasting
/// stack becomes falsifiable. Sources: USER (manual entry), FINDING
/// (recorded from a finding's close-out), INCIDENT (recorded from
/// an incident / ticket).
model LossEvent {
  id              String          @id @default(cuid())
  tenantId        String
  /// Optional risk attribution: a loss can be portfolio-wide (riskId
  /// null) — the predicted-vs-actual overlay still aggregates it.
  riskId          String?
  /// When the loss occurred (calendar date — finance, not telemetry).
  occurredAt      DateTime
  /// Realised loss amount, currency = tenant's `currencySymbol` (OB-A).
  amount          Float
  /// Short human description ("Customer breach response, vendor X").
  /// Encrypted at rest via the Epic B manifest (loss narratives are
  /// confidential business content).
  description     String?
  source          LossEventSource @default(USER)
  /// Free-text rationale (RQ2-1-style provenance): WHY this number,
  /// WHICH ticket, who the assessor talked to.
  justification   String?
  /// Nullable: imported / migrated rows may have no acting user.
  createdByUserId String?
  createdAt       DateTime        @default(now())
  /// Mark-as-resolved style soft delete so historical predictions
  /// can still see the actual that came in then later got reclassified.
  deletedAt       DateTime?
  risk            Risk?           @relation(fields: [riskId], references: [id], onDelete: SetNull)
  tenant          Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId, occurredAt])
  @@index([tenantId, riskId, occurredAt])
  @@index([tenantId, createdAt])
}

/// RQ-9 — daily aggregate snapshot of the whole portfolio (one per
/// tenant per day) for portfolio trend charts.
model PortfolioSnapshot {
  id               String   @id @default(cuid())
  tenantId         String
  totalRiskCount   Int
  openRiskCount    Int
  quantifiedCount  Int
  totalAle         Float?
  avgAle           Float?
  maxSingleAle     Float?
  totalScore       Int
  avgScore         Float
  appetiteBreached Boolean  @default(false)
  snapshotAt       DateTime @default(now())
  tenant           Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, snapshotAt])
  @@index([tenantId, snapshotAt])
}

/// RQ-10 — a reusable report template (structure + data sources).
model ReportTemplate {
  id          String           @id @default(cuid())
  tenantId    String
  name        String
  description String?
  type        String // PORTFOLIO_SUMMARY | RISK_DEEP_DIVE | BIA | CUSTOM
  configJson  Json
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  runs        ReportRun[]
  schedules   ReportSchedule[]

  @@index([tenantId])
  @@index([tenantId, type])
}

/// RQ-10 — a single report generation execution.
model ReportRun {
  id              String         @id @default(cuid())
  tenantId        String
  templateId      String
  parametersJson  Json
  format          String // PDF | CSV
  outputPath      String?
  outputSizeBytes Int?
  status          String         @default("QUEUED") // QUEUED | GENERATING | COMPLETED | FAILED
  errorMessage    String?
  requestedBy     String?
  deliverToJson   Json?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  template        ReportTemplate @relation(fields: [templateId], references: [id])
  tenant          Tenant         @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([templateId])
}

/// RQ-10 — scheduled report delivery configuration.
model ReportSchedule {
  id                 String         @id @default(cuid())
  tenantId           String
  templateId         String
  parametersJson     Json
  format             String         @default("PDF")
  cadence            String // WEEKLY | MONTHLY | QUARTERLY
  deliveryDay        Int?
  recipientsJson     Json
  sharePointDriveId  String?
  sharePointFolderId String?
  isActive           Boolean        @default(true)
  nextRunAt          DateTime?
  lastRunAt          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  template           ReportTemplate @relation(fields: [templateId], references: [id])
  tenant             Tenant         @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([nextRunAt, isActive])
  @@index([templateId])
}

model RiskSuggestionSession {
  id              String                  @id @default(cuid())
  tenantId        String
  createdByUserId String
  status          SuggestionSessionStatus @default(DRAFT)
  inputJson       String
  modelName       String?
  provider        String                  @default("stub")
  errorMessage    String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  items           RiskSuggestionItem[]
  createdBy       User                    @relation("SuggestionSessionCreator", fields: [createdByUserId], references: [id])
  tenant          Tenant                  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

model RiskSuggestionItem {
  id                    String                @id @default(cuid())
  sessionId             String
  tenantId              String
  assetId               String?
  title                 String
  description           String?
  category              String?
  threat                String?
  vulnerability         String?
  likelihoodSuggested   Int?
  impactSuggested       Int?
  rationale             String?
  suggestedControlsJson String?
  status                SuggestionItemStatus  @default(PENDING)
  editedJson            String?
  createdRiskId         String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  asset                 Asset?                @relation(fields: [assetId], references: [id])
  suggestionSession     RiskSuggestionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  session               Tenant                @relation(fields: [tenantId], references: [id])

  @@index([sessionId])
  @@index([tenantId])
  @@index([tenantId, sessionId])
}

/// Epic MCP Phase 3 — the propose-not-commit queue. An external agent (via the
/// MCP server, `mcp:propose` scope) can PROPOSE a risk/control/policy/finding;
/// the proposal lands here as PENDING and a human approves it before the REAL
/// create-usecase runs. An agent never mutates a record directly. `payloadJson`
/// (the proposed content, validated + Epic-D sanitised at the propose boundary)
/// and `rationale` are encrypted at rest (Epic B — see encrypted-fields.ts).
model AgentProposal {
  id                   String               @id @default(cuid())
  tenantId             String
  kind                 AgentProposalKind
  status               SuggestionItemStatus @default(PENDING)
  payloadJson          String
  rationale            String?
  proposedViaKeyId     String?
  proposedBySessionRef String?
  reviewedByUserId     String?
  reviewedAt           DateTime?
  createdEntityId      String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, createdAt])
}

/// Epic Agentic 1A — a durable, audited, human-gated agentic workflow run. The
/// engine composes the existing MCP read/propose tools under this run model; it
/// adds orchestration + checkpoints, NOT new authority. Every write a workflow
/// makes routes through the propose-not-commit approval queue (AgentProposal) —
/// the engine can commit nothing a single MCP tool couldn't. `contextJson`
/// (accumulated state) and `summary` (the output artifact) are encrypted at rest
/// (Epic B — see encrypted-fields.ts).
model WorkflowRun {
  id                String            @id @default(cuid())
  tenantId          String
  workflowKey       String
  status            WorkflowRunStatus @default(RUNNING)
  startedByUserId   String?
  triggeredViaKeyId String?
  startedAt         DateTime          @default(now())
  completedAt       DateTime?
  contextJson       String?
  summary           String?
  stepCount         Int               @default(0)
  costTokens        Int               @default(0)
  errorMessage      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  steps             WorkflowStep[]

  @@index([tenantId, status, startedAt])
}

/// An append-only record of one workflow step — the run's audit narrative.
model WorkflowStep {
  id          String             @id @default(cuid())
  runId       String
  tenantId    String
  seq         Int
  kind        WorkflowStepKind
  toolCalled  String?
  inputJson   String?
  outputJson  String?
  status      WorkflowStepStatus @default(PENDING)
  at          DateTime           @default(now())
  actorUserId String?
  run         WorkflowRun        @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, seq])
  @@index([tenantId, runId])
}

/// Epic Regwatch 2A — the computed diff between two versions of a framework's
/// requirement set (ADDED / CHANGED / REMOVED requirement codes + a
/// human-readable changelog). GLOBAL (framework structure is the same for every
/// tenant — no tenantId, no RLS). Computed from the existing version-history
/// (Framework.metadataJson) via `computeRequirementDiff`; the per-tenant impact
/// is `TenantFrameworkDelta`.
model FrameworkVersionDiff {
  id             String                @id @default(cuid())
  frameworkKey   String
  fromVersion    String
  toVersion      String
  addedCodesJson String                @default("[]")
  changedCodesJson String              @default("[]")
  removedCodesJson String              @default("[]")
  changelog      String?
  createdAt      DateTime              @default(now())
  tenantDeltas   TenantFrameworkDelta[]

  @@unique([frameworkKey, fromVersion, toVersion])
  @@index([frameworkKey, createdAt])
}

/// Epic Regwatch 2A — what a framework-version update means for ONE tenant: the
/// new uncovered gaps (added requirements the tenant has no control for) and the
/// tenant's controls flagged for re-review (mapped to a changed requirement).
/// Tenant-scoped (RLS). References the global `FrameworkVersionDiff`.
model TenantFrameworkDelta {
  id                   String               @id @default(cuid())
  tenantId             String
  diffId               String
  frameworkKey         String
  fromVersion          String
  toVersion            String
  newGapCodesJson      String               @default("[]")
  flaggedControlIdsJson String              @default("[]")
  newGapCount          Int                  @default(0)
  flaggedControlCount  Int                  @default(0)
  status               FrameworkDeltaStatus @default(NEW)
  reviewedByUserId     String?
  reviewedAt           DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  diff                 FrameworkVersionDiff @relation(fields: [diffId], references: [id], onDelete: Cascade)

  @@unique([tenantId, diffId])
  @@index([tenantId, status, createdAt])
  @@index([diffId])
}

model Control {
  id                           String                   @id @default(cuid())
  tenantId                     String?
  code                         String?
  annexId                      String?                  @unique
  name                         String
  // Internal-controls import: objective (Overview shows this as "Objective"),
  // success criteria (Overview "Success Criteria"), and testing/audit
  // methodology (Tests tab, above Test plans).
  objective                    String?
  successCriteria              String?
  testingMethodology           String?
  category                     String?
  status                       ControlStatus            @default(NOT_STARTED)
  effectiveness                Int?
  /// RQ3-8 — annual cost (operate + maintain) in the tenant's
  /// currency. Float matches the existing money-field pattern
  /// (sleAmount, aroAmount, fairAle on Risk). Nullable until an
  /// owner prices it — the ROI surface returns an honest null with
  /// a typed `NO_COST` reason rather than fabricating a number.
  annualCost                   Float?
  lastTested                   DateTime?
  reviewCadence                ReviewCadence?
  isCustom                     Boolean                  @default(false)
  ownerUserId                  String?
  createdByUserId              String?
  frequency                    ControlFrequency?
  nextDueAt                    DateTime?
  evidenceSource               EvidenceSourceType?
  automationKey                String?
  automationType               ControlAutomationType?
  mitigationType               ControlMitigationType?
  applicability                Applicability            @default(APPLICABLE)
  applicabilityJustification   String?
  applicabilityDecidedByUserId String?
  applicabilityDecidedAt       DateTime?
  createdAt                    DateTime                 @default(now())
  updatedAt                    DateTime                 @updatedAt
  deletedAt                    DateTime?
  deletedByUserId              String?
  retentionUntil               DateTime?
  applicabilityDecidedBy       User?                    @relation("ControlApplicabilityDecider", fields: [applicabilityDecidedByUserId], references: [id])
  createdBy                    User?                    @relation("ControlCreator", fields: [createdByUserId], references: [id])
  owner                        User?                    @relation("ControlOwner", fields: [ownerUserId], references: [id])
  tenant                       Tenant?                  @relation(fields: [tenantId], references: [id])
  assets                       ControlAsset[]
  contributors                 ControlContributor[]
  evidenceLinks                ControlEvidenceLink[]
  requirementLinks             ControlRequirementLink[]
  controlTasks                 ControlTask[]
  testPlans                    ControlTestPlan[]
  testRuns                     ControlTestRun[]
  evidence                     Evidence[]
  frameworkMappings            FrameworkMapping[]
  findings                     Finding[]                @relation("FindingControl")
  compensatingForFindings      Finding[]                @relation("FindingCompensatingControl")
  integrationExecutions        IntegrationExecution[]
  policyLinks                  PolicyControlLink[]
  risks                        RiskControl[]
  tasks                        Task[]
  // Epic G-5 — control exception register. Two reverse relations:
  // (a) exceptions registered against THIS control,
  // (b) exceptions that name THIS control as their compensating
  //     control (i.e. "we mitigate the gap by doing this").
  exceptions                   ControlException[]       @relation("ControlExceptionAffected")
  compensatingForExceptions    ControlException[]       @relation("ControlExceptionCompensating")

  /// Composite parent key — supports the
  /// `ControlException.(controlId, tenantId) → Control.(id, tenantId)`
  /// FK shape, so a cross-tenant exception link is impossible at
  /// the DB level. Same denorm-tenantId Phase-2 pattern used by
  /// AuditChecklistItem → Audit.
  @@unique([id, tenantId])
  @@index([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, applicability])
  @@index([ownerUserId])
  @@index([nextDueAt])
  @@index([tenantId, deletedAt])
  // GAP-perf — supports `ownerUserId` filter in tenant scope.
  // `[ownerUserId]` alone exists but isn't tenant-prefixed, so
  // Postgres can't selectively scan one tenant's slice for a
  // specific owner without an additional filter pass.
  @@index([tenantId, ownerUserId])
  // GAP-perf — supports `category` filter (free-text exact match).
  @@index([tenantId, category])
}

model RiskControl {
  id              String   @id @default(cuid())
  riskId          String
  controlId       String
  tenantId        String
  rationale       String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  control         Control  @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy       User?    @relation("RiskControlCreator", fields: [createdByUserId], references: [id])
  risk            Risk     @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, riskId, controlId])
  @@index([tenantId, controlId])
  @@index([tenantId])
}

model ControlAsset {
  id              String       @id @default(cuid())
  controlId       String
  assetId         String
  tenantId        String
  coverageType    CoverageType @default(UNKNOWN)
  rationale       String?
  createdByUserId String?
  createdAt       DateTime     @default(now())
  asset           Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  control         Control      @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy       User?        @relation("ControlAssetCreator", fields: [createdByUserId], references: [id])
  tenant          Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, controlId, assetId])
  @@index([tenantId, assetId])
  @@index([tenantId])
}

model AssetRiskLink {
  id              String        @id @default(cuid())
  tenantId        String
  assetId         String
  riskId          String
  exposureLevel   ExposureLevel @default(MEDIUM)
  rationale       String?
  createdByUserId String?
  createdAt       DateTime      @default(now())
  asset           Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdBy       User?         @relation("AssetRiskCreator", fields: [createdByUserId], references: [id])
  risk            Risk          @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, assetId, riskId])
  @@index([tenantId, riskId])
  @@index([tenantId])
}

model ControlContributor {
  id        String   @id @default(cuid())
  tenantId  String
  controlId String
  userId    String
  createdAt DateTime @default(now())
  control   Control  @relation(fields: [controlId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([controlId, userId])
  @@index([tenantId])
}

model ControlTask {
  id             String            @id @default(cuid())
  tenantId       String
  controlId      String
  title          String
  description    String?
  status         ControlTaskStatus @default(OPEN)
  assigneeUserId String?
  dueAt          DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  assignee       User?             @relation("ControlTaskAssignee", fields: [assigneeUserId], references: [id])
  control        Control           @relation(fields: [controlId], references: [id], onDelete: Cascade)
  tenant         Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([controlId])
  @@index([status])
  @@index([dueAt])
  // GAP-perf — backs the dashboard "overdue tasks" query
  // (status IN ('OPEN','IN_PROGRESS') AND dueAt < now()) and the
  // refactored `runConsistencyCheck` overdue lookup. The
  // single-column `[status]` and `[dueAt]` indexes can't satisfy
  // the combined predicate efficiently.
  @@index([tenantId, status, dueAt])
}

model ControlEvidenceLink {
  id                  String           @id @default(cuid())
  tenantId            String
  controlId           String
  kind                EvidenceLinkKind
  fileId              String?
  url                 String?
  integrationResultId String?
  /// BIA-as-evidence (kind BIA) — the continuity control (NIS2
  /// Art.21(2)(c)) links a Business Impact Analysis as the operational
  /// artifact that satisfies the requirement.
  biaId               String?
  note                String?
  createdByUserId     String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  control             Control          @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy           User?            @relation("ControlEvidenceCreator", fields: [createdByUserId], references: [id])
  bia                 BusinessImpactAnalysis? @relation(fields: [biaId], references: [id], onDelete: Cascade)
  tenant              Tenant           @relation(fields: [tenantId], references: [id])

  @@unique([controlId, kind, fileId])
  @@unique([controlId, kind, url])
  @@unique([controlId, kind, biaId])
  @@index([tenantId])
  @@index([controlId])
  @@index([tenantId, biaId])
}

model ControlTemplate {
  id               String                           @id @default(cuid())
  code             String                           @unique
  title            String
  description      String?
  category         String?
  defaultFrequency ControlFrequency?
  defaultOwnerHint String?
  // Internal-controls import (customer GRC export): the control's objective
  // (what it achieves), success criteria (what "passing" looks like), and
  // testing/audit methodology. Copied onto the Control on install.
  objective          String?
  successCriteria    String?
  testingMethodology String?
  // Pipe-separated policy names this control relates to (from the source
  // export); resolved to PolicyControlLink per-tenant on install where a
  // matching policy exists. Framework mapping deferred (source Tags empty).
  relatedPolicies  String?
  isGlobal         Boolean                          @default(true)
  createdAt        DateTime                         @default(now())
  requirementLinks ControlTemplateRequirementLink[]
  tasks            ControlTemplateTask[]
  packLinks        PackTemplateLink[]
}

model ControlTemplateTask {
  id          String          @id @default(cuid())
  templateId  String
  title       String
  description String?
  template    ControlTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ControlTemplateRequirementLink {
  id            String               @id @default(cuid())
  templateId    String
  requirementId String
  requirement   FrameworkRequirement @relation(fields: [requirementId], references: [id])
  template      ControlTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, requirementId])
}

model Evidence {
  id                String                    @id @default(cuid())
  tenantId          String
  controlId         String?
  // Source task — set when this evidence was uploaded/linked from a
  // task's Evidence tab. Powers the task Evidence tab AND the
  // "uploaded from" back-reference on the evidence detail surface.
  taskId            String?
  // Source risk / asset — same pattern as taskId: set when uploaded
  // from that entity's Evidence tab; powers the attached-evidence tab
  // + the "uploaded from" back-reference.
  riskId            String?
  assetId           String?
  type              EvidenceType
  title             String
  content           String?
  fileName          String?
  fileSize          Int?
  category          String?
  dateCollected     DateTime                  @default(now())
  owner             String? // Legacy free-text — kept for backward compat
  ownerUserId       String? // Real user FK — used for due-item routing & notifications
  reviewCycle       ReviewCadence?
  nextReviewDate    DateTime?
  status            EvidenceStatus            @default(DRAFT)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  deletedAt         DateTime?
  deletedByUserId   String?
  fileRecordId      String?
  expiredAt         DateTime?
  isArchived        Boolean                   @default(false)
  retentionDays     Int?
  retentionPolicy   RetentionPolicy           @default(NONE)
  retentionUntil    DateTime?
  /// B8 follow-up — free-text folder label (e.g. "SOC2/2026" or
  /// "Quarterly access reviews"). Mirrors the `VendorDocument.folder`
  /// pattern. Nullable; null/empty maps to "no folder" in the UI.
  /// Sanitised + trimmed at the usecase boundary.
  folder            String?
  testEvidenceLinks ControlTestEvidenceLink[]
  policyEvidenceItems PolicyEvidenceItem[]
  // Epic G-3 — vendor questionnaire FILE_UPLOAD answers attach
  // their proof here.
  vendorAnswers     VendorAssessmentAnswer[]  @relation("VendorAnswerEvidence")
  control           Control?                  @relation(fields: [controlId], references: [id])
  task              Task?                     @relation(fields: [taskId], references: [id])
  risk              Risk?                     @relation(fields: [riskId], references: [id])
  asset             Asset?                    @relation(fields: [assetId], references: [id])
  fileRecord        FileRecord?               @relation(fields: [fileRecordId], references: [id])
  ownerUser         User?                     @relation("EvidenceOwner", fields: [ownerUserId], references: [id])
  tenant            Tenant                    @relation(fields: [tenantId], references: [id])
  reviews           EvidenceReview[]
  findingLinks      FindingEvidence[]
  incidentLinks     IncidentEvidence[]
  reminderHistories ReminderHistory[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, deletedAt])
  @@index([tenantId, retentionUntil])
  @@index([tenantId, isArchived])
  @@index([tenantId, ownerUserId])
  // GAP-perf — supports `status` filter (DRAFT|SUBMITTED|APPROVED|REJECTED).
  @@index([tenantId, status])
  // GAP-perf — supports `controlId` filter ("evidence for control X").
  // Already a heavily-used UI surface — every control detail page
  // pulls evidence by controlId.
  @@index([tenantId, controlId])
  // Supports the task Evidence tab ("evidence for task X") + the
  // evidence "uploaded from" back-reference lookup.
  @@index([tenantId, taskId])
  // Same, for the risk + asset Evidence tabs.
  @@index([tenantId, riskId])
  @@index([tenantId, assetId])
  // GAP-perf — supports `type` filter (FILE|LINK|TEXT|SCREENSHOT).
  @@index([tenantId, type])
  // B8 follow-up — supports folder filter + group-by reads. Same
  // shape as VendorDocument's folder index.
  @@index([tenantId, folder])
}

model FileRecord {
  id               String           @id @default(cuid())
  tenantId         String
  pathKey          String           @unique
  originalName     String
  mimeType         String
  sizeBytes        Int
  sha256           String
  status           FileRecordStatus @default(PENDING)
  uploadedByUserId String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  storedAt         DateTime?
  bucket           String?
  domain           String           @default("general")
  scanStatus       String           @default("PENDING")
  storageProvider  String           @default("local")
  scanDetails      String?
  scannedAt        DateTime?
  deletedAt        DateTime?
  deletedByUserId  String?
  retentionUntil   DateTime?
  evidence         Evidence[]
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  uploadedBy       User             @relation("FileUploader", fields: [uploadedByUserId], references: [id])
  // Epic G-4 — campaigns whose evidence PDF this row carries.
  accessReviews    AccessReview[]   @relation("AccessReviewEvidence")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, scanStatus])
  @@index([tenantId, deletedAt])
}

model EvidenceReview {
  // denorm-tenantId — Phase 2: tenantId is NOT NULL and the parent
  // relation is composite (evidenceId, tenantId) → Evidence(id,
  // tenantId), which structurally guarantees this row's tenantId
  // matches its parent's. Phase 3 swaps the chained RLS policy for
  // the trivial direct form.
  id         String       @id @default(cuid())
  tenantId   String
  evidenceId String
  reviewerId String
  action     ReviewAction
  comment    String?
  createdAt  DateTime     @default(now())
  evidence   Evidence     @relation(fields: [evidenceId, tenantId], references: [id, tenantId], onDelete: Cascade)
  reviewer   User         @relation(fields: [reviewerId], references: [id])
  tenant     Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, evidenceId])
}

model Policy {
  id                   String              @id @default(cuid())
  tenantId             String
  slug                 String
  title                String
  description          String?
  category             String?
  status               PolicyStatus        @default(DRAFT)
  currentVersionId     String?             @unique
  ownerUserId          String?
  reviewFrequencyDays  Int?
  nextReviewAt         DateTime?
  /// Last time the policy was marked reviewed (periodic re-validation).
  /// Distinct from PolicyApproval (initial sign-off): markPolicyReviewed
  /// stamps this + recomputes nextReviewAt = now + reviewFrequencyDays.
  lastReviewedAt       DateTime?
  language             String?             @default("en")
  /// Lifecycle version counter (matches CISO-Assistant editing_version).
  /// 1 = initial content, 2+ = published. Incremented only on publish.
  lifecycleVersion     Int                 @default(1)
  /// Persisted history of prior published snapshots as JSON array.
  /// Matches CISO-Assistant editing_history. Entries have fields:
  /// version, payload, publishedAt, publishedBy, changeSummary (optional)
  lifecycleHistoryJson Json?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  deletedAt            DateTime?
  deletedByUserId      String?
  retentionUntil       DateTime?
  /// SP-4 — SharePoint document link (bidirectional policy sync).
  spDriveId            String?
  spItemId             String?
  /// Last known SharePoint eTag — drives conflict detection on push/pull.
  spItemETag           String?
  spWebUrl             String?
  /// Active Graph change-notification subscription id (null when unlinked).
  spSubscriptionId     String?
  /// SP-F1 — the IntegrationConnection backing this link (multi-connection
  /// tenants). Null on pre-SP-F1 links → resolve the tenant's first connection.
  spConnectionId       String?
  currentVersion       PolicyVersion?      @relation("CurrentVersion", fields: [currentVersionId], references: [id])
  owner                User?               @relation("PolicyOwner", fields: [ownerUserId], references: [id])
  tenant               Tenant              @relation(fields: [tenantId], references: [id])
  approvals            PolicyApproval[]
  controlLinks         PolicyControlLink[]
  evidenceItems        PolicyEvidenceItem[]
  versions             PolicyVersion[]     @relation("PolicyVersions")

  @@unique([id, tenantId])
  @@index([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([nextReviewAt])
  @@index([tenantId, deletedAt])
}

model PolicyVersion {
  id               String                  @id @default(cuid())
  policyId         String
  versionNumber    Int
  contentType      PolicyContentType       @default(MARKDOWN)
  contentText      String?
  externalUrl      String?
  changeSummary    String?
  createdById      String
  createdAt        DateTime                @default(now())
  tenantId         String
  currentOfPolicy  Policy?                 @relation("CurrentVersion")
  acknowledgements PolicyAcknowledgement[]
  approvals        PolicyApproval[]
  createdBy        User                    @relation("PolicyVersionCreator", fields: [createdById], references: [id])
  policy           Policy                  @relation("PolicyVersions", fields: [policyId], references: [id], onDelete: Cascade)
  tenant           Tenant                  @relation(fields: [tenantId], references: [id])

  @@unique([policyId, versionNumber])
  @@index([tenantId])
}

model PolicyApproval {
  id                String               @id @default(cuid())
  tenantId          String
  policyId          String
  policyVersionId   String
  requestedByUserId String
  approvedByUserId  String?
  status            PolicyApprovalStatus @default(PENDING)
  decidedAt         DateTime?
  comment           String?
  createdAt         DateTime             @default(now())
  approvedBy        User?                @relation("PolicyApprover", fields: [approvedByUserId], references: [id])
  policy            Policy               @relation(fields: [policyId], references: [id], onDelete: Cascade)
  policyVersion     PolicyVersion        @relation(fields: [policyVersionId], references: [id], onDelete: Cascade)
  requestedBy       User                 @relation("PolicyApprovalRequester", fields: [requestedByUserId], references: [id])
  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // FK reverse-lookup indexes. PolicyApproval is now first-class
  // tenant-scoped (carries its own tenantId — direct RLS, not
  // ownership-chained), so the FK reverse lookups ride tenant-leading
  // composites. tenantId leads both, so no separate @@index([tenantId]).
  @@index([tenantId, policyId])
  @@index([tenantId, policyVersionId])
}

model PolicyAcknowledgement {
  id              String        @id @default(cuid())
  policyVersionId String
  userId          String
  acknowledgedAt  DateTime      @default(now())
  policyVersion   PolicyVersion @relation(fields: [policyVersionId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id])

  @@unique([policyVersionId, userId])
}

model PolicyControlLink {
  // denorm-tenantId — direct tenantId + composite parent FK on the
  // Policy side. The Control side stays single-column because
  // Control.tenantId is intentionally nullable (library-derived
  // controls are global). The pre-denorm chained RLS only walked
  // via Policy too, so this matches the existing protection model
  // and additionally lifts read perf into the trivial RLS path.
  id        String  @id @default(cuid())
  tenantId  String
  policyId  String
  controlId String
  control   Control @relation(fields: [controlId], references: [id], onDelete: Cascade)
  policy    Policy  @relation(fields: [policyId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenant    Tenant  @relation(fields: [tenantId], references: [id])

  @@unique([policyId, controlId])
  @@index([tenantId])
  @@index([tenantId, policyId])
  @@index([tenantId, controlId])
}

/// Evidence-to-Retain checklist for a policy. Items are parsed
/// best-effort from the template's "Evidence to Retain" section on
/// creation (label only); the tenant then links each to a real
/// Evidence record. The link makes a policy's operational proof
/// navigable instead of just prose. evidenceId is nullable (SetNull on
/// evidence delete) — an unlinked item is a still-open checklist entry.
model PolicyEvidenceItem {
  id         String    @id @default(cuid())
  tenantId   String
  policyId   String
  /// Free-text checklist label (e.g. "Risk register: 7 years").
  label      String
  sortOrder  Int       @default(0)
  evidenceId String?
  createdAt  DateTime  @default(now())
  policy     Policy    @relation(fields: [policyId, tenantId], references: [id, tenantId], onDelete: Cascade)
  evidence   Evidence? @relation(fields: [evidenceId], references: [id], onDelete: SetNull)
  tenant     Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, policyId])
  @@index([evidenceId])
}

model PolicyTemplate {
  id          String            @id @default(cuid())
  title       String
  category    String?
  language    String?           @default("en")
  contentType PolicyContentType @default(MARKDOWN)
  contentText String
  tags        String?
  isGlobal    Boolean           @default(true)
  /// Provenance for imported templates (e.g. 'ciso-toolkit'). NULL for
  /// hand-written templates. Gates the "Adapted from …" attribution
  /// credit in the template picker — a licensing obligation for
  /// third-party content (MIT etc.).
  source      String?
  /// Stable upstream id for imported templates (e.g. 'POL-02'). Lets the
  /// seed/sync upsert idempotently without relying on title.
  externalRef String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Finding {
  id                    String            @id @default(cuid())
  tenantId              String
  auditId               String?
  severity              FindingSeverity
  type                  FindingType
  title                 String
  description           String
  rootCause             String?
  correctiveAction      String?
  // Free-text analyst notes / commentary on the finding. Encrypted at
  // rest (see encrypted-fields manifest).
  analysis              String?
  owner                 String?
  // Assignee — a tenant member accountable for the finding (supersedes
  // the legacy free-text `owner`).
  assigneeUserId        String?
  // The control this finding is raised against.
  controlId             String?
  // A compensating control that mitigates the finding.
  compensatingControlId String?
  dueDate               DateTime?
  status                FindingStatus     @default(OPEN)
  verificationNotes     String?
  verifiedBy            String?
  verifiedAt            DateTime?
  // Generic provenance tag — identifies findings auto-materialized from
  // a derived source (e.g. sourceKind='NIS2_SELF_ASSESSMENT',
  // sourceRef=<questionId>) so re-running the materializer is idempotent
  // and can reconcile (close on now-passing answers). NULL for
  // hand-raised findings.
  sourceKind            String?
  sourceRef             String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  deletedAt             DateTime?
  deletedByUserId       String?
  audit                 Audit?            @relation(fields: [auditId], references: [id])
  tenant                Tenant            @relation(fields: [tenantId], references: [id])
  assignee              User?             @relation("FindingAssignee", fields: [assigneeUserId], references: [id])
  control               Control?          @relation("FindingControl", fields: [controlId], references: [id], onDelete: SetNull)
  compensatingControl   Control?          @relation("FindingCompensatingControl", fields: [compensatingControlId], references: [id], onDelete: SetNull)
  evidenceLinks         FindingEvidence[]
  riskLinks             FindingRisk[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, deletedAt])
  @@index([tenantId, auditId])
  @@index([tenantId, assigneeUserId])
  @@index([tenantId, controlId])
  @@index([tenantId, compensatingControlId])
  // Idempotent materializer lookup: findings for one derived source.
  @@index([tenantId, sourceKind, sourceRef])
}

// Many-to-many: a finding can implicate several risks. Composite parent
// FKs to (id, tenantId) guarantee both sides share this row's tenant —
// the FindingEvidence pattern. RLS + indexes mirror that junction.
model FindingRisk {
  id        String   @id @default(cuid())
  tenantId  String
  findingId String
  riskId    String
  createdAt DateTime @default(now())
  finding   Finding  @relation(fields: [findingId, tenantId], references: [id, tenantId], onDelete: Cascade)
  risk      Risk     @relation(fields: [riskId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([findingId, riskId])
  @@index([tenantId])
  @@index([tenantId, findingId])
  @@index([tenantId, riskId])
}

model FindingEvidence {
  // denorm-tenantId — Phase 2: junction with two composite parent
  // FKs. Each FK references its parent's (id, tenantId) unique
  // constraint, which transitively guarantees both parents share
  // this row's tenantId — strictly stronger than the previous
  // chained-RLS WITH CHECK (which was bypass-able by SECURITY
  // DEFINER paths or admin migrations).
  id         String   @id @default(cuid())
  tenantId   String
  findingId  String
  evidenceId String
  evidence   Evidence @relation(fields: [evidenceId, tenantId], references: [id, tenantId], onDelete: Cascade)
  finding    Finding  @relation(fields: [findingId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([findingId, evidenceId])
  @@index([tenantId])
  @@index([tenantId, findingId])
  @@index([tenantId, evidenceId])
}

// ─── NIS2 Article 23 incident response ──────────────────────────────
// A live security incident (distinct from Finding, which is an AUDIT
// observation). The detectedAt clock drives the Article 23 regulatory
// notification deadlines (24h / 72h / 1 month). Methodology adapted
// (CC BY 4.0) from Kshreenath/NIS2-Checklist — Paolo Carner / BARE
// Consulting. See docs/implementation-notes/2026-06-28-incident-response.md.
model Incident {
  id              String                  @id @default(cuid())
  tenantId        String
  // Tenant-scoped human reference, e.g. INC-2026-001.
  reference       String
  title           String
  // Free-text incident description. Encrypted at rest (Epic B) +
  // sanitized on write (Epic D).
  description     String
  severity        IncidentSeverity
  phase           IncidentPhase           @default(DETECTION)
  // 'RANSOMWARE' | 'DATA_BREACH' | 'DDOS' | 'UNAUTHORIZED_ACCESS' | 'OTHER'
  incidentType    String
  // The clock starts here — drives the 24h/72h/1-month deadlines.
  detectedAt      DateTime
  // Whether NIS2 Article 23 notification is required. SUGGESTED from
  // severity (HIGH/CRITICAL) but never auto-asserted — a human confirms
  // (the tenant's DPO/legal owns the legal determination).
  reportable      Boolean                 @default(false)
  reportedAt      DateTime?
  containedAt     DateTime?
  resolvedAt      DateTime?
  // Incident commander (a tenant member). Plain userId — no FK relation,
  // mirroring Finding.verifiedBy / deletedByUserId.
  ownerUserId     String?
  // Art.21(2) controls implicated by this incident.
  linkedControlIds String[]
  // Keys of completed containment-runbook steps (per-incidentType
  // checklist in src/data/incident-containment.ts). Checking a step also
  // appends an IncidentTimelineEntry — this array is the persisted
  // checkbox state. Reference guidance, not enforced.
  completedContainmentSteps String[] @default([])
  createdByUserId String
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  tenant          Tenant                  @relation(fields: [tenantId], references: [id])
  notifications   IncidentNotification[]
  timeline        IncidentTimelineEntry[]
  evidenceLinks   IncidentEvidence[]

  @@unique([id, tenantId])
  @@unique([tenantId, reference])
  @@index([tenantId])
  @@index([tenantId, phase])
  @@index([tenantId, severity, detectedAt])
  @@index([tenantId, ownerUserId])
}

// Junction linking an incident to forensic Evidence records (logs, disk
// images, memory/network captures). Mirrors FindingEvidence: two composite
// parent FKs to (id, tenantId) guarantee both parents share this row's
// tenant. RLS + indexes mirror that junction.
model IncidentEvidence {
  id         String   @id @default(cuid())
  tenantId   String
  incidentId String
  evidenceId String
  // Optional forensic-checklist category this evidence satisfies (e.g.
  // 'SYSTEM_LOGS', 'MEMORY_CAPTURE') — a key from the forensic checklist
  // in src/data/incident-containment.ts. NULL for ad-hoc links.
  forensicCategory String?
  createdAt  DateTime @default(now())
  evidence   Evidence @relation(fields: [evidenceId, tenantId], references: [id, tenantId], onDelete: Cascade)
  incident   Incident @relation(fields: [incidentId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([incidentId, evidenceId])
  @@index([tenantId])
  @@index([tenantId, incidentId])
  @@index([tenantId, evidenceId])
}

// The Article 23 notification clock — one row per required notification
// kind. Auto-created (3 rows) when an incident is marked reportable; the
// deadline derives from the incident's detectedAt.
model IncidentNotification {
  id            String                     @id @default(cuid())
  tenantId      String
  incidentId    String
  kind          IncidentNotificationKind
  // detectedAt + 24h / +72h / +1 month.
  dueAt         DateTime
  status        IncidentNotificationStatus @default(PENDING)
  submittedAt   DateTime?
  // Authority case ref returned on submission (plaintext — load-bearing).
  submissionRef String?
  // What was submitted (the report text). Encrypted at rest (Epic B) +
  // sanitized on write (Epic D).
  submissionNote String?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  incident      Incident                   @relation(fields: [incidentId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenant        Tenant                     @relation(fields: [tenantId], references: [id])

  @@unique([incidentId, kind])
  @@index([tenantId])
  @@index([tenantId, incidentId])
  @@index([tenantId, status, dueAt])
}

// Append-only incident timeline (who did what, when) — the forensic +
// narrative record. Distinct from AuditLog (this is incident-narrative,
// not the hash-chained system audit).
model IncidentTimelineEntry {
  id          String        @id @default(cuid())
  tenantId    String
  incidentId  String
  at          DateTime      @default(now())
  // Plain userId of the actor — no FK relation.
  actorUserId String?
  // Free-text narrative entry. Encrypted at rest (Epic B) + sanitized
  // on write (Epic D).
  entry       String
  phaseAtTime IncidentPhase
  incident    Incident      @relation(fields: [incidentId, tenantId], references: [id, tenantId], onDelete: Cascade)
  tenant      Tenant        @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, incidentId, at])
}

/// Business Impact Analysis (ISO 22301 / NIS2 Art.21(2)(c) / DORA
/// operational resilience). Clean-room from the recognised BIA
/// methodology — the operational artifact that satisfies the NIS2
/// business-continuity requirement IC previously only seeded. Attaches
/// to a modeled ProcessNode (preferred) or stands free. Sits beside
/// Incidents as a sibling operational-resilience obligation. Tenant-
/// scoped: RLS + Epic B (`notes`) + Epic D + indexes.
model BusinessImpactAnalysis {
  id            String  @id @default(cuid())
  tenantId      String
  /// Attach to a modeled process node (preferred). Null = free-standing
  /// service not yet on a process map.
  processNodeId String?
  name          String
  /// CRITICAL | HIGH | MEDIUM | LOW.
  criticality   String
  /// Recovery Time Objective — hours to restore after disruption.
  rtoHours      Int?
  /// Recovery Point Objective — tolerable data-loss window (hours).
  rpoHours      Int?
  /// Max Tolerable Period of Disruption — hours before the impact is
  /// existential. The primary driver of recovery-priority ranking.
  mtpdHours     Int?
  /// Structured impact ramp: [{ atHours, financial, operational,
  /// reputational, legal }] — powers the impact-over-time surface.
  impactProfile Json?
  /// Free-text analyst notes — encrypted at rest (Epic B) + sanitized
  /// on write (Epic D).
  notes         String?
  ownerUserId   String?
  reviewedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant                @relation(fields: [tenantId], references: [id])
  processNode   ProcessNode?          @relation(fields: [processNodeId], references: [id])
  ownerUser     User?                 @relation("BiaOwner", fields: [ownerUserId], references: [id])
  dependencies  BiaDependency[]
  /// BIA-as-evidence: the continuity control (NIS2 Art.21(2)(c)) links
  /// this BIA via a ControlEvidenceLink (kind BIA).
  evidenceLinks ControlEvidenceLink[]

  @@index([tenantId, criticality])
  @@index([tenantId, processNodeId])
  @@index([tenantId, ownerUserId])
}

/// A dependency a BIA'd process relies on — a polymorphic pointer
/// (process/asset/vendor) so the recovery sequence can account for what
/// must be up first. Polymorphic by design (dependsOnType + dependsOnId),
/// so no FK to the three target tables.
model BiaDependency {
  id            String   @id @default(cuid())
  biaId         String
  tenantId      String
  /// 'PROCESS' | 'ASSET' | 'VENDOR'.
  dependsOnType String
  dependsOnId   String
  createdAt     DateTime @default(now())

  bia    BusinessImpactAnalysis @relation(fields: [biaId], references: [id], onDelete: Cascade)
  tenant Tenant                 @relation(fields: [tenantId], references: [id])

  @@index([tenantId, biaId])
}

model Framework {
  id                  String                  @id @default(cuid())
  key                 String                  @unique
  description         String?
  name                String
  version             String?
  metadataJson        String?
  contentHash         String?
  sourceUrn           String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @default(now()) @updatedAt
  kind                FrameworkKind           @default(ISO_STANDARD)
  packs               FrameworkPack[]
  requirements        FrameworkRequirement[]
  mappingSetsAsSource RequirementMappingSet[] @relation("MappingSetSource")
  mappingSetsAsTarget RequirementMappingSet[] @relation("MappingSetTarget")

  @@unique([key, version])
}

model FrameworkRequirement {
  id                      String                           @id @default(cuid())
  frameworkId             String
  code                    String
  title                   String
  description             String?
  category                String?
  sortOrder               Int                              @default(0)
  theme                   String?
  themeNumber             Int?
  section                 String?
  deprecatedAt            DateTime?
  controlLinks            ControlRequirementLink[]
  templateLinks           ControlTemplateRequirementLink[]
  aiSystemLinks           AiSystemRequirementLink[]
  mappingsFrom            FrameworkMapping[]               @relation("MappingFrom")
  mappingsTo              FrameworkMapping[]               @relation("MappingTo")
  requirementMappingsFrom RequirementMapping[]             @relation("ReqMappingSource")
  requirementMappingsTo   RequirementMapping[]             @relation("ReqMappingTarget")
  framework               Framework                        @relation(fields: [frameworkId], references: [id])
  tenantOrders            FrameworkRequirementOrder[]

  @@unique([frameworkId, code])
}

// Epic 46.4 — per-tenant ordering overlay for the framework
// builder. Frameworks themselves are global rows shared across
// every tenant; this table lets a tenant reorder requirements (and
// implicitly sections) without ever mutating the global
// `FrameworkRequirement.sortOrder`. The tree usecase merges these
// values BEFORE grouping, so a tenant override always wins.
//
// RLS: canonical Class-A shape (direct tenantId column). Migration
// `20260501104500_framework_requirement_order_overlay` applies the
// `tenant_isolation` + `superuser_bypass` policies.
model FrameworkRequirementOrder {
  id            String               @id @default(cuid())
  tenantId      String
  requirementId String
  sortOrder     Int
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  requirement   FrameworkRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([tenantId, requirementId])
  @@index([tenantId])
}

model FrameworkPack {
  id            String             @id @default(cuid())
  key           String             @unique
  name          String
  frameworkId   String
  version       String?
  description   String?
  createdAt     DateTime           @default(now())
  framework     Framework          @relation(fields: [frameworkId], references: [id])
  templateLinks PackTemplateLink[]
}

model PackTemplateLink {
  id         String          @id @default(cuid())
  packId     String
  templateId String
  pack       FrameworkPack   @relation(fields: [packId], references: [id], onDelete: Cascade)
  template   ControlTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([packId, templateId])
}

model FrameworkMapping {
  id                String                @id @default(cuid())
  fromRequirementId String
  toRequirementId   String?
  toControlId       String?
  rationale         String?
  fromRequirement   FrameworkRequirement  @relation("MappingFrom", fields: [fromRequirementId], references: [id])
  toControl         Control?              @relation(fields: [toControlId], references: [id])
  toRequirement     FrameworkRequirement? @relation("MappingTo", fields: [toRequirementId], references: [id])

  @@unique([fromRequirementId, toControlId])
}

model RequirementMappingSet {
  id                String               @id @default(cuid())
  sourceFrameworkId String
  targetFrameworkId String
  name              String
  description       String?
  version           Int                  @default(1)
  sourceUrn         String? // Provenance URN from library system
  contentHash       String? // Deduplication hash
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @default(now()) @updatedAt
  sourceFramework   Framework            @relation("MappingSetSource", fields: [sourceFrameworkId], references: [id])
  targetFramework   Framework            @relation("MappingSetTarget", fields: [targetFrameworkId], references: [id])
  mappings          RequirementMapping[]

  @@unique([sourceFrameworkId, targetFrameworkId])
  @@index([sourceFrameworkId])
  @@index([targetFrameworkId])
}

model RequirementMapping {
  id                  String                @id @default(cuid())
  mappingSetId        String
  sourceRequirementId String
  targetRequirementId String
  strength            MappingStrength       @default(RELATED)
  rationale           String?
  metadataJson        String? // Provenance, ingestion source, extra context
  /// Audit Coherence S9 (2026-05-24) — temporal validity window.
  /// `validFrom` defaults to creation time; `validTo` is null for
  /// "currently active" mappings. The traceability resolver
  /// excludes mappings where `validTo < now()` so historical /
  /// superseded mappings don't pollute current gap-analysis
  /// reports. Auditors can still query the row for the historical
  /// trail.
  validFrom           DateTime              @default(now())
  validTo             DateTime?
  createdAt           DateTime              @default(now())
  mappingSet          RequirementMappingSet @relation(fields: [mappingSetId], references: [id], onDelete: Cascade)
  sourceRequirement   FrameworkRequirement  @relation("ReqMappingSource", fields: [sourceRequirementId], references: [id])
  targetRequirement   FrameworkRequirement  @relation("ReqMappingTarget", fields: [targetRequirementId], references: [id])

  @@unique([mappingSetId, sourceRequirementId, targetRequirementId])
  @@index([sourceRequirementId])
  @@index([targetRequirementId])
  @@index([mappingSetId])
  // Audit Coherence S9 — covers the "active mappings" hot path
  // (`validTo IS NULL OR validTo > now()` filter).
  @@index([validTo])
}

model ControlRequirementLink {
  id            String               @id @default(cuid())
  tenantId      String
  controlId     String
  requirementId String
  createdAt     DateTime             @default(now())
  control       Control              @relation(fields: [controlId], references: [id], onDelete: Cascade)
  requirement   FrameworkRequirement @relation(fields: [requirementId], references: [id])
  tenant        Tenant               @relation(fields: [tenantId], references: [id])

  @@unique([controlId, requirementId])
  @@index([tenantId, requirementId])
}

model ControlTestPlan {
  id                 String            @id @default(cuid())
  tenantId           String
  controlId          String
  name               String
  description        String?
  method             TestMethod        @default(MANUAL)
  frequency          ControlFrequency  @default(AD_HOC)
  nextDueAt          DateTime?
  ownerUserId        String?
  expectedEvidence   Json?
  status             TestPlanStatus    @default(ACTIVE)
  // Epic G-2 — automated scheduled execution. `nextDueAt` stays the
  // soft due-by indicator (UI overdue badge, deadline-monitor digest);
  // `nextRunAt` is the hard scheduler trigger. They diverge for plans
  // where humans review monthly but the script runs daily.
  automationType     AutomationType    @default(MANUAL)
  schedule           String?
  scheduleTimezone   String?
  nextRunAt          DateTime?
  lastScheduledRunAt DateTime?
  automationConfig   Json?
  createdByUserId    String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  /// Soft-delete (bulk-delete support) — enrolled in SOFT_DELETE_MODELS.
  deletedAt          DateTime?
  deletedByUserId    String?
  control            Control           @relation(fields: [controlId], references: [id])
  createdBy          User              @relation("TestPlanCreator", fields: [createdByUserId], references: [id])
  owner              User?             @relation("TestPlanOwner", fields: [ownerUserId], references: [id])
  tenant             Tenant            @relation(fields: [tenantId], references: [id])
  runs               ControlTestRun[]
  steps              ControlTestStep[]

  @@index([tenantId])
  @@index([tenantId, controlId])
  @@index([tenantId, nextDueAt])
  @@index([tenantId, status])
  @@index([tenantId, nextRunAt])
  @@index([tenantId, automationType, status])
  @@index([tenantId, deletedAt])
}

model ControlTestRun {
  id               String                    @id @default(cuid())
  tenantId         String
  controlId        String
  testPlanId       String
  status           TestRunStatus             @default(PLANNED)
  result           TestResult?
  executedAt       DateTime?
  executedByUserId String?
  notes            String?
  findingSummary   String?
  createdByUserId  String
  requestId        String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  evidence         ControlTestEvidenceLink[]
  control          Control                   @relation(fields: [controlId], references: [id])
  createdBy        User                      @relation("TestRunCreator", fields: [createdByUserId], references: [id])
  executedBy       User?                     @relation("TestRunExecutor", fields: [executedByUserId], references: [id])
  tenant           Tenant                    @relation(fields: [tenantId], references: [id])
  // Cascade so the data-lifecycle hard-purge of a soft-deleted test plan
  // (90d) erases its runs too (runs' evidence links already cascade).
  testPlan         ControlTestPlan           @relation(fields: [testPlanId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, testPlanId])
  @@index([tenantId, result])
  @@index([tenantId, executedAt])
  @@index([tenantId, controlId])
}

model ControlTestEvidenceLink {
  id                  String           @id @default(cuid())
  tenantId            String
  testRunId           String
  kind                TestEvidenceKind
  fileId              String?
  evidenceId          String?
  url                 String?
  integrationResultId String?
  note                String?
  createdByUserId     String
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  sha256Hash          String?
  createdBy           User             @relation("TestEvidenceCreator", fields: [createdByUserId], references: [id])
  evidence            Evidence?        @relation(fields: [evidenceId], references: [id])
  tenant              Tenant           @relation(fields: [tenantId], references: [id])
  testRun             ControlTestRun   @relation(fields: [testRunId], references: [id], onDelete: Cascade)

  @@unique([testRunId, kind, evidenceId])
  @@unique([testRunId, kind, fileId])
  @@index([tenantId])
  @@index([tenantId, testRunId])
}

model ControlTestStep {
  id             String          @id @default(cuid())
  tenantId       String
  testPlanId     String
  sortOrder      Int             @default(0)
  instruction    String
  expectedOutput String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  testPlan       ControlTestPlan @relation(fields: [testPlanId], references: [id], onDelete: Cascade)

  @@index([tenantId, testPlanId])
}

/// Daily compliance KPI snapshot for trend reporting.
/// One row per tenant per day. Idempotent via @@unique([tenantId, snapshotDate]).
/// Stores denormalized KPI values computed by the daily snapshot job.
model ComplianceSnapshot {
  id           String   @id @default(cuid())
  tenantId     String
  /// Calendar date (midnight UTC) — NOT a full timestamp.
  /// Enables clean GROUP BY / ORDER BY for trend queries.
  snapshotDate DateTime @db.Date

  // ── Control Coverage ──
  controlsTotal       Int @default(0)
  controlsApplicable  Int @default(0)
  controlsImplemented Int @default(0)
  controlsInProgress  Int @default(0)
  controlsNotStarted  Int @default(0)
  /// Cached coverage % × 10 (e.g. 753 = 75.3%). Int avoids float precision issues.
  controlCoverageBps  Int @default(0)

  // ── Risks ──
  risksTotal      Int @default(0)
  risksOpen       Int @default(0)
  risksMitigating Int @default(0)
  risksAccepted   Int @default(0)
  risksClosed     Int @default(0)
  risksLow        Int @default(0)
  risksMedium     Int @default(0)
  risksHigh       Int @default(0)
  risksCritical   Int @default(0)
  // KPI-card metrics. NULLABLE (not @default) so pre-existence snapshot rows
  // read NULL ("no data, don't plot") instead of a false 0 — forward-only
  // fill, no backfill. See src/lib/charts/kpi-trends.ts.
  risksAvgScore      Float?
  risksOverdueReview Int?

  // ── Evidence ──
  evidenceTotal      Int @default(0)
  evidenceOverdue    Int @default(0)
  evidenceDueSoon7d  Int @default(0)
  evidenceDueSoon30d Int @default(0)
  evidenceCurrent    Int @default(0)
  // Status-bucket counts for the KPI cards. NULLABLE (not @default(0)) so
  // pre-existence snapshot rows read NULL ("no data, don't plot") instead of a
  // false 0 — forward-only fill, no backfill. See src/lib/charts/kpi-trends.ts.
  evidenceDraft     Int?
  evidenceSubmitted Int?
  evidenceApproved  Int?

  // ── Policies ──
  policiesTotal         Int @default(0)
  policiesPublished     Int @default(0)
  policiesOverdueReview Int @default(0)
  // Status-bucket counts for the KPI cards (nullable forward-only fill).
  policiesDraft    Int?
  policiesInReview Int?
  policiesApproved Int?

  // ── Tasks ──
  tasksTotal   Int @default(0)
  tasksOpen    Int @default(0)
  tasksOverdue Int @default(0)
  // Due-within-7-days count for the KPI card (nullable forward-only fill).
  tasksDueSoon7d Int?

  // ── Vendors ──
  vendorsTotal         Int @default(0)
  vendorsOverdueReview Int @default(0)
  // Status/criticality counts for the KPI cards (nullable forward-only fill).
  vendorsActive   Int?
  vendorsCritical Int?

  // ── Test plans ──
  // `testPlansTotal` anchors the trim (@default(0), like every other total);
  // the status buckets are nullable forward-only fill. See kpi-trends.ts.
  testPlansTotal    Int @default(0)
  testPlansActive   Int?
  testPlansPaused   Int?
  testPlansArchived Int?

  // ── Assets ──
  assetsTotal           Int @default(0)
  assetsActive          Int @default(0)
  assetsHighCriticality Int @default(0)
  assetsRetired         Int @default(0)

  // ── Findings ──
  findingsOpen Int @default(0)

  // ── Meta ──
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, snapshotDate])
  @@index([tenantId, snapshotDate])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────
// Epic G-5 — Control Exception Register.
//
// Formal record of a control that cannot be implemented as designed,
// covering the auditor's required artifact: who accepted the risk,
// what compensating control (if any) is in place, when it expires,
// and the chain of renewals over time.
//
// Lifecycle is REQUESTED → (APPROVED | REJECTED) → (EXPIRED). A
// renewal is a brand-new row in REQUESTED state with `renewedFromId`
// pointing at the prior (typically EXPIRED or near-expiry APPROVED)
// row — the renewal lineage is intentionally a per-row link, not a
// status mutation, so each acceptance has its own approver +
// expiry + audit trail.
//
// `compensatingControlId` is optional but heavily used: most
// exceptions carry a "we mitigate by doing X with Control Y"
// rationale that auditors expect to see linked.
//
// Tenant scoping: Class-A direct-scoped (own `tenantId` column);
// canonical RLS trio + FORCE in the migration. The control FK is
// composite (controlId, tenantId) → Control(id, tenantId) so a
// cross-tenant link is impossible at the DB level. Compensating
// control + renewal-from FK use the same composite shape.
// ─────────────────────────────────────────────────────────────────

model ControlException {
  id                    String                 @id @default(cuid())
  tenantId              String
  /// FK target — the control that cannot be implemented as designed.
  controlId             String
  status                ControlExceptionStatus @default(REQUESTED)
  /// Required free-text rationale for the exception. Surfaced
  /// verbatim in audit packs; encrypted at rest via the manifest.
  justification         String
  /// Optional FK to the control that mitigates this exception
  /// ("we don't enforce X because we instead do Y via control Z").
  compensatingControlId String?
  /// User who carries the risk-acceptance authority. Required at
  /// creation — auditors want to know up-front who would sign off.
  riskAcceptedByUserId  String
  /// Set when status transitions to APPROVED.
  approvedAt            DateTime?
  approvedByUserId      String?
  /// Set when status transitions to REJECTED.
  rejectedAt            DateTime?
  rejectedByUserId      String?
  rejectionReason       String?
  /// Required deadline at which the exception expires. The expiry
  /// monitor reminds approvers in the 30 → 7 → 1 day windows.
  /// Nullable for REQUESTED rows that haven't been formally
  /// scoped yet; required (CHECK) once status moves to APPROVED.
  expiresAt             DateTime?
  /// Renewal lineage — points at the prior row this one supersedes.
  /// Self-referential composite FK (renewedFromId, tenantId) →
  /// ControlException(id, tenantId) so renewals can never reference
  /// a prior row in another tenant.
  renewedFromId         String?
  createdByUserId       String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  /// Soft-delete columns — same convention as AuditCycle.
  deletedAt             DateTime?
  deletedByUserId       String?

  tenant              Tenant             @relation(fields: [tenantId], references: [id])
  control             Control            @relation("ControlExceptionAffected", fields: [controlId, tenantId], references: [id, tenantId])
  compensatingControl Control?           @relation("ControlExceptionCompensating", fields: [compensatingControlId, tenantId], references: [id, tenantId])
  renewedFrom         ControlException?  @relation("ControlExceptionRenewalChain", fields: [renewedFromId, tenantId], references: [id, tenantId])
  renewals            ControlException[] @relation("ControlExceptionRenewalChain")
  createdBy           User               @relation("ControlExceptionCreatedBy", fields: [createdByUserId], references: [id])
  riskAcceptedBy      User               @relation("ControlExceptionRiskAcceptedBy", fields: [riskAcceptedByUserId], references: [id])
  approvedBy          User?              @relation("ControlExceptionApprovedBy", fields: [approvedByUserId], references: [id])
  rejectedBy          User?              @relation("ControlExceptionRejectedBy", fields: [rejectedByUserId], references: [id])
  deletedBy           User?              @relation("ControlExceptionDeletedBy", fields: [deletedByUserId], references: [id])

  /// Composite parent key. Used by the self-referential FK above
  /// AND by any future child entity (audit packs, approval logs).
  @@unique([id, tenantId])
  @@index([tenantId, status])
  @@index([tenantId, expiresAt])
  @@index([tenantId, controlId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, createdAt])
  @@index([renewedFromId])
}

// ─────────────────────────────────────────────────────────────────
// Epic G-7 — Risk Treatment Plans (ISO 27001 6.1.3).
//
// Replaces the free-text `Risk.treatmentNotes` field with a
// structured plan: explicit strategy + owner + target date +
// ordered milestones, each with its own due date and completion
// state. Auditors expect to walk the milestone sequence on
// every MITIGATE plan; the ordered list (sortOrder) makes that
// reconstructible without a JSON blob.
//
// Lifecycle is DRAFT → ACTIVE → (COMPLETED | OVERDUE). OVERDUE is
// set by the monitor job, not user paths — operators who want to
// close a plan past its target date go through "complete plan"
// (transitions to COMPLETED with a closing remark recorded in the
// audit log).
//
// Tenant scoping: Class-A direct-scoped (own `tenantId` column);
// canonical RLS trio + FORCE in the migration. The risk FK is
// composite (riskId, tenantId) → Risk(id, tenantId) so cross-
// tenant plans are impossible by construction. Milestones use the
// same composite shape against the parent plan.
// ─────────────────────────────────────────────────────────────────

model RiskTreatmentPlan {
  id                String              @id @default(cuid())
  tenantId          String
  riskId            String
  /// Strategy chosen for this plan. Parallel to (but more
  /// vocabulary-current than) the legacy `Risk.treatment` field —
  /// see `TreatmentStrategy` enum docstring.
  strategy          TreatmentStrategy
  /// Plan owner — the user accountable for execution. Required
  /// because auditors will ask "who runs this plan?".
  ownerUserId       String
  /// SLA target — surfaced in the dashboard + drives the
  /// overdue-monitor job's flip to OVERDUE.
  targetDate        DateTime
  status            TreatmentPlanStatus @default(DRAFT)
  /// Set when status transitions to COMPLETED. Audit-visible
  /// timestamp + the user who closed the plan.
  completedAt       DateTime?
  completedByUserId String?
  /// Free-text closing remark — encrypted at rest because the
  /// rationale may name internal users / systems.
  closingRemark     String?
  /// Soft-delete columns — same convention as AuditCycle.
  createdByUserId   String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  deletedByUserId   String?

  tenant      Tenant               @relation(fields: [tenantId], references: [id])
  risk        Risk                 @relation(fields: [riskId, tenantId], references: [id, tenantId])
  owner       User                 @relation("RiskTreatmentPlanOwner", fields: [ownerUserId], references: [id])
  createdBy   User                 @relation("RiskTreatmentPlanCreator", fields: [createdByUserId], references: [id])
  completedBy User?                @relation("RiskTreatmentPlanCompleter", fields: [completedByUserId], references: [id])
  deletedBy   User?                @relation("RiskTreatmentPlanDeleter", fields: [deletedByUserId], references: [id])
  milestones  TreatmentMilestone[]

  /// Composite parent key — supports the
  /// `TreatmentMilestone.(treatmentPlanId, tenantId) →
  /// RiskTreatmentPlan.(id, tenantId)` FK shape.
  @@unique([id, tenantId])
  @@index([tenantId, status])
  @@index([tenantId, riskId])
  @@index([tenantId, ownerUserId, status])
  @@index([tenantId, targetDate])
  @@index([tenantId, deletedAt])
  @@index([tenantId, createdAt])
}

model TreatmentMilestone {
  id                String    @id @default(cuid())
  tenantId          String
  treatmentPlanId   String
  title             String
  /// Free-text milestone description (e.g. "Procure new SIEM
  /// licences"). Encrypted at rest because the description may
  /// name internal systems / vendors.
  description       String?
  dueDate           DateTime
  /// Set when the milestone is marked complete.
  completedAt       DateTime?
  completedByUserId String?
  /// Optional reference to evidence backing this milestone —
  /// String? rather than a typed FK so it can carry a URL, a
  /// FileRecord id, or an internal Evidence id without a fan-out
  /// in the schema. The future `attachEvidence` usecase will
  /// migrate this to a typed relation.
  evidence          String?
  /// Manual ordering. Plans render milestones in this order; the
  /// reorder usecase mutates the column in a single tx.
  sortOrder         Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  treatmentPlan RiskTreatmentPlan @relation(fields: [treatmentPlanId, tenantId], references: [id, tenantId], onDelete: Cascade)
  completedBy   User?             @relation("TreatmentMilestoneCompleter", fields: [completedByUserId], references: [id])

  @@index([tenantId, treatmentPlanId])
  @@index([tenantId, dueDate])
  @@index([tenantId, completedAt])
  @@index([treatmentPlanId, sortOrder])
}

// ─── NIS2 Gap Assessment (imported open-data, CC BY 4.0) ──────────────
//
// The 116-question / 15-domain NIS2 self-assessment question set imported
// from NISD2/nis2-gap-assessment-schema (content CC BY 4.0 — see
// prisma/fixtures/nis2-gap-assessment.LICENSE.md). This is a SEPARATE
// artifact from the seeded NIS2 `Framework` (key='NIS2',
// version='2022/2555') and its requirements — the two live side by side,
// never merged. Enum-shaped columns (criticality/respondent/consequence/
// timeToFix/answer/status) are stored as String, validated at ingest by
// the Zod string enums in src/lib/schemas/nis2-gap-assessment.ts — the
// codebase never deals with the upstream integer codes.

/// Global reference: one of the 15 NIS2 gap-assessment domains.
/// Not tenant-scoped (shared library content, no RLS).
model Nis2GapDomain {
  /// Upstream domain id (0–14) — stable natural key from the source.
  id          Int    @id
  /// Short stable code, e.g. "SCOPE" (upstream `code`).
  code        String @unique
  /// Bilingual { en, de } — stored verbatim from upstream.
  name        Json
  description Json
  /// Suggested assessment "day" bucket (1–5) from upstream.
  day         Int

  questions Nis2GapQuestion[]
}

/// Global reference: one NIS2 gap-assessment question.
/// Not tenant-scoped (shared library content, no RLS).
model Nis2GapQuestion {
  /// Upstream question id, e.g. "gap-0-01" (globally unique).
  id           String  @id
  /// FK → Nis2GapDomain.id (upstream `domain` integer).
  domainId     Int
  /// Bilingual { en, de } legalese question text.
  text         Json
  /// Bilingual { en, de } plain-language restatement.
  plainText    Json
  /// Statutory anchor, e.g. "§28 BSIG" or "Art 21(2)(a)". German-law
  /// citations are PRESERVED and tagged here, never dropped.
  legalBasis   String
  /// String enums — validated at ingest. See NIS2_* in the Zod schema.
  criticality  String
  respondent   String
  consequence  String
  fineExposure Boolean
  timeToFix    String
  day          Int
  /// Upstream question ids this question depends on (gating order).
  dependsOn    String[]

  domain  Nis2GapDomain              @relation(fields: [domainId], references: [id])
  answers Nis2SelfAssessmentAnswer[]

  @@index([domainId])
}

/// Tenant-scoped: one tenant's run through the NIS2 gap assessment.
model Nis2SelfAssessment {
  id          String    @id @default(cuid())
  tenantId    String
  title       String?
  /// Lifecycle: DRAFT | IN_PROGRESS | COMPLETED | ARCHIVED (String, not a
  /// Prisma enum, to mirror the source's string-enum convention).
  status      String    @default("DRAFT")
  /// Provenance of the run — WIZARD_BASELINE (the one-time onboarding-wizard
  /// gap run, assessment #1) or STANDALONE (a later re-assessment started from
  /// the Audits lifecycle surface). String enum, same convention as `status`.
  /// Never delegated when WIZARD_BASELINE (see gap-assessment-assignment).
  source      String    @default("STANDALONE")
  /// Opaque actor ids — plain String (no User FK) so the assessment is
  /// independent of user-lifecycle cascades.
  createdById String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  answers     Nis2SelfAssessmentAnswer[]
  assignments Nis2GapAssignment[]

  @@index([tenantId, updatedAt])
  @@index([tenantId, createdAt])
}

/// Tenant-scoped: one answer within a self-assessment.
/// `note` is encrypted at rest (Epic B manifest).
model Nis2SelfAssessmentAnswer {
  id           String   @id @default(cuid())
  tenantId     String
  assessmentId String
  questionId   String
  /// String enum: NA | NO | PARTIALLY | YES (validated at the usecase).
  answer       String
  /// Free-text rationale — ENCRYPTED at rest (see encrypted-fields.ts).
  note         String?
  answeredById String?
  answeredAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment Nis2SelfAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question   Nis2GapQuestion    @relation(fields: [questionId], references: [id])

  @@unique([assessmentId, questionId])
  @@index([tenantId, assessmentId])
  @@index([questionId])
}

/// Multi-respondent delegation of a STANDALONE re-assessment: one row per
/// respondent role, partitioning the 116 questions into DISJOINT buckets so
/// each member answers only their own. Answers are NOT copied here — they live
/// on the parent `Nis2SelfAssessmentAnswer` (single source, no merge); an
/// assignment only records WHICH questionIds a member owns. Never dispatched
/// for a WIZARD_BASELINE run (the admin answers the baseline once at onboarding).
model Nis2GapAssignment {
  id             String    @id @default(cuid())
  tenantId       String
  assessmentId   String
  /// String enum: CEO | IT | HR | PROCUREMENT | ANYONE (the bank's respondent).
  respondentRole String
  /// Opaque user id (no FK — mirrors the assessment's actor-id convention);
  /// null for an unclaimed ANYONE bucket.
  assigneeUserId String?
  /// String enum: PENDING | IN_PROGRESS | SUBMITTED.
  status         String    @default("PENDING")
  /// The disjoint subset of question ids this assignment owns.
  questionIds    String[]
  submittedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment Nis2SelfAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  /// One assignment per role per run — makes dispatch idempotent (upsert).
  @@unique([assessmentId, respondentRole])
  @@index([tenantId, assessmentId])
  @@index([tenantId, assigneeUserId])
}

// ─── AI-Governance Self-Assessment (unified AISVS / ISO 42001 / EU AI Act) ───
// Mirrors the NIS2 self-assessment shape: global reference content
// (AiGovDomain + AiGovQuestion) + tenant-scoped run (AiGovSelfAssessment +
// AiGovSelfAssessmentAnswer). One 30-question assessment whose answers project
// onto three standards via each question's mappingsJson.

/// Global reference: one AI-governance self-assessment domain (1-7).
/// Not tenant-scoped (shared library content, no RLS).
model AiGovDomain {
  /// Stable domain id (1-7) from the fixture.
  id        Int             @id
  /// Short stable code, e.g. "GOVERNANCE".
  code      String          @unique
  name      String
  questions AiGovQuestion[]
}

/// Global reference: one AI-governance self-assessment question.
/// Not tenant-scoped (shared library content, no RLS).
model AiGovQuestion {
  /// Fixture question id, e.g. "aig-1-01" (globally unique).
  id           String  @id
  domainId     Int
  /// Paraphrased question text (references standards by ID, never verbatim
  /// AISVS/ISO prose — see the per-source license matrix).
  text         String
  /// `{ aisvs: string[], iso42001: string[], euAiAct: string[] }` — the
  /// standard references each answer projects onto (the 3-way readout).
  mappingsJson Json
  /// Architecture gate: null | "RAG" | "AGENTIC" — auto-N/A otherwise.
  conditional  String?
  /// String enum: CRITICAL | HIGH | MEDIUM (validated at the usecase).
  criticality  String

  domain  AiGovDomain                 @relation(fields: [domainId], references: [id])
  answers AiGovSelfAssessmentAnswer[]

  @@index([domainId])
}

/// Tenant-scoped: one tenant's run through the AI-governance self-assessment.
model AiGovSelfAssessment {
  id                 String    @id @default(cuid())
  tenantId           String
  title              String?
  /// Lifecycle: DRAFT | IN_PROGRESS | COMPLETED | ARCHIVED (String enum).
  status             String    @default("DRAFT")
  /// Pins the question-set version this run was started against.
  questionSetVersion Int       @default(1)
  createdById        String?
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant  Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  answers AiGovSelfAssessmentAnswer[]

  @@index([tenantId, updatedAt])
}

/// Tenant-scoped: one answer within an AI-governance self-assessment.
/// `note` is encrypted at rest (Epic B manifest) + sanitised on write (Epic D).
model AiGovSelfAssessmentAnswer {
  id           String   @id @default(cuid())
  tenantId     String
  assessmentId String
  questionId   String
  /// String enum: NA | NO | PARTIALLY | YES (validated at the usecase).
  answer       String
  /// Free-text rationale — ENCRYPTED at rest (see encrypted-fields.ts).
  note         String?
  answeredById String?
  answeredAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment AiGovSelfAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question   AiGovQuestion       @relation(fields: [questionId], references: [id])

  @@unique([assessmentId, questionId])
  @@index([tenantId, assessmentId])
  @@index([questionId])
}

/// Public Trust Center — an EXPLICIT, tenant-curated projection published to
/// the open internet at `/trust/<slug>`. SECURITY-CRITICAL: this is the only
/// intentionally-public surface in an otherwise auth+RLS-locked app. The
/// public page reads ONLY this row (never Risk/Control/Evidence/Finding/…),
/// renders ONLY the fields the tenant explicitly composed, and is OFF by
/// default. Nothing here is auto-derived from live posture — the tenant
/// curates every claim. Free text is sanitised on write (public XSS surface).
/// RLS-covered (carries tenantId) for the authenticated compose path; the
/// public read goes through the system role by `slug` (single curated row).
model TrustCenter {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Public URL segment: /trust/<slug>. Globally unique.
  slug                String   @unique
  /// OFF by default — a tenant has no public page until they explicitly enable.
  enabled             Boolean  @default(false)
  /// Drives X-Robots-Tag — some tenants want the page indexed for marketing,
  /// some want it noindex. OFF (noindex) by default.
  indexable           Boolean  @default(false)
  displayName         String
  tagline             String?
  /// Explicit allowlist of frameworks to show + the status label the TENANT
  /// sets (NOT derived from coverage %, which could leak a low number).
  /// Shape: [{ key, statusLabel, badge }]. Sanitised on write.
  publishedFrameworks Json     @default("[]")
  /// Curated prose the tenant writes — NOT a live control count. Sanitised.
  postureSummary      String?
  /// Links to tenant-chosen, already-public artifacts (whitepaper, SOC2 cover
  /// letter). NEVER auto-exposed evidence. Shape: [{ label, url }]. Sanitised.
  publishedDocuments  Json     @default("[]")
  securityContact     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  /// Audit pointer — who last toggled publish. Plain column (no relation) to
  /// keep the public read graph minimal.
  publishedByUserId   String?

  @@index([tenantId])
}

/// AI compliance-posture summary — a tenant-wide narrative + prioritized
/// advice, generated once/day by the `compliance-posture-summary` cron and
/// CACHED here so the dashboard hero reads it cheaply (never calls an LLM on
/// the render path). Degrades to a deterministic stub summary when no LLM is
/// configured, so the feature is fully functional with zero config.
///
/// Content is an AGGREGATE, non-sensitive narrative derived from already-
/// visible KPIs (coverage %, overdue counts, risk severities) — it is NOT
/// encrypted (see src/lib/security/encrypted-fields.ts) but IS sanitised on
/// write. One row per tenant (upsert by tenantId); the daily regeneration
/// makes it Operational/derived for retention. RLS-covered (carries tenantId).
model CompliancePostureSummary {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  generatedAt   DateTime @default(now())
  /// STRONG | ESTABLISHED | DEVELOPING | AT_RISK. Plain string (not an enum)
  /// so an unforeseen provider label can't hard-fail the row — the output
  /// guard clamps it into the known set before persist.
  postureLabel  String
  /// 0-100 derived maturity/health score; nullable when not computable.
  maturityScore Int?
  /// The narrative (1-3 sentences). Sanitised on write.
  summaryText   String
  /// Prioritized next actions: [{ title, detail, priority }]. Sanitised.
  adviceJson    Json     @default("[]")
  /// The aggregate metrics snapshot fed to the generator (provenance + audit).
  signalsJson   Json     @default("{}")
  /// Which provider produced this row: stub | anthropic | openrouter.
  provider      String
  /// The model id when an LLM produced it; null for the deterministic stub.
  model         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────
// EU AI Act — per-SYSTEM registry (Regulation (EU) 2024/1689).
//
// Distinct from the AI-Act/ISO 42001 *frameworks* (org-wide requirement
// catalogues) and the AI self-assessment (posture): this is the register of
// each concrete AI system a tenant provides or deploys, its risk-tier
// classification (authored from Art 5 / Annex III / Art 50), and its linkage
// to the obligations that tier pulls in. Class-A tenant-scoped shape.
// ─────────────────────────────────────────────────────────────────
model AiSystem {
  id             String           @id @default(cuid())
  tenantId       String
  name           String
  /// Free-text — the system's intended purpose. Sensitive: encrypted at rest
  /// (Epic B manifest) and sanitised on write.
  purpose        String?
  /// Free-text — the deployment/use context. Sensitive: encrypted + sanitised.
  useContext     String?
  /// The provider/vendor of the model or system (e.g. "OpenAI", in-house).
  provider       String?
  deploymentRole AiDeploymentRole @default(DEPLOYER)
  riskTier       AiRiskTier       @default(MINIMAL)
  /// The Regulation clause identifier that drove the tier (e.g. "Annex III(4)",
  /// "Art.5(1)(c)"). Generated by the classifier — explainability, not PII.
  classificationClauseId String?
  /// Human-readable rationale for the tier, citing the clause. Generated.
  classificationRationale String?
  ownerUserId    String?
  status         AiSystemStatus   @default(ACTIVE)
  createdByUserId String?
  deletedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  tenant           Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requirementLinks AiSystemRequirementLink[]
  decisionLogs     AiDecisionLog[]

  /// Composite parent key so child links can never point cross-tenant.
  @@unique([id, tenantId])
  @@index([tenantId, riskTier])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@index([tenantId, createdAt])
}

// Tenant-scoped join: a registered AI system → a framework requirement
// (EU AI Act / ISO 42001 obligation). Mirrors ControlRequirementLink; created
// only through the usecase (with audit). Composite FK to AiSystem(id, tenantId).
model AiSystemRequirementLink {
  id            String   @id @default(cuid())
  tenantId      String
  aiSystemId    String
  requirementId String
  createdAt     DateTime @default(now())

  aiSystem    AiSystem             @relation(fields: [aiSystemId, tenantId], references: [id, tenantId], onDelete: Cascade)
  requirement FrameworkRequirement @relation(fields: [requirementId], references: [id])
  tenant      Tenant               @relation(fields: [tenantId], references: [id])

  @@unique([aiSystemId, requirementId])
  @@index([tenantId, requirementId])
  @@index([tenantId, aiSystemId])
}
