// ─────────────────────────────────────────────────────────────────
//  GAP-09 — multi-file schema: VENDOR RISK
//
//  Owns:
//    • Vendor + VendorContact
//    • VendorAssessment + VendorAssessmentSection +
//      VendorAssessmentQuestion + VendorAssessmentResponse
//    • VendorAssessmentTemplate + VendorAssessmentTemplateSection
//    • VendorEvidenceLink
//
//  Why a dedicated file: vendor assessments have a separate UI flow,
//  a distinct retention model, and a different review cadence from
//  the core compliance domain. Pulling them out keeps `compliance.prisma`
//  focused on the certification surface (controls/risks/evidence)
//  and makes vendor-specific schema changes locally reviewable.
//
//  This file is currently empty. Models will land here in a focused
//  follow-up PR.
// ─────────────────────────────────────────────────────────────────

model Vendor {
  id                  String                 @id @default(cuid())
  tenantId            String
  name                String
  legalName           String?
  websiteUrl          String?
  domain              String?
  country             String?
  description         String?
  ownerUserId         String?
  status              VendorStatus           @default(ONBOARDING)
  criticality         VendorCriticality      @default(MEDIUM)
  inherentRisk        VendorCriticality?
  residualRisk        VendorCriticality?
  nextReviewAt        DateTime?
  contractRenewalAt   DateTime?
  dataAccess          VendorDataAccess?
  isSubprocessor      Boolean                @default(false)
  tags                Json?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  certificationsJson  Json?
  enrichmentLastRunAt DateTime?
  enrichmentStatus    String?
  privacyPolicyUrl    String?
  securityPageUrl     String?
  deletedAt           DateTime?
  deletedByUserId     String?
  retentionUntil      DateTime?
  owner               User?                  @relation("VendorOwner", fields: [ownerUserId], references: [id])
  tenant              Tenant                 @relation(fields: [tenantId], references: [id])
  assessments         VendorAssessment[]
  contacts            VendorContact[]
  documents           VendorDocument[]
  docExtractions      VendorDocExtraction[]
  monitors            VendorMonitor[]
  postureEvents       VendorPostureEvent[]
  evidenceBundles     VendorEvidenceBundle[]
  links               VendorLink[]
  primaryOf           VendorRelationship[]   @relation("PrimaryRelation")
  subprocessorOf      VendorRelationship[]   @relation("SubprocessorRelation")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, criticality])
  @@index([tenantId, nextReviewAt])
  @@index([tenantId, contractRenewalAt])
  @@index([tenantId, deletedAt])
}

model VendorContact {
  id             String   @id @default(cuid())
  tenantId       String
  vendorId       String
  name           String
  email          String?
  title          String?
  phone          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  nameEncrypted  String?
  emailEncrypted String?
  emailHash      String?
  phoneEncrypted String?
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  vendor         Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([tenantId, vendorId])
}

model VendorDocument {
  id               String                @id @default(cuid())
  tenantId         String
  vendorId         String
  type             VendorDocumentType
  fileId           String?
  externalUrl      String?
  title            String?
  // B8 — document folders. A free-text folder label that lets a
  // tenant group documents by their own organisational scheme
  // (e.g. "Contracts/2026", "Onboarding"). Nullable — unfoldered
  // documents continue to render as today. Trimmed + sanitised at
  // the usecase boundary. Indexed for filter + group-by reads.
  folder           String?
  validFrom        DateTime?
  validTo          DateTime?
  notes            String?
  uploadedByUserId String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  tenant           Tenant                @relation(fields: [tenantId], references: [id])
  uploadedBy       User                  @relation("VendorDocUploader", fields: [uploadedByUserId], references: [id])
  vendor           Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  extractions      VendorDocExtraction[]

  @@index([tenantId, vendorId])
  @@index([tenantId, vendorId, type])
  @@index([tenantId, vendorId, folder])
  @@index([tenantId, validTo])
}

model QuestionnaireTemplate {
  id          String                  @id @default(cuid())
  key         String                  @unique
  name        String
  description String?
  version     Int                     @default(1)
  isGlobal    Boolean                 @default(true)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  questions   QuestionnaireQuestion[]
  assessments VendorAssessment[]
}

model QuestionnaireQuestion {
  id             String                   @id @default(cuid())
  templateId     String
  section        String
  prompt         String
  answerType     AnswerType
  optionsJson    Json?
  weight         Float                    @default(1)
  riskPointsJson Json?
  required       Boolean                  @default(true)
  sortOrder      Int                      @default(0)
  template       QuestionnaireTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  answers        VendorAssessmentAnswer[]

  @@index([templateId, section, sortOrder])
}

// ─── Epic G-3 — Vendor Risk Questionnaire Builder ────────────────
//
// Normalized 3-table template structure that supersedes the
// legacy QuestionnaireTemplate / QuestionnaireQuestion above. The
// legacy models are kept for the existing approval-flow callers
// (AssessmentRepository, /vendors/questionnaires/templates routes);
// new G-3 work targets the models below.
//
// Design notes:
//   - Tenant-scoped (legacy was global). Templates can still be
//     marked isGlobal=true to surface a system-shipped catalog,
//     but tenants own their own copies for editing.
//   - (key, version) is the canonical identity tuple. A template
//     edit produces a NEW version row so live assessments stay
//     pinned via VendorAssessment.templateVersionId.
//   - Sections own ordering and weighting; questions live inside
//     sections. The legacy `section: String` field on
//     QuestionnaireQuestion is replaced by a real FK on
//     VendorAssessmentTemplateQuestion.
//   - SCALE questions configure their range and labels via
//     `scaleConfigJson` (e.g. `{ min: 1, max: 5,
//     labels: ['Poor', 'Excellent'] }`).
//   - FILE_UPLOAD questions persist via the Evidence FK on the
//     answer row (see VendorAssessmentAnswer.evidenceId below).

model VendorAssessmentTemplate {
  id                String                             @id @default(cuid())
  tenantId          String
  /// Stable template identifier shared across versions of the
  /// same template. (key, version) together form the unique
  /// identity tuple — see @@unique below.
  key               String
  /// Monotonically increasing version counter. Edits to a
  /// published template create a new (key, version+1) row; the
  /// previous row stays so live assessments remain valid.
  version           Int                                @default(1)
  /// True for the latest version of a key — covers the dashboard's
  /// "show latest" filter without requiring per-tenant aggregation.
  isLatestVersion   Boolean                            @default(true)
  /// Templates start unpublished; only published templates can be
  /// sent to vendors.
  isPublished       Boolean                            @default(false)
  isGlobal          Boolean                            @default(false)
  name              String
  description       String?
  /// Epic G-3 prompt 5 — scoring configuration. Shape:
  ///   { mode: 'SIMPLE_SUM' | 'WEIGHTED_AVERAGE' | 'PASS_FAIL_THRESHOLD',
  ///     threshold?: number,        // PASS_FAIL_THRESHOLD only
  ///     ratingThresholds?: Array<{ rating: 'LOW'|'MEDIUM'|'HIGH'|'CRITICAL',
  ///                                 minScore?: number, maxScore?: number }> }
  /// Null = SIMPLE_SUM with no rating mapping (legacy default).
  scoringConfigJson Json?
  createdByUserId   String?
  createdAt         DateTime                           @default(now())
  updatedAt         DateTime                           @updatedAt
  tenant            Tenant                             @relation(fields: [tenantId], references: [id])
  createdBy         User?                              @relation("AssessmentTemplateCreator", fields: [createdByUserId], references: [id])
  sections          VendorAssessmentTemplateSection[]
  questions         VendorAssessmentTemplateQuestion[]
  assessments       VendorAssessment[]                 @relation("AssessmentByTemplateVersion")

  @@unique([tenantId, key, version])
  @@index([tenantId])
  @@index([tenantId, isLatestVersion])
  @@index([tenantId, isPublished])
}

model VendorAssessmentTemplateSection {
  id          String                             @id @default(cuid())
  tenantId    String
  templateId  String
  /// Ordering within the template; lower values render first.
  sortOrder   Int                                @default(0)
  title       String
  description String?
  /// Per-section weight applied to the section's question scores
  /// during aggregation. Null means equal weighting.
  weight      Float?
  createdAt   DateTime                           @default(now())
  updatedAt   DateTime                           @updatedAt
  tenant      Tenant                             @relation(fields: [tenantId], references: [id])
  template    VendorAssessmentTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  questions   VendorAssessmentTemplateQuestion[]

  @@index([tenantId, templateId, sortOrder])
}

model VendorAssessmentTemplateQuestion {
  id              String                          @id @default(cuid())
  tenantId        String
  templateId      String
  sectionId       String
  /// Ordering within the section; lower values render first.
  sortOrder       Int                             @default(0)
  prompt          String
  answerType      AnswerType
  required        Boolean                         @default(true)
  weight          Float                           @default(1)
  /// SINGLE_SELECT/MULTI_SELECT options + per-option point values.
  /// `[{ "label": "Yes", "value": "yes", "points": 1 }, ...]`
  optionsJson     Json?
  /// SCALE configuration: `{ "min": 1, "max": 5,
  /// "labels": ["Strongly disagree", "Strongly agree"] }`.
  scaleConfigJson Json?
  /// Per-answer-token risk-points map for legacy compatibility
  /// with the existing scoring service (see vendor-scoring.ts).
  riskPointsJson  Json?
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @updatedAt
  tenant          Tenant                          @relation(fields: [tenantId], references: [id])
  template        VendorAssessmentTemplate        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  section         VendorAssessmentTemplateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  answers         VendorAssessmentAnswer[]        @relation("AnswerByTemplateQuestion")

  @@index([tenantId, templateId, sortOrder])
  @@index([tenantId, sectionId, sortOrder])
}

model VendorAssessment {
  id                           String                    @id @default(cuid())
  tenantId                     String
  vendorId                     String
  /// Legacy templateId — points at QuestionnaireTemplate. Existing
  /// approval-flow rows keep using this; new G-3 sends leave it
  /// null and populate `templateVersionId` instead. The column is
  /// nullable so the FK doesn't force every G-3 send to also
  /// allocate a stub QuestionnaireTemplate row.
  templateId                   String?
  /// Epic G-3 — pin the assessment to a specific template version
  /// so subsequent template edits don't mutate live questionnaires.
  /// Nullable for legacy rows that only carry templateId.
  templateVersionId            String?
  status                       AssessmentStatus          @default(DRAFT)
  startedAt                    DateTime                  @default(now())
  submittedAt                  DateTime?
  decidedAt                    DateTime?
  requestedByUserId            String
  decidedByUserId              String?
  score                        Float?
  riskRating                   VendorCriticality?
  notes                        String?
  nextReviewAt                 DateTime?
  /// Lifecycle version counter (matches CISO-Assistant editing_version).
  /// 1 = initial, 2+ = approved. Incremented on each approval cycle.
  lifecycleVersion             Int                       @default(1)
  /// Persisted history of prior assessment snapshots as JSON array.
  /// Matches CISO-Assistant editing_history.
  lifecycleHistoryJson         Json?
  // ─── Epic G-3 send-and-collect lifecycle fields ──────────────
  /// Set when the questionnaire transitions DRAFT → SENT.
  sentAt                       DateTime?
  sentByUserId                 String?
  /// Email address the questionnaire was sent to. Stored separately
  /// from VendorContact so a one-off recipient doesn't pollute the
  /// vendor contact list.
  respondentEmail              String?
  /// External shareable response link uses an opaque token in the
  /// URL; only its hash is stored here. Verifying the link
  /// computes the same hash and looks up the assessment.
  externalAccessTokenHash      String?
  externalAccessTokenExpiresAt DateTime?
  /// Set when the questionnaire transitions SUBMITTED → REVIEWED.
  reviewedAt                   DateTime?
  reviewedByUserId             String?
  reviewerNotes                String?
  /// Set when the assessment is archived (REVIEWED → CLOSED).
  closedAt                     DateTime?
  closedByUserId               String?
  // ─── End G-3 fields ──────────────────────────────────────────
  createdAt                    DateTime                  @default(now())
  updatedAt                    DateTime                  @updatedAt
  decidedBy                    User?                     @relation("AssessmentDecider", fields: [decidedByUserId], references: [id])
  requestedBy                  User                      @relation("AssessmentRequester", fields: [requestedByUserId], references: [id])
  sentBy                       User?                     @relation("AssessmentSender", fields: [sentByUserId], references: [id])
  reviewedBy                   User?                     @relation("AssessmentReviewer", fields: [reviewedByUserId], references: [id])
  closedBy                     User?                     @relation("AssessmentCloser", fields: [closedByUserId], references: [id])
  template                     QuestionnaireTemplate?    @relation(fields: [templateId], references: [id])
  templateVersion              VendorAssessmentTemplate? @relation("AssessmentByTemplateVersion", fields: [templateVersionId], references: [id])
  tenant                       Tenant                    @relation(fields: [tenantId], references: [id])
  vendor                       Vendor                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  answers                      VendorAssessmentAnswer[]

  @@index([tenantId, vendorId])
  @@index([tenantId, status])
  @@index([tenantId, riskRating])
  // Index the external token hash for O(log n) lookup when the
  // external respondent hits the answer URL.
  @@index([externalAccessTokenHash])
}

model VendorAssessmentAnswer {
  id                     String                            @id @default(cuid())
  tenantId               String
  assessmentId           String
  /// Legacy FK — points at QuestionnaireQuestion. Kept for the
  /// existing approval-flow data; new G-3 answers populate
  /// `templateQuestionId` instead.
  questionId             String
  /// Epic G-3 — FK to the new normalized question model.
  /// Nullable for legacy rows that only carry questionId.
  templateQuestionId     String?
  answerJson             Json
  computedPoints         Float                             @default(0)
  // ─── Epic G-3 reviewer override + evidence linkage ───────────
  /// When a reviewer disagrees with the auto-computed score, they
  /// stamp the override here. `computedPoints` stays untouched so
  /// the audit trail records both values.
  reviewerOverridePoints Float?
  reviewerNotes          String?
  /// FILE_UPLOAD answers attach an Evidence row here. Other answer
  /// types may also reference supporting evidence at the
  /// reviewer's discretion.
  evidenceId             String?
  // ─── End G-3 fields ──────────────────────────────────────────
  createdAt              DateTime                          @default(now())
  updatedAt              DateTime                          @updatedAt
  assessment             VendorAssessment                  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question               QuestionnaireQuestion             @relation(fields: [questionId], references: [id])
  templateQuestion       VendorAssessmentTemplateQuestion? @relation("AnswerByTemplateQuestion", fields: [templateQuestionId], references: [id])
  evidence               Evidence?                         @relation("VendorAnswerEvidence", fields: [evidenceId], references: [id])
  tenant                 Tenant                            @relation(fields: [tenantId], references: [id])

  @@unique([assessmentId, questionId])
  @@index([tenantId, assessmentId])
  @@index([tenantId, templateQuestionId])
}

/// AI-assisted vendor-document extraction (SOC 2 / ISO cert / pen-test).
/// The propose-not-commit SESSION: a VendorDocument is parsed to text,
/// sanitised, AI-extracted into structured fields, and each mapped question
/// becomes a VendorAnswerProposal a human reviews before it lands as a real
/// VendorAssessmentAnswer. Mirrors RiskSuggestionSession/Item. Tenant-scoped
/// (RLS + indexes). The raw document text is sanitised before the AI call
/// and NOT persisted — only the structured, Zod-validated extraction.
model VendorDocExtraction {
  id               String    @id @default(cuid())
  tenantId         String
  vendorId         String
  documentId       String
  /// Optional target assessment being pre-filled.
  assessmentId     String?
  /// PENDING | EXTRACTED | FAILED.
  status           String    @default("PENDING")
  provider         String    @default("stub")
  modelName        String?
  /// SOC2_TYPE2 | SOC2_TYPE1 | ISO27001 | PENTEST | OTHER (from the AI).
  reportType       String?
  auditPeriodStart DateTime?
  auditPeriodEnd   DateTime?
  scope            String?
  auditor          String?
  /// The full Zod-validated AI extraction (controls + results + exceptions).
  /// Every proposal's citation traces back into this payload.
  extractionJson   Json?
  errorMessage     String?
  createdByUserId  String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant    Tenant                 @relation(fields: [tenantId], references: [id])
  vendor    Vendor                 @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  document  VendorDocument         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy User                   @relation("VendorDocExtractionCreator", fields: [createdByUserId], references: [id])
  proposals VendorAnswerProposal[]

  @@index([tenantId, vendorId])
  @@index([tenantId, status])
  @@index([tenantId, documentId])
}

/// A PROPOSED vendor-assessment answer derived from a document extraction.
/// PENDING until a human approves (→ ACCEPTED, materialises a
/// VendorAssessmentAnswer via `createdAnswerId`) or rejects. NEVER scored
/// until approved — the propose-not-commit contract. Carries the source
/// citation so a reviewer verifies the AI did not hallucinate.
model VendorAnswerProposal {
  id                 String   @id @default(cuid())
  tenantId           String
  extractionId       String
  assessmentId       String?
  questionId         String?
  templateQuestionId String?
  /// Proposed payload — same shape a VendorAssessmentAnswer.answerJson takes.
  proposedAnswerJson Json
  /// high | medium | low — AI confidence in the document→question mapping.
  confidence         String   @default("medium")
  /// e.g. "SOC 2 CC6.1, no exceptions, period 2025-06..2026-05".
  sourceCitation     String
  /// PENDING | ACCEPTED | REJECTED.
  status             String   @default("PENDING")
  /// The VendorAssessmentAnswer created when this proposal is approved.
  createdAnswerId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant     Tenant              @relation(fields: [tenantId], references: [id])
  extraction VendorDocExtraction @relation(fields: [extractionId], references: [id], onDelete: Cascade)

  @@index([tenantId, extractionId])
  @@index([tenantId, status])
}

/// Continuous-monitoring configuration + rolling posture state for a vendor.
/// One row per vendor (the "monitor"). A point-in-time assessment goes stale
/// the moment it's signed; this row is the always-on companion — which checks
/// are enabled, when the monitor last ran, and the latest cached signal state
/// (breach date, TLS/security-header grade, attestation expiry). The
/// per-signal history lives in VendorPostureEvent; this is the current-state
/// summary the dashboard + vendor detail read.
model VendorMonitor {
  id                   String    @id @default(cuid())
  tenantId             String
  vendorId             String
  /// Master switch — a disabled monitor is skipped by the sweep.
  enabled              Boolean   @default(true)
  /// Which signal families this vendor opts into.
  checkAttestation     Boolean   @default(true)
  checkBreach          Boolean   @default(true)
  checkTls             Boolean   @default(true)
  /// Opt-in: a breach / expired attestation materialises a vendor Finding.
  /// Off by default — posture events + owner notifications always fire, but a
  /// scored Finding is a deliberate escalation the tenant turns on.
  materializeFindings  Boolean   @default(false)
  /// Rolling state — refreshed on every monitor run.
  lastRunAt            DateTime?
  lastRunStatus        String? // OK | ERROR
  lastError            String?
  /// Latest breach observation (null = never seen in a breach feed).
  breachLastSeenAt     DateTime?
  breachCount          Int       @default(0)
  /// Latest public TLS / security-header grade (A..F) + when graded.
  tlsGrade             String?
  tlsCheckedAt         DateTime?
  /// Cached earliest attestation expiry across the vendor's parsed reports.
  attestationExpiresAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([tenantId, vendorId])
  @@index([tenantId, enabled])
  @@index([tenantId, lastRunAt])
}

/// Append-only posture timeline — the continuous-assurance record for a
/// vendor, not just the latest questionnaire. Each monitored signal (breach
/// hit, attestation expiry, TLS grade change, triggered reassessment, status
/// change) lands one row. `fingerprint` makes the recurring signals
/// idempotent — the monitor re-running on the same breach / same expired
/// report never double-writes. `createdFindingId` links the event to the
/// Finding it materialised (when materializeFindings is on).
model VendorPostureEvent {
  id               String   @id @default(cuid())
  tenantId         String
  vendorId         String
  /// BREACH_DETECTED | ATTESTATION_EXPIRED | ATTESTATION_EXPIRING |
  /// TLS_GRADE | REASSESSMENT_TRIGGERED | MONITOR_RUN | STATUS_CHANGED.
  eventType        String
  /// INFO | LOW | MEDIUM | HIGH | CRITICAL.
  severity         String   @default("INFO")
  /// Provider / origin of the signal: 'stub' | 'hibp-domain' | 'header-grade'
  /// | 'internal'.
  source           String   @default("internal")
  /// Human-readable one-line summary rendered on the timeline.
  summary          String
  /// Idempotency key — `${eventType}:${vendorId}:${stableSignalKey}`.
  fingerprint      String
  detailsJson      Json?
  /// The Finding materialised from this event, if any.
  createdFindingId String?
  occurredAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([tenantId, fingerprint])
  @@index([tenantId, vendorId, occurredAt])
  @@index([tenantId, eventType])
}

model VendorLink {
  id         String               @id @default(cuid())
  tenantId   String
  vendorId   String
  entityType VendorLinkEntityType
  entityId   String
  relation   VendorLinkRelation   @default(RELATED)
  createdAt  DateTime             @default(now())
  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  vendor     Vendor               @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([tenantId, vendorId, entityType, entityId])
  @@index([tenantId, vendorId])
}

model VendorEvidenceBundle {
  id              String                     @id @default(cuid())
  tenantId        String
  vendorId        String
  name            String
  description     String?
  frozenAt        DateTime?
  createdByUserId String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  createdBy       User?                      @relation("EvidenceBundleCreator", fields: [createdByUserId], references: [id])
  tenant          Tenant                     @relation(fields: [tenantId], references: [id])
  vendor          Vendor                     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  items           VendorEvidenceBundleItem[]

  @@index([tenantId, vendorId])
}

model VendorEvidenceBundleItem {
  id           String               @id @default(cuid())
  bundleId     String
  tenantId     String
  entityType   String
  entityId     String
  snapshotJson Json?
  createdAt    DateTime             @default(now())
  bundle       VendorEvidenceBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  tenant       Tenant               @relation(fields: [tenantId], references: [id])

  @@unique([bundleId, entityType, entityId])
  @@index([tenantId, bundleId])
}

model VendorRelationship {
  id                   String   @id @default(cuid())
  tenantId             String
  primaryVendorId      String
  subprocessorVendorId String
  purpose              String?
  dataTypes            String?
  country              String?
  createdAt            DateTime @default(now())
  primary              Vendor   @relation("PrimaryRelation", fields: [primaryVendorId], references: [id], onDelete: Cascade)
  subprocessor         Vendor   @relation("SubprocessorRelation", fields: [subprocessorVendorId], references: [id], onDelete: Cascade)
  tenant               Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, primaryVendorId, subprocessorVendorId])
  @@index([tenantId, primaryVendorId])
  @@index([tenantId, subprocessorVendorId])
}
