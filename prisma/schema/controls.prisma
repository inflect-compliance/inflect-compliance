// controls.prisma — Control + everything that FKs to it (coverage joins, tasks, evidence link, templates, tests, exceptions).
// Split from compliance.prisma (2026-07-10) — pure reorg, no datamodel change.
// Enums live in enums.prisma; relations resolve across the schema folder.

/// Per-tenant monotonic counter for minting `CTL-N` custom-control
/// keys (the framework-installed controls keep their canonical
/// annexId / supplied code). Only the `createControl` path that
/// lacks an explicit code consumes this sequence; framework imports
/// supply their own code/annexId and bypass the counter entirely.
model ControlKeySequence {
  tenantId  String @id
  lastValue Int    @default(0)
}

model Control {
  id                           String                   @id @default(cuid())
  tenantId                     String?
  code                         String?
  annexId                      String?                  @unique
  name                         String
  // Internal-controls import: objective (Overview shows this as "Objective"),
  // success criteria (Overview "Success Criteria"), and testing/audit
  // methodology (Tests tab, above Test plans).
  objective                    String?
  successCriteria              String?
  testingMethodology           String?
  category                     String?
  status                       ControlStatus            @default(NOT_STARTED)
  effectiveness                Int?
  /// RQ3-8 — annual cost (operate + maintain) in the tenant's
  /// currency. Float matches the existing money-field pattern
  /// (sleAmount, aroAmount, fairAle on Risk). Nullable until an
  /// owner prices it — the ROI surface returns an honest null with
  /// a typed `NO_COST` reason rather than fabricating a number.
  annualCost                   Float?
  lastTested                   DateTime?
  reviewCadence                ReviewCadence?
  isCustom                     Boolean                  @default(false)
  ownerUserId                  String?
  createdByUserId              String?
  frequency                    ControlFrequency?
  nextDueAt                    DateTime?
  evidenceSource               EvidenceSourceType?
  automationKey                String?
  automationType               ControlAutomationType?
  mitigationType               ControlMitigationType?
  applicability                Applicability            @default(APPLICABLE)
  applicabilityJustification   String?
  applicabilityDecidedByUserId String?
  applicabilityDecidedAt       DateTime?
  createdAt                    DateTime                 @default(now())
  updatedAt                    DateTime                 @updatedAt
  deletedAt                    DateTime?
  deletedByUserId              String?
  retentionUntil               DateTime?
  applicabilityDecidedBy       User?                    @relation("ControlApplicabilityDecider", fields: [applicabilityDecidedByUserId], references: [id])
  createdBy                    User?                    @relation("ControlCreator", fields: [createdByUserId], references: [id])
  owner                        User?                    @relation("ControlOwner", fields: [ownerUserId], references: [id])
  tenant                       Tenant?                  @relation(fields: [tenantId], references: [id])
  assets                       ControlAsset[]
  contributors                 ControlContributor[]
  evidenceLinks                ControlEvidenceLink[]
  requirementLinks             ControlRequirementLink[]
  controlTasks                 ControlTask[]
  testPlans                    ControlTestPlan[]
  testRuns                     ControlTestRun[]
  evidence                     Evidence[]
  frameworkMappings            FrameworkMapping[]
  findings                     Finding[]                @relation("FindingControl")
  compensatingForFindings      Finding[]                @relation("FindingCompensatingControl")
  integrationExecutions        IntegrationExecution[]
  policyLinks                  PolicyControlLink[]
  risks                        RiskControl[]
  tasks                        Task[]
  // Epic G-5 — control exception register. Two reverse relations:
  // (a) exceptions registered against THIS control,
  // (b) exceptions that name THIS control as their compensating
  //     control (i.e. "we mitigate the gap by doing this").
  exceptions                   ControlException[]       @relation("ControlExceptionAffected")
  compensatingForExceptions    ControlException[]       @relation("ControlExceptionCompensating")

  /// Composite parent key — supports the
  /// `ControlException.(controlId, tenantId) → Control.(id, tenantId)`
  /// FK shape, so a cross-tenant exception link is impossible at
  /// the DB level. Same denorm-tenantId Phase-2 pattern used by
  /// AuditChecklistItem → Audit.
  @@unique([id, tenantId])
  @@index([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, applicability])
  @@index([ownerUserId])
  @@index([nextDueAt])
  @@index([tenantId, deletedAt])
  // GAP-perf — supports `ownerUserId` filter in tenant scope.
  // `[ownerUserId]` alone exists but isn't tenant-prefixed, so
  // Postgres can't selectively scan one tenant's slice for a
  // specific owner without an additional filter pass.
  @@index([tenantId, ownerUserId])
  // GAP-perf — supports `category` filter (free-text exact match).
  @@index([tenantId, category])
}

model RiskControl {
  id              String   @id @default(cuid())
  riskId          String
  controlId       String
  tenantId        String
  rationale       String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  control         Control  @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy       User?    @relation("RiskControlCreator", fields: [createdByUserId], references: [id])
  risk            Risk     @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, riskId, controlId])
  @@index([tenantId, controlId])
  @@index([tenantId])
}

model ControlAsset {
  id              String       @id @default(cuid())
  controlId       String
  assetId         String
  tenantId        String
  coverageType    CoverageType @default(UNKNOWN)
  rationale       String?
  createdByUserId String?
  createdAt       DateTime     @default(now())
  asset           Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  control         Control      @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy       User?        @relation("ControlAssetCreator", fields: [createdByUserId], references: [id])
  tenant          Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, controlId, assetId])
  @@index([tenantId, assetId])
  @@index([tenantId])
}

model ControlContributor {
  id        String   @id @default(cuid())
  tenantId  String
  controlId String
  userId    String
  createdAt DateTime @default(now())
  control   Control  @relation(fields: [controlId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([controlId, userId])
  @@index([tenantId])
}

model ControlTask {
  id             String            @id @default(cuid())
  tenantId       String
  controlId      String
  title          String
  description    String?
  status         ControlTaskStatus @default(OPEN)
  assigneeUserId String?
  dueAt          DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  assignee       User?             @relation("ControlTaskAssignee", fields: [assigneeUserId], references: [id])
  control        Control           @relation(fields: [controlId], references: [id], onDelete: Cascade)
  tenant         Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([controlId])
  @@index([status])
  @@index([dueAt])
  // GAP-perf — backs the dashboard "overdue tasks" query
  // (status IN ('OPEN','IN_PROGRESS') AND dueAt < now()) and the
  // refactored `runConsistencyCheck` overdue lookup. The
  // single-column `[status]` and `[dueAt]` indexes can't satisfy
  // the combined predicate efficiently.
  @@index([tenantId, status, dueAt])
}

model ControlEvidenceLink {
  id                  String           @id @default(cuid())
  tenantId            String
  controlId           String
  kind                EvidenceLinkKind
  fileId              String?
  url                 String?
  integrationResultId String?
  /// BIA-as-evidence (kind BIA) — the continuity control (NIS2
  /// Art.21(2)(c)) links a Business Impact Analysis as the operational
  /// artifact that satisfies the requirement.
  biaId               String?
  note                String?
  createdByUserId     String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  control             Control          @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy           User?            @relation("ControlEvidenceCreator", fields: [createdByUserId], references: [id])
  bia                 BusinessImpactAnalysis? @relation(fields: [biaId], references: [id], onDelete: Cascade)
  tenant              Tenant           @relation(fields: [tenantId], references: [id])

  @@unique([controlId, kind, fileId])
  @@unique([controlId, kind, url])
  @@unique([controlId, kind, biaId])
  @@index([tenantId])
  @@index([controlId])
  @@index([tenantId, biaId])
}

model ControlTemplate {
  id               String                           @id @default(cuid())
  code             String                           @unique
  title            String
  description      String?
  category         String?
  defaultFrequency ControlFrequency?
  defaultOwnerHint String?
  // Internal-controls import (customer GRC export): the control's objective
  // (what it achieves), success criteria (what "passing" looks like), and
  // testing/audit methodology. Copied onto the Control on install.
  objective          String?
  successCriteria    String?
  testingMethodology String?
  // Pipe-separated policy names this control relates to (from the source
  // export); resolved to PolicyControlLink per-tenant on install where a
  // matching policy exists. Framework mapping deferred (source Tags empty).
  relatedPolicies  String?
  isGlobal         Boolean                          @default(true)
  createdAt        DateTime                         @default(now())
  requirementLinks ControlTemplateRequirementLink[]
  tasks            ControlTemplateTask[]
  packLinks        PackTemplateLink[]
}

model ControlTemplateTask {
  id          String          @id @default(cuid())
  templateId  String
  title       String
  description String?
  template    ControlTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ControlTemplateRequirementLink {
  id            String               @id @default(cuid())
  templateId    String
  requirementId String
  requirement   FrameworkRequirement @relation(fields: [requirementId], references: [id])
  template      ControlTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, requirementId])
}

model ControlRequirementLink {
  id            String               @id @default(cuid())
  tenantId      String
  controlId     String
  requirementId String
  createdAt     DateTime             @default(now())
  control       Control              @relation(fields: [controlId], references: [id], onDelete: Cascade)
  requirement   FrameworkRequirement @relation(fields: [requirementId], references: [id])
  tenant        Tenant               @relation(fields: [tenantId], references: [id])

  @@unique([controlId, requirementId])
  @@index([tenantId, requirementId])
}

model ControlTestPlan {
  id                 String            @id @default(cuid())
  tenantId           String
  controlId          String
  name               String
  description        String?
  method             TestMethod        @default(MANUAL)
  frequency          ControlFrequency  @default(AD_HOC)
  nextDueAt          DateTime?
  ownerUserId        String?
  expectedEvidence   Json?
  status             TestPlanStatus    @default(ACTIVE)
  // Epic G-2 — automated scheduled execution. `nextDueAt` stays the
  // soft due-by indicator (UI overdue badge, deadline-monitor digest);
  // `nextRunAt` is the hard scheduler trigger. They diverge for plans
  // where humans review monthly but the script runs daily.
  automationType     AutomationType    @default(MANUAL)
  schedule           String?
  scheduleTimezone   String?
  nextRunAt          DateTime?
  lastScheduledRunAt DateTime?
  automationConfig   Json?
  createdByUserId    String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  /// Soft-delete (bulk-delete support) — enrolled in SOFT_DELETE_MODELS.
  deletedAt          DateTime?
  deletedByUserId    String?
  control            Control           @relation(fields: [controlId], references: [id])
  createdBy          User              @relation("TestPlanCreator", fields: [createdByUserId], references: [id])
  owner              User?             @relation("TestPlanOwner", fields: [ownerUserId], references: [id])
  tenant             Tenant            @relation(fields: [tenantId], references: [id])
  runs               ControlTestRun[]
  steps              ControlTestStep[]

  @@index([tenantId])
  @@index([tenantId, controlId])
  @@index([tenantId, nextDueAt])
  @@index([tenantId, status])
  @@index([tenantId, nextRunAt])
  @@index([tenantId, automationType, status])
  @@index([tenantId, deletedAt])
}

model ControlTestRun {
  id               String                    @id @default(cuid())
  tenantId         String
  controlId        String
  testPlanId       String
  status           TestRunStatus             @default(PLANNED)
  result           TestResult?
  executedAt       DateTime?
  executedByUserId String?
  notes            String?
  findingSummary   String?
  createdByUserId  String
  requestId        String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  evidence         ControlTestEvidenceLink[]
  control          Control                   @relation(fields: [controlId], references: [id])
  createdBy        User                      @relation("TestRunCreator", fields: [createdByUserId], references: [id])
  executedBy       User?                     @relation("TestRunExecutor", fields: [executedByUserId], references: [id])
  tenant           Tenant                    @relation(fields: [tenantId], references: [id])
  // Cascade so the data-lifecycle hard-purge of a soft-deleted test plan
  // (90d) erases its runs too (runs' evidence links already cascade).
  testPlan         ControlTestPlan           @relation(fields: [testPlanId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, testPlanId])
  @@index([tenantId, result])
  @@index([tenantId, executedAt])
  @@index([tenantId, controlId])
}

model ControlTestEvidenceLink {
  id                  String           @id @default(cuid())
  tenantId            String
  testRunId           String
  kind                TestEvidenceKind
  fileId              String?
  evidenceId          String?
  url                 String?
  integrationResultId String?
  note                String?
  createdByUserId     String
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  sha256Hash          String?
  createdBy           User             @relation("TestEvidenceCreator", fields: [createdByUserId], references: [id])
  evidence            Evidence?        @relation(fields: [evidenceId], references: [id])
  tenant              Tenant           @relation(fields: [tenantId], references: [id])
  testRun             ControlTestRun   @relation(fields: [testRunId], references: [id], onDelete: Cascade)

  @@unique([testRunId, kind, evidenceId])
  @@unique([testRunId, kind, fileId])
  @@index([tenantId])
  @@index([tenantId, testRunId])
}

model ControlTestStep {
  id             String          @id @default(cuid())
  tenantId       String
  testPlanId     String
  sortOrder      Int             @default(0)
  instruction    String
  expectedOutput String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  testPlan       ControlTestPlan @relation(fields: [testPlanId], references: [id], onDelete: Cascade)

  @@index([tenantId, testPlanId])
}

model ControlException {
  id                    String                 @id @default(cuid())
  tenantId              String
  /// FK target — the control that cannot be implemented as designed.
  controlId             String
  status                ControlExceptionStatus @default(REQUESTED)
  /// Required free-text rationale for the exception. Surfaced
  /// verbatim in audit packs; encrypted at rest via the manifest.
  justification         String
  /// Optional FK to the control that mitigates this exception
  /// ("we don't enforce X because we instead do Y via control Z").
  compensatingControlId String?
  /// User who carries the risk-acceptance authority. Required at
  /// creation — auditors want to know up-front who would sign off.
  riskAcceptedByUserId  String
  /// Set when status transitions to APPROVED.
  approvedAt            DateTime?
  approvedByUserId      String?
  /// Set when status transitions to REJECTED.
  rejectedAt            DateTime?
  rejectedByUserId      String?
  rejectionReason       String?
  /// Required deadline at which the exception expires. The expiry
  /// monitor reminds approvers in the 30 → 7 → 1 day windows.
  /// Nullable for REQUESTED rows that haven't been formally
  /// scoped yet; required (CHECK) once status moves to APPROVED.
  expiresAt             DateTime?
  /// Renewal lineage — points at the prior row this one supersedes.
  /// Self-referential composite FK (renewedFromId, tenantId) →
  /// ControlException(id, tenantId) so renewals can never reference
  /// a prior row in another tenant.
  renewedFromId         String?
  createdByUserId       String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  /// Soft-delete columns — same convention as AuditCycle.
  deletedAt             DateTime?
  deletedByUserId       String?

  tenant              Tenant             @relation(fields: [tenantId], references: [id])
  control             Control            @relation("ControlExceptionAffected", fields: [controlId, tenantId], references: [id, tenantId])
  compensatingControl Control?           @relation("ControlExceptionCompensating", fields: [compensatingControlId, tenantId], references: [id, tenantId])
  renewedFrom         ControlException?  @relation("ControlExceptionRenewalChain", fields: [renewedFromId, tenantId], references: [id, tenantId])
  renewals            ControlException[] @relation("ControlExceptionRenewalChain")
  createdBy           User               @relation("ControlExceptionCreatedBy", fields: [createdByUserId], references: [id])
  riskAcceptedBy      User               @relation("ControlExceptionRiskAcceptedBy", fields: [riskAcceptedByUserId], references: [id])
  approvedBy          User?              @relation("ControlExceptionApprovedBy", fields: [approvedByUserId], references: [id])
  rejectedBy          User?              @relation("ControlExceptionRejectedBy", fields: [rejectedByUserId], references: [id])
  deletedBy           User?              @relation("ControlExceptionDeletedBy", fields: [deletedByUserId], references: [id])

  /// Composite parent key. Used by the self-referential FK above
  /// AND by any future child entity (audit packs, approval logs).
  @@unique([id, tenantId])
  @@index([tenantId, status])
  @@index([tenantId, expiresAt])
  @@index([tenantId, controlId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, createdAt])
  @@index([renewedFromId])
}
