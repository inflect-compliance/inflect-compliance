// trust-center.prisma — Public trust-center projection + gated-document access flow.
// Split from compliance.prisma (2026-07-10) — pure reorg, no datamodel change.
// Enums live in enums.prisma; relations resolve across the schema folder.

/// Public Trust Center — an EXPLICIT, tenant-curated projection published to
/// the open internet at `/trust/<slug>`. SECURITY-CRITICAL: this is the only
/// intentionally-public surface in an otherwise auth+RLS-locked app. The
/// public page reads ONLY this row (never Risk/Control/Evidence/Finding/…),
/// renders ONLY the fields the tenant explicitly composed, and is OFF by
/// default. Nothing here is auto-derived from live posture — the tenant
/// curates every claim. Free text is sanitised on write (public XSS surface).
/// RLS-covered (carries tenantId) for the authenticated compose path; the
/// public read goes through the system role by `slug` (single curated row).
model TrustCenter {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Public URL segment: /trust/<slug>. Globally unique.
  slug                String   @unique
  /// OFF by default — a tenant has no public page until they explicitly enable.
  enabled             Boolean  @default(false)
  /// Drives X-Robots-Tag — some tenants want the page indexed for marketing,
  /// some want it noindex. OFF (noindex) by default.
  indexable           Boolean  @default(false)
  displayName         String
  tagline             String?
  /// Explicit allowlist of frameworks to show + the status label the TENANT
  /// sets (NOT derived from coverage %, which could leak a low number).
  /// Shape: [{ key, statusLabel, badge }]. Sanitised on write.
  publishedFrameworks Json     @default("[]")
  /// Curated prose the tenant writes — NOT a live control count. Sanitised.
  postureSummary      String?
  /// Links to tenant-chosen, already-public artifacts (whitepaper, SOC2 cover
  /// letter). NEVER auto-exposed evidence. Shape: [{ label, url }]. Sanitised.
  publishedDocuments  Json     @default("[]")
  securityContact     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  /// Audit pointer — who last toggled publish. Plain column (no relation) to
  /// keep the public read graph minimal.
  publishedByUserId   String?
  /// PR-8 — email domains auto-approved for gated-document access (["acme.com"]).
  accessDomainAllowlist Json  @default("[]")
  /// PR-8 — require an NDA click-through before a gated download is granted.
  ndaRequired         Boolean @default(false)
  documents           TrustCenterDocument[]

  @@index([tenantId])
}

/// PR-8 — a document published on the trust center. `gated=true` requires an
/// approved TrustCenterAccessRequest + a signed, expiring, single-use download
/// token; `gated=false` is freely downloadable.
model TrustCenterDocument {
  id            String   @id @default(cuid())
  tenantId      String
  trustCenterId String
  label         String
  fileRecordId  String
  gated         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  trustCenter TrustCenter @relation(fields: [trustCenterId], references: [id], onDelete: Cascade)
  requests    TrustCenterAccessRequest[]

  @@index([tenantId])
  @@index([tenantId, trustCenterId])
}

/// PR-8 — a visitor's request to access a gated document. Auto-approved when
/// the requester email domain is in the tenant's allowlist; otherwise stays
/// REQUESTED for manual approval. On approval a hashed, expiring, single-use
/// download token is issued.
model TrustCenterAccessRequest {
  id                String                   @id @default(cuid())
  tenantId          String
  documentId        String
  requesterName     String
  requesterEmail    String
  company           String?
  status            TrustCenterAccessStatus  @default(REQUESTED)
  ndaSignedAt       DateTime?
  grantedAt         DateTime?
  expiresAt         DateTime?
  /// SHA-256 of the single-use download token (plaintext returned once).
  downloadTokenHash String?                  @unique
  downloadedAt      DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  tenant   Tenant              @relation(fields: [tenantId], references: [id])
  document TrustCenterDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, documentId])
}
