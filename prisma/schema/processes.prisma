// ─────────────────────────────────────────────────────────────────
//  Roadmap-26 PR-A — Process Maps (persisted xyflow canvases).
//
//  Four tables — a `ProcessMap` (metadata) owns a graph of
//  `ProcessNode`s and `ProcessEdge`s. Each edge can carry zero or
//  more `ProcessEdgeControl` rows (the "control sits on the line
//  between two steps" idea documented in the R25 brief; refined in
//  R26-PR-D with first-class semantics).
//
//  Why a new file (not under compliance.prisma): the graph models
//  live entirely outside the compliance domain (no FK into Control /
//  Risk / Asset *today*). They are visual-documentation artefacts.
//  PR-D adds the optional `controlId` FK to wire `ProcessEdgeControl`
//  to a real Control row when the link is meaningful — but the
//  TABLE itself never depends on a control existing.
//
//  Why nodes + edges live as separate tables (not as a single
//  `graphJson Json` on ProcessMap):
//    • Indexed queries — "find all maps that use control X" or
//      "find every map that references this risk" need a real row,
//      not a blob.
//    • Future versioning — PR-B/D evolve the per-type payload; a
//      single graphJson would couple every migration to every
//      consumer. Per-row tables let the JSON `dataJson` slot stay
//      forward-compatible.
//    • Edge controls already need their own table for the future
//      FK to Control; the rest of the graph follows the same
//      shape for consistency.
//
//  Tenant isolation — direct-scoped RLS (Class A), three policies
//  per table (tenant_isolation USING + tenant_isolation_insert
//  WITH CHECK + superuser_bypass) plus FORCE ROW LEVEL SECURITY.
//  Migration `20260519_r26_pra_process_maps` carries the policies.
//
//  Composite parent FK shape — every child carries `(parentId,
//  tenantId)` as the FK reference. Cross-tenant child writes are
//  structurally impossible because the FK target unique key is
//  `(id, tenantId)` on the parent. Mirrors the
//  `RiskTreatmentPlan → Risk` pattern from Epic G-7.
// ─────────────────────────────────────────────────────────────────

model ProcessMap {
  id              String           @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  status          ProcessMapStatus @default(DRAFT)
  /// VR-2 — DOCUMENT (process maps, existing) vs AUTOMATION (visual rule
  /// editor). Gates the palette, inspector, edge kinds, and toolbar.
  canvasMode      ProcessCanvasMode @default(DOCUMENT)
  createdByUserId String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  // Incremented on every successful save. PR-A's repo layer
  // bumps it on every `replaceGraph`. Frontend reads it back for
  // future optimistic-concurrency hints (e.g. "the canvas was
  // edited by someone else — reload?"). NOT yet enforced as a
  // hard optimistic lock at the repo layer — that is a forward
  // affordance the column reserves.
  version         Int              @default(1)
  // Soft-delete slot — list queries filter on `deletedAt IS NULL`.
  // Hard-delete is available via the DELETE endpoint when the
  // caller has the canAdmin permission.
  deletedAt       DateTime?
  deletedByUserId String?

  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  createdBy User          @relation("ProcessMapCreatedBy", fields: [createdByUserId], references: [id])
  deletedBy User?         @relation("ProcessMapDeletedBy", fields: [deletedByUserId], references: [id])
  nodes     ProcessNode[]
  edges     ProcessEdge[]
  snapshots ProcessMapSnapshot[]

  @@unique([id, tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, updatedAt])
}

// ─────────────────────────────────────────────────────────────────
//  Epic P5-PR-A — ProcessMapSnapshot.
//
//  Stores the full graph JSON for every committed version of a
//  process map so the version-history sidebar can list snapshots
//  + future P5-PR-B can render any earlier version + diff between
//  two snapshots. Per-version one row keyed on (processMapId,
//  version); the unique constraint guarantees no duplicates if a
//  retry of `replaceGraph` ever fires.
//
//  Tenant isolation: direct-scoped RLS (Class A) added in the
//  paired migration. The (id, tenantId) composite + cascading
//  FK to ProcessMap keep cross-tenant references structurally
//  impossible.
//
//  `graphJson` carries the same shape the canvas sends on save:
//    { version, nodes: [...], edges: [...] }
//  The route layer never decodes the inner shape; the client
//  re-parses on view-version + diff renders.
// ─────────────────────────────────────────────────────────────────
model ProcessMapSnapshot {
  id              String   @id @default(cuid())
  tenantId        String
  processMapId    String
  version         Int
  graphJson       Json
  createdAt       DateTime @default(now())
  createdByUserId String

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  processMap ProcessMap @relation(fields: [processMapId, tenantId], references: [id, tenantId], onDelete: Cascade)
  createdBy  User       @relation("ProcessMapSnapshotCreatedBy", fields: [createdByUserId], references: [id])

  @@unique([processMapId, version])
  @@index([tenantId, processMapId, version])
  @@index([tenantId, createdAt])
}

model ProcessNode {
  id           String   @id @default(cuid())
  tenantId     String
  processMapId String
  // Client-stable id (e.g. "node-1") — distinct from the row's
  // cuid `id`. Persists across saves so the frontend can keep
  // xyflow selections + camera focus stable when the user clicks
  // Save. Unique per process map.
  nodeKey      String
  // Canonical node-type key. PR-A only ships "processStep" (the
  // only node type R25 introduced). PR-B widens this to the full
  // taxonomy.
  nodeType     String
  label        String
  subtitle     String?
  posX         Float
  posY         Float
  // R30 — optional parent reference for the "group" kind. References
  // the parent's per-map `nodeKey` (the frontend-stable id), NOT the
  // row's cuid `id`. The rest of the graph (ProcessEdge.sourceKey /
  // targetKey) already references node KEYS — keeping `parentNodeKey`
  // on the same kind lets the frontend round-trip xyflow's `parentId`
  // (which references the xyflow node id, which IS our nodeKey)
  // without translation.
  //
  // No FK constraint: the parent must exist in the SAME processMap
  // row-set; `replaceGraph` validates this structurally. Migration
  // adds a partial index on `(processMapId, parentNodeKey)` for the
  // "find all children of this group" query.
  parentNodeKey String?
  // Forward-compatible per-type payload. PR-B uses this to carry
  // typed metadata for richer node kinds (control owner, risk
  // severity, asset criticality) without further migrations.
  dataJson     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  processMap ProcessMap @relation(fields: [processMapId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([processMapId, nodeKey])
  @@index([tenantId, processMapId])
}

model ProcessEdge {
  id            String   @id @default(cuid())
  tenantId      String
  processMapId  String
  // Client-stable edge id. Same rationale as ProcessNode.nodeKey.
  edgeKey       String
  // References the source + target *node keys* (not row ids), so
  // a save → reload round-trip preserves the graph even if the
  // server re-mints row ids for any reason. The repo layer
  // ensures both keys exist among the map's nodes at save time.
  sourceKey     String
  targetKey     String
  // "flow" is the default. PR-D introduces governance-aware edge
  // kinds (e.g. "data-flow" vs "approval-flow") via this column.
  edgeKind      String   @default("flow")
  labelOverride String?
  dataJson      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  processMap ProcessMap           @relation(fields: [processMapId, tenantId], references: [id, tenantId], onDelete: Cascade)
  controls   ProcessEdgeControl[]

  @@unique([processMapId, edgeKey])
  @@unique([id, tenantId])
  @@index([tenantId, processMapId])
}

model ProcessEdgeControl {
  id           String   @id @default(cuid())
  tenantId     String
  // Denormalised from the parent ProcessMap so RLS can scope every
  // table on the same column shape. The composite FK to the parent
  // ProcessEdge already binds (edgeId, tenantId) — denormalising
  // processMapId in addition keeps "all controls in map X" a
  // direct indexed query.
  processMapId String
  edgeId       String
  // Client-stable id, scoped to the edge.
  controlKey   String
  label        String
  // Future FK to the real Control row. Nullable today so the
  // PR-A scope can save edge-mounted controls without forcing
  // the user to pick a Control first; PR-D wires the picker UI
  // and may FLIP this to NOT NULL once the migration is safe.
  controlId    String?
  dataJson     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant      @relation(fields: [tenantId], references: [id])
  edge   ProcessEdge @relation(fields: [edgeId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([edgeId, controlKey])
  @@index([tenantId, processMapId])
  @@index([tenantId, controlId])
}
