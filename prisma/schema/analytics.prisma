// analytics.prisma — Tenant-wide denormalised dashboard snapshots (cross-domain KPI aggregates).
// Split from compliance.prisma (2026-07-10) — pure reorg, no datamodel change.
// Enums live in enums.prisma; relations resolve across the schema folder.

/// Daily compliance KPI snapshot for trend reporting.
/// One row per tenant per day. Idempotent via @@unique([tenantId, snapshotDate]).
/// Stores denormalized KPI values computed by the daily snapshot job.
model ComplianceSnapshot {
  id           String   @id @default(cuid())
  tenantId     String
  /// Calendar date (midnight UTC) — NOT a full timestamp.
  /// Enables clean GROUP BY / ORDER BY for trend queries.
  snapshotDate DateTime @db.Date

  // ── Control Coverage ──
  controlsTotal       Int @default(0)
  controlsApplicable  Int @default(0)
  controlsImplemented Int @default(0)
  controlsInProgress  Int @default(0)
  controlsNotStarted  Int @default(0)
  /// Cached coverage % × 10 (e.g. 753 = 75.3%). Int avoids float precision issues.
  controlCoverageBps  Int @default(0)

  // ── Risks ──
  risksTotal         Int    @default(0)
  risksOpen          Int    @default(0)
  risksMitigating    Int    @default(0)
  risksAccepted      Int    @default(0)
  risksClosed        Int    @default(0)
  risksLow           Int    @default(0)
  risksMedium        Int    @default(0)
  risksHigh          Int    @default(0)
  risksCritical      Int    @default(0)
  // KPI-card metrics. NULLABLE (not @default) so pre-existence snapshot rows
  // read NULL ("no data, don't plot") instead of a false 0 — forward-only
  // fill, no backfill. See src/lib/charts/kpi-trends.ts.
  risksAvgScore      Float?
  risksOverdueReview Int?

  // ── Evidence ──
  evidenceTotal      Int  @default(0)
  evidenceOverdue    Int  @default(0)
  evidenceDueSoon7d  Int  @default(0)
  evidenceDueSoon30d Int  @default(0)
  evidenceCurrent    Int  @default(0)
  // Status-bucket counts for the KPI cards. NULLABLE (not @default(0)) so
  // pre-existence snapshot rows read NULL ("no data, don't plot") instead of a
  // false 0 — forward-only fill, no backfill. See src/lib/charts/kpi-trends.ts.
  evidenceDraft      Int?
  evidenceSubmitted  Int?
  evidenceApproved   Int?

  // ── Policies ──
  policiesTotal         Int  @default(0)
  policiesPublished     Int  @default(0)
  policiesOverdueReview Int  @default(0)
  // Status-bucket counts for the KPI cards (nullable forward-only fill).
  policiesDraft         Int?
  policiesInReview      Int?
  policiesApproved      Int?

  // ── Tasks ──
  tasksTotal     Int  @default(0)
  tasksOpen      Int  @default(0)
  tasksOverdue   Int  @default(0)
  // Due-within-7-days count for the KPI card (nullable forward-only fill).
  tasksDueSoon7d Int?

  // ── Vendors ──
  vendorsTotal         Int  @default(0)
  vendorsOverdueReview Int  @default(0)
  // Status/criticality counts for the KPI cards (nullable forward-only fill).
  vendorsActive        Int?
  vendorsCritical      Int?

  // ── Test plans ──
  // `testPlansTotal` anchors the trim (@default(0), like every other total);
  // the status buckets are nullable forward-only fill. See kpi-trends.ts.
  testPlansTotal    Int  @default(0)
  testPlansActive   Int?
  testPlansPaused   Int?
  testPlansArchived Int?

  // ── Assets ──
  assetsTotal           Int @default(0)
  assetsActive          Int @default(0)
  assetsHighCriticality Int @default(0)
  assetsRetired         Int @default(0)

  // ── Findings ──
  findingsOpen Int @default(0)

  // ── Meta ──
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, snapshotDate])
  @@index([tenantId, snapshotDate])
  @@index([tenantId])
}

/// AI compliance-posture summary — a tenant-wide narrative + prioritized
/// advice, generated once/day by the `compliance-posture-summary` cron and
/// CACHED here so the dashboard hero reads it cheaply (never calls an LLM on
/// the render path). Degrades to a deterministic stub summary when no LLM is
/// configured, so the feature is fully functional with zero config.
///
/// Content is an AGGREGATE, non-sensitive narrative derived from already-
/// visible KPIs (coverage %, overdue counts, risk severities) — it is NOT
/// encrypted (see src/lib/security/encrypted-fields.ts) but IS sanitised on
/// write. One row per tenant (upsert by tenantId); the daily regeneration
/// makes it Operational/derived for retention. RLS-covered (carries tenantId).
model CompliancePostureSummary {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  generatedAt   DateTime @default(now())
  /// STRONG | ESTABLISHED | DEVELOPING | AT_RISK. Plain string (not an enum)
  /// so an unforeseen provider label can't hard-fail the row — the output
  /// guard clamps it into the known set before persist.
  postureLabel  String
  /// 0-100 derived maturity/health score; nullable when not computable.
  maturityScore Int?
  /// The narrative (1-3 sentences). Sanitised on write.
  summaryText   String
  /// Prioritized next actions: [{ title, detail, priority }]. Sanitised.
  adviceJson    Json     @default("[]")
  /// The aggregate metrics snapshot fed to the generator (provenance + audit).
  signalsJson   Json     @default("{}")
  /// Which provider produced this row: stub | anthropic | openrouter.
  provider      String
  /// The model id when an LLM produced it; null for the deterministic stub.
  model         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
}
