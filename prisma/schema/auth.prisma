// ─────────────────────────────────────────────────────────────────
//  GAP-09 — multi-file schema: AUTH & TENANCY
//
//  Owns:
//    • Tenant + Organization (hub-and-spoke)
//    • TenantMembership / OrgMembership / TenantCustomRole
//    • User (NextAuth Prisma adapter shape)
//    • Account / Session (NextAuth)
//    • UserSession (Epic C.3 — server-recorded session record with
//      ipAddress/userAgent/expiresAt for revocation)
//    • TenantInviteToken
//    • TenantSecuritySettings
//    • SsoConnection / ScimToken
//
//  Cross-domain relations declared here that point INTO this file:
//    • Every tenant-scoped model has a `tenant Tenant @relation(...)`
//      and a `tenantId String` — declared on the OWNING side
//      (i.e. the model's own domain file). The reverse relation field
//      on Tenant is what lives here.
//
//  Why keep all auth/tenancy together: the back-reference fields on
//  Tenant span every domain (controls, risks, evidence, …). Splitting
//  Tenant out from User/Membership would force every domain file to
//  re-import Tenant relations, scattering the join surface.
//
//  This file is currently empty. The actual auth/tenancy models live
//  in `schema.prisma` and will be relocated here as a focused PR.
// ─────────────────────────────────────────────────────────────────

model Tenant {
  id                                String                             @id @default(cuid())
  name                              String
  slug                              String                             @unique
  /// Hub-and-spoke parent (Epic O-1). Nullable for backward compatibility:
  /// existing tenants migrated before the organization layer landed have
  /// no parent. New tenants created via `/api/org/{slug}/tenants` are
  /// always linked. ON DELETE SET NULL so removing an org doesn't take
  /// its tenants with it — orphaned tenants behave like the legacy
  /// pre-org model.
  organizationId                    String?
  industry                          String?
  scope                             String?
  context                           String?
  interestedParties                 String?
  boundaries                        String?
  exclusions                        String?
  reminderDaysBefore                Int                                @default(14)
  maxRiskScale                      Int                                @default(5)
  /// Soft-delete (org admin panel "remove tenant"). When set, the
  /// tenant is filtered out of tenant resolution (getTenantContext →
  /// 404), the org portfolio list, the tenant picker, and the JWT
  /// membership claims — making it inaccessible — while the underlying
  /// data is retained for compliance + possible restore. A hard purge
  /// is a separate, deliberate operation.
  deletedAt                         DateTime?
  /// Epic B.2 — wrapped per-tenant Data Encryption Key.
  /// Shape: the existing `encryptField()` envelope (`v1:base64(...)`),
  /// wrapping a 32-byte random DEK. See `src/lib/security/tenant-keys.ts`.
  /// Nullable so existing tenants continue working until the backfill
  /// script lands. The runtime integration phase may treat `NULL` as
  /// "use the global KEK directly" (current behaviour) or generate a
  /// DEK lazily on first use.
  encryptedDek                      String?
  /// Epic B — previous wrapped DEK, retained during a per-tenant DEK
  /// rotation. Envelope: identical to `encryptedDek` — `v1:base64(...)`
  /// produced by `wrapDek()` from `src/lib/security/tenant-keys.ts`.
  ///
  /// Lifecycle: non-NULL only while a per-tenant DEK rotation is in
  /// flight (i.e. after a new DEK has been written to `encryptedDek`
  /// but before the background re-encryption job has finished
  /// rewriting every ciphertext that carried the old DEK). Once all
  /// v2:<old-dek>:... ciphertexts have been re-encrypted under the new
  /// DEK, the job clears this column back to NULL.
  ///
  /// Read-fallback: `getTenantDek` will try `encryptedDek` first and,
  /// on AES-GCM authentication failure, fall back to
  /// `previousEncryptedDek` — mirroring the master-KEK dual-key
  /// fallback in `decryptField`. (This fallback is reserved for the
  /// real implementation; the current `rotateTenantDek` stub throws.)
  ///
  /// Invariant: `previousEncryptedDek` must not equal `encryptedDek`
  /// when non-NULL. Equality would make the old and new DEKs
  /// indistinguishable on the decrypt path (silent key mixing). A DB
  /// CHECK constraint (`Tenant_previousEncryptedDek_differs`) enforces
  /// this at the storage layer so a rotation bug cannot silently
  /// produce identical values in both columns.
  previousEncryptedDek              String?
  /// Per-tenant override of the audit-readiness scoring weights.
  /// NULL means use the hardcoded defaults
  /// (ISO27001 / NIS2 / GENERIC) shipped with the platform. Shape
  /// is `{ ISO27001?: { coverage, implementation, evidence, tasks, issues },
  ///       NIS2?: { coverage, evidence, policies, issues },
  ///       GENERIC?: { coverage, evidence, issues } }`. Each
  /// inner object's weights must sum to 1.0; values outside [0,1]
  /// or sums > 1.0 are rejected at the usecase layer.
  /// Audit Coherence S5 (2026-05-22).
  readinessWeightsJson              Json?
  createdAt                         DateTime                           @default(now())
  updatedAt                         DateTime                           @updatedAt
  assets                            Asset[]
  assetRiskLinks                    AssetRiskLink[]
  audits                            Audit[]
  auditCycles                       AuditCycle[]
  auditLogs                         AuditLog[]
  auditPacks                        AuditPack[]
  auditPackItems                    AuditPackItem[]
  readinessSnapshots                ReadinessSnapshot[]
  auditPackShares                   AuditPackShare[]
  auditorAccounts                   AuditorAccount[]
  billingAccount                    BillingAccount?
  billingEvents                     BillingEvent[]
  clauseProgress                    ClauseProgress[]
  controls                          Control[]
  controlAssets                     ControlAsset[]
  controlContributors               ControlContributor[]
  controlEvidenceLinks              ControlEvidenceLink[]
  controlRequirementLinks           ControlRequirementLink[]
  frameworkRequirementOrders        FrameworkRequirementOrder[]
  controlTasks                      ControlTask[]
  controlTestEvidenceLinks          ControlTestEvidenceLink[]
  controlTestPlans                  ControlTestPlan[]
  controlTestRuns                   ControlTestRun[]
  controlTestSteps                  ControlTestStep[]
  evidence                          Evidence[]
  fileRecords                       FileRecord[]
  findings                          Finding[]
  integrationConnections            IntegrationConnection[]
  integrationExecutions             IntegrationExecution[]
  integrationWebhookEvents          IntegrationWebhookEvent[]
  notifications                     Notification[]
  notificationOutbox                NotificationOutbox[]
  policies                          Policy[]
  policyVersions                    PolicyVersion[]
  policyApprovals                   PolicyApproval[]
  reminderHistories                 ReminderHistory[]
  risks                             Risk[]
  riskControls                      RiskControl[]
  riskSuggestionItems               RiskSuggestionItem[]
  riskSuggestionSessions            RiskSuggestionSession[]
  riskMatrixConfig                  RiskMatrixConfig?
  riskAppetiteConfig                RiskAppetiteConfig?
  riskAppetiteBreaches              RiskAppetiteBreach[]
  riskSimulationRuns                RiskSimulationRun[]
  riskScenarios                     RiskScenario[]
  riskHierarchyNodes                RiskHierarchyNode[]
  riskHierarchyLinks                RiskHierarchyLink[]
  keyRiskIndicators                 KeyRiskIndicator[]
  kriReadings                       KriReading[]
  riskCorrelations                  RiskCorrelation[]
  riskSnapshots                     RiskSnapshot[]
  portfolioSnapshots                PortfolioSnapshot[]
  reportTemplates                   ReportTemplate[]
  reportRuns                        ReportRun[]
  reportSchedules                   ReportSchedule[]
  tasks                             Task[]
  taskComments                      TaskComment[]
  taskLinks                         TaskLink[]
  taskWatchers                      TaskWatcher[]
  identityProviders                 TenantIdentityProvider[]
  entraGroupMappings                TenantEntraGroupMapping[]
  invites                           TenantInvite[]
  memberships                       TenantMembership[]
  notificationSettings              TenantNotificationSettings?
  onboarding                        TenantOnboarding?
  scimTokens                        TenantScimToken[]
  securitySettings                  TenantSecuritySettings?
  identityLinks                     UserIdentityLink[]
  mfaEnrollments                    UserMfaEnrollment[]
  userNotificationPrefs             UserNotificationPreference[]
  vendors                           Vendor[]
  vendorAssessments                 VendorAssessment[]
  vendorAssessmentAnswers           VendorAssessmentAnswer[]
  // Epic G-3 — normalized vendor questionnaire templates.
  vendorAssessmentTemplates         VendorAssessmentTemplate[]
  vendorAssessmentTemplateSections  VendorAssessmentTemplateSection[]
  vendorAssessmentTemplateQuestions VendorAssessmentTemplateQuestion[]
  vendorContacts                    VendorContact[]
  vendorDocuments                   VendorDocument[]
  vendorEvidenceBundles             VendorEvidenceBundle[]
  vendorEvidenceBundleItems         VendorEvidenceBundleItem[]
  vendorLinks                       VendorLink[]
  vendorRelationships               VendorRelationship[]
  syncMappings                      IntegrationSyncMapping[]
  customRoles                       TenantCustomRole[]
  apiKeys                           TenantApiKey[]
  complianceSnapshots               ComplianceSnapshot[]
  automationRules                   AutomationRule[]
  automationExecutions              AutomationExecution[]
  // denorm-tenantId Phase 1 inverse relations.
  evidenceReviews                   EvidenceReview[]
  auditChecklistItems               AuditChecklistItem[]
  findingEvidences                  FindingEvidence[]
  findingRisks                      FindingRisk[]
  auditorPackAccesses               AuditorPackAccess[]
  // PolicyControlLink denormalisation (single-table follow-on).
  policyControlLinks                PolicyControlLink[]
  // Epic G-4 — Access Review Campaigns.
  accessReviews                     AccessReview[]
  accessReviewDecisions             AccessReviewDecision[]
  // Epic G-5 — control exception register.
  controlExceptions                 ControlException[]
  // Epic G-7 — risk treatment plans.
  riskTreatmentPlans                RiskTreatmentPlan[]
  treatmentMilestones               TreatmentMilestone[]
  // Roadmap-26 PR-A — persisted process maps (xyflow canvases).
  processMaps                       ProcessMap[]
  processNodes                      ProcessNode[]
  processEdges                      ProcessEdge[]
  processEdgeControls               ProcessEdgeControl[]
  // Epic P5-PR-A — process map snapshots.
  processMapSnapshots               ProcessMapSnapshot[]
  // Hub-and-spoke (Epic O-1).
  organization                      Organization?                      @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
}

// Hub-and-spoke organization layer (Epic O-1).
//
// An Organization is the parent of N tenants (typical: 100 solution-
// owner tenants per CISO portfolio). Org-level members come in two
// roles: ORG_ADMIN (CISO-class — gets auto-provisioned AUDITOR
// membership in every child tenant via the Epic O-2 service) and
// ORG_READER (portfolio-only, no per-tenant access).
//
// Slug is unique across the whole system, parallel to Tenant.slug.
// URL paths are `/org/{slug}` and `/t/{slug}` — the namespaces don't
// collide because the prefixes differ.
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenants                      Tenant[]
  memberships                  OrgMembership[]
  invites                      OrgInvite[]
  provisionedTenantMemberships TenantMembership[]   @relation("OrgProvisionedTenantMemberships")
  auditLogs                    OrgAuditLog[]
  dashboardWidgets             OrgDashboardWidget[]
}

// Per-user, per-org role assignment.
//
// Two roles in the OrgRole enum: ORG_ADMIN, ORG_READER. ADMIN
// becoming a member triggers the Epic O-2 auto-provisioning service
// which creates an AUDITOR `TenantMembership` in every child tenant
// (idempotent — skips users who already have a manual membership).
//
// Removing an ORG_ADMIN triggers the deprovisioning service which
// deletes only auto-created memberships (the ones with
// `provisionedByOrgId` matching this org); manually-granted
// memberships are preserved.
model OrgMembership {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole  @default(ORG_READER)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

// Epic D — invitation-gated org onboarding.
//
// Mirrors the TenantInvite model exactly (same field set, same
// lifecycle semantics) so admins can issue an invite to an email,
// the recipient lands on /invite/org/<token>, signs in via OAuth,
// and the auth callback redeems the invite to create their
// OrgMembership atomically.
//
// Lifecycle:
//   • createOrgInviteToken upserts on (organizationId, email),
//     refreshing the token + expiresAt and clearing acceptedAt /
//     revokedAt on re-invite.
//   • redeemOrgInvite uses an updateMany test-and-set on
//     {token, acceptedAt: null, revokedAt: null, expiresAt: { gt: now }}
//     so concurrent redemptions can't double-claim; email-mismatch
//     burns the token (acceptedAt is set in the same atomic claim).
//   • revokeOrgInvite sets revokedAt = now(); the row stays in place
//     for audit history.
//
// Token: 32 random bytes, base64url-encoded, stored raw with
// @unique. No HMAC — the entropy (256 bits) is the security
// boundary. A 7-day TTL is enforced on creation.
model OrgInvite {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  role           OrgRole   @default(ORG_READER)
  token          String    @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("OrgInviteInviter", fields: [invitedById], references: [id])

  @@unique([organizationId, email])
  @@index([token])
  @@index([organizationId])
}

// Epic 41 — Configurable Dashboard Widget Engine.
//
// Persists the widget composition of the org-level dashboard at
// `/org/[orgSlug]`. Each row is one widget rendered on the portfolio
// overview: a KPI tile, RAG donut, risk-trend chart, tenant-coverage
// list, or drill-down CTA group. The frontend renders strictly from
// these rows — the backend enforces shape via Zod at the API layer.
//
// Org-scoped (NOT tenant-scoped). Same shape as OrgInvite /
// OrgMembership / OrgAuditLog: `organizationId` is the foreign key,
// the global postgres role serves the queries, isolation is enforced
// by `getOrgCtx` resolving the user's OrgMembership before the
// usecase runs. Not in TENANT_SCOPED_MODELS.
//
// Position + size + config are stored as JSON. The DB enforces
// nothing about their internal shape — that's deliberate so a new
// widget type doesn't require a migration. The Zod schemas in
// `src/app-layer/schemas/org-dashboard-widget.schemas.ts` lock the
// shape per (type, chartType) and the API layer rejects payloads
// that don't fit.
model OrgDashboardWidget {
  id             String                 @id @default(cuid())
  organizationId String
  type           OrgDashboardWidgetType
  /// Sub-variant within a `type` (e.g. for KPI: 'coverage' /
  /// 'critical-risks' / 'overdue-evidence' / 'tenants'). Free-form
  /// at the schema layer; the Zod map narrows valid values per type.
  chartType      String
  /// Optional human-readable title. When null the frontend uses
  /// the widget's default title for the (type, chartType) pair.
  title          String?
  /// Per-(type, chartType) config. Locked by Zod at the API
  /// boundary; storing as JSON keeps the model open to new widget
  /// types without migrations.
  config         Json
  /// Grid position { x: int, y: int } — top-left in the
  /// react-grid-layout coordinate system.
  position       Json
  /// Grid size { w: int, h: int } — width and height in grid cells.
  size           Json
  /// True (default) renders the widget; false hides it without
  /// deleting the row, preserving position so re-enabling is
  /// non-destructive.
  enabled        Boolean                @default(true)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model TenantOnboarding {
  id             String           @id @default(cuid())
  tenantId       String           @unique
  status         OnboardingStatus @default(NOT_STARTED)
  currentStep    String           @default("COMPANY_PROFILE")
  completedSteps String[]         @default([])
  stepData       Json             @default("{}")
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
}

/// Tenant-scoped custom role with granular permission overrides.
/// Coexists with the built-in Role enum (ADMIN/EDITOR/READER/AUDITOR).
/// When a TenantMembership has a customRoleId, the permissionsJson from
/// this model takes precedence over the enum-based defaults for UI gating.
/// Backend authorization should merge/override accordingly.
model TenantCustomRole {
  id              String             @id @default(cuid())
  tenantId        String
  name            String /// Display name, e.g. "Compliance Lead"
  description     String? /// Optional description of the role's purpose
  baseRole        Role               @default(READER) /// Fallback enum role for coarse checks
  permissionsJson Json /// Typed PermissionSet — see src/lib/permissions.ts
  isActive        Boolean            @default(true) /// Soft-disable without deleting assignments
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  memberships     TenantMembership[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

/// Tenant-scoped API keys for machine-to-machine authentication.
/// Keys are stored as SHA-256 hashes — the plaintext is shown only once at creation.
/// Supports expiry, revocation, scope restrictions, and last-used tracking.
model TenantApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  name        String /// Human-friendly label, e.g. "CI/CD Pipeline"
  keyPrefix   String /// First 8 chars of the plaintext key (for identification)
  keyHash     String /// SHA-256 hash of the full plaintext key
  scopes      Json      @default("[]") /// JSON array of scope strings, e.g. ["controls:read","evidence:write"]
  expiresAt   DateTime? /// Optional expiry — null = no expiry
  revokedAt   DateTime? /// Non-null = revoked
  lastUsedAt  DateTime? /// Updated on each successful auth
  lastUsedIp  String? /// IP of last auth request
  createdById String /// User who created this key
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  createdBy   User      @relation("ApiKeyCreator", fields: [createdById], references: [id])

  @@unique([keyHash])
  @@index([tenantId])
  @@index([tenantId, revokedAt])
}

model TenantMembership {
  id                    String                 @id @default(cuid())
  tenantId              String
  userId                String
  role                  Role                   @default(READER)
  customRoleId          String? /// Optional FK to TenantCustomRole for granular overrides
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deactivatedAt         DateTime?
  invitedAt             DateTime?
  invitedByUserId       String?
  status                MembershipStatus       @default(ACTIVE)
  /// Hub-and-spoke (Epic O-1). When non-NULL, this membership was
  /// auto-created by the org auto-provisioning service in response to
  /// the user gaining ORG_ADMIN on the named Organization. The
  /// deprovisioning service deletes ONLY rows with this column set,
  /// so manually-granted ADMIN/EDITOR/READER/AUDITOR memberships
  /// survive an ORG_ADMIN removal.
  ///
  /// NULL = manually created (the historical default, preserved for
  /// every membership that existed before the org layer landed).
  ///
  /// ON DELETE SET NULL on the Organization FK so deleting the parent
  /// org doesn't delete the auto-provisioned memberships — they
  /// transition to "manually created" semantics and are kept.
  /// (The deprovision usecase is the canonical cleanup path; the FK
  /// rule is referential-integrity defence-in-depth.)
  provisionedByOrgId    String?
  customRole            TenantCustomRole?      @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  invitedBy             User?                  @relation("MembershipInviter", fields: [invitedByUserId], references: [id])
  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  user                  User                   @relation(fields: [userId], references: [id])
  provisionedByOrg      Organization?          @relation("OrgProvisionedTenantMemberships", fields: [provisionedByOrgId], references: [id], onDelete: SetNull)
  // Epic G-4 — historical decisions reviewing this membership.
  // SetNull on cascade so a membership delete doesn't erase the
  // audit trail; the decision row keeps its frozen subjectUserId +
  // snapshotRole fields and stays evidence-quality.
  accessReviewDecisions AccessReviewDecision[] @relation("AccessReviewDecisionMembership")

  @@unique([tenantId, userId])
  @@index([tenantId, status])
  @@index([customRoleId])
  @@index([provisionedByOrgId])
}

// ─────────────────────────────────────────────────────────────────
// Epic G-4 — Access Review Campaigns (SOC 2 CC6.2).
//
// Periodic certification that the right humans have the right access
// to the right tenants. An auditor's first ask in any SOC 2 Type II
// cycle is: "show me the most recent user access review and the
// signed-off decisions". The shape is deliberately campaign-flavored
// (ramp from AuditCycle), not a checklist:
//
//   • AccessReview is the campaign root. It carries the scope, the
//     review window, the reviewer identity, the deadline, and the
//     final closure timestamp.
//   • AccessReviewDecision is one row per subject user, snapshotted
//     at campaign creation (see scope semantics on AccessReviewScope).
//     It records the role/status the user had AT SNAPSHOT, the
//     reviewer's CONFIRM/REVOKE/MODIFY decision, and the eventual
//     execution timestamp when the decision is applied to the
//     underlying TenantMembership.
//
// Snapshotting is what makes the schema audit-ready: a row's
// `snapshotRole` is frozen at creation. If the membership is later
// modified or deleted (e.g. user offboarded mid-review), the
// decision row remains a faithful record of what the reviewer
// considered.
//
// Tenant isolation: both tables are Class-A direct-scoped (own
// `tenantId` column). RLS migration adds the canonical
// tenant_isolation + tenant_isolation_insert + superuser_bypass
// policies and FORCE ROW LEVEL SECURITY.
// ─────────────────────────────────────────────────────────────────

model AccessReview {
  id                   String             @id @default(cuid())
  tenantId             String
  name                 String
  description          String?
  /// Decides which memberships seed the AccessReviewDecision rows
  /// at creation. CUSTOM means the creator passes an explicit list
  /// of subject memberships; the resulting decision rows are still
  /// the authoritative scope record regardless of source.
  scope                AccessReviewScope  @default(ALL_USERS)
  /// Window the campaign covers. Used in evidence headers — auditors
  /// want "the access review for Q1 2026" not "the access review
  /// created on 2026-04-30".
  periodStartAt        DateTime?
  periodEndAt          DateTime?
  /// Single primary reviewer per campaign. Multi-reviewer campaigns
  /// are a future extension; today the API restricts decision-write
  /// to this user.
  reviewerUserId       String
  status               AccessReviewStatus @default(OPEN)
  dueAt                DateTime?
  closedAt             DateTime?
  closedByUserId       String?
  /// Set at closeout to the FileRecord holding the signed PDF
  /// evidence artifact for this campaign. Nullable because:
  ///   • OPEN / IN_REVIEW campaigns have no evidence yet.
  ///   • Closeout PDF generation can fail after decisions execute
  ///     (partial-failure path); the campaign stays CLOSED with
  ///     this null and an operator-triggered regenerate path will
  ///     populate it.
  /// SetNull on FileRecord delete so a stray evidence delete
  /// doesn't shred the campaign row.
  evidenceFileRecordId String?
  createdByUserId      String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  deletedAt            DateTime?
  deletedByUserId      String?

  tenant       Tenant                 @relation(fields: [tenantId], references: [id])
  reviewer     User                   @relation("AccessReviewReviewer", fields: [reviewerUserId], references: [id])
  createdBy    User                   @relation("AccessReviewCreator", fields: [createdByUserId], references: [id])
  closedBy     User?                  @relation("AccessReviewCloser", fields: [closedByUserId], references: [id])
  deletedBy    User?                  @relation("AccessReviewDeleter", fields: [deletedByUserId], references: [id])
  evidenceFile FileRecord?            @relation("AccessReviewEvidence", fields: [evidenceFileRecordId], references: [id], onDelete: SetNull)
  decisions    AccessReviewDecision[]

  /// Composite parent key used by AccessReviewDecision's compound FK
  /// (the same denorm-tenantId pattern Phase 2 introduced for
  /// AuditChecklistItem → Audit).
  @@unique([id, tenantId])
  @@index([tenantId, status])
  @@index([tenantId, reviewerUserId, status])
  @@index([tenantId, dueAt])
  @@index([tenantId, deletedAt])
  @@index([tenantId, createdAt])
}

model AccessReviewDecision {
  id                       String           @id @default(cuid())
  tenantId                 String
  accessReviewId           String
  /// Live FK to TenantMembership. SetNull on delete so an offboard
  /// during the review window doesn't shred the audit row — the
  /// snapshot fields below preserve the evidentiary record.
  membershipId             String?
  /// Frozen subject identity. Even if the membership row vanishes,
  /// the decision still names a real user.
  subjectUserId            String
  /// Snapshot of the membership's role + status at the moment the
  /// decision row was written. Reviewers decide against the snapshot,
  /// not against whatever the live membership currently looks like.
  snapshotRole             Role
  snapshotCustomRoleId     String?
  snapshotMembershipStatus MembershipStatus
  snapshotAt               DateTime         @default(now())

  /// Null = reviewer has not yet decided.
  decision        AccessReviewDecisionType?
  decidedAt       DateTime?
  decidedByUserId String?
  /// Free-text reviewer rationale. SOC 2 evidence — recommended for
  /// REVOKE / MODIFY, optional for CONFIRM.
  notes           String?

  /// MODIFY decisions specify a target role. Null on CONFIRM/REVOKE.
  modifiedToRole         Role?
  modifiedToCustomRoleId String?

  /// Set when the decision has been applied to the live
  /// TenantMembership (REVOKE → deactivate, MODIFY → role change,
  /// CONFIRM → no-op marker). Phase 1 leaves these null; the
  /// follow-up usecase populates them.
  executedAt       DateTime?
  executedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  accessReview AccessReview      @relation(fields: [accessReviewId, tenantId], references: [id, tenantId], onDelete: Cascade)
  membership   TenantMembership? @relation("AccessReviewDecisionMembership", fields: [membershipId], references: [id], onDelete: SetNull)
  subjectUser  User              @relation("AccessReviewDecisionSubject", fields: [subjectUserId], references: [id])
  decidedBy    User?             @relation("AccessReviewDecisionDecider", fields: [decidedByUserId], references: [id])
  executedBy   User?             @relation("AccessReviewDecisionExecutor", fields: [executedByUserId], references: [id])

  /// One decision row per (campaign, subject user). Anchored on
  /// subjectUserId rather than membershipId so a membership that's
  /// deleted-and-recreated mid-campaign still has exactly one
  /// logical decision record.
  @@unique([accessReviewId, subjectUserId])
  @@index([tenantId, accessReviewId])
  @@index([tenantId, accessReviewId, decision])
  @@index([tenantId, subjectUserId])
  @@index([tenantId, membershipId])
}

model User {
  id                            String                       @id @default(cuid())
  // GAP-21: `email` and `name` are stored encrypted at rest. The
  // schema field names map to the encrypted DB columns; the
  // pii-middleware encrypts on write and decrypts on read so
  // callers continue to pass plaintext at the API boundary.
  // `emailHash` carries the deterministic lookup hash and is the
  // sole uniqueness anchor.
  //
  // emailHash is declared optional at the schema/TS level so callers
  // who don't pass it explicitly type-check (the middleware
  // populates it from `email` on every write). The DB column is
  // NOT NULL — enforced by migration
  // 20260429000000_gap21_drop_pii_plaintext_columns + the
  // structural ratchet at
  // tests/guardrails/pii-hash-not-null.test.ts. The schema-DB
  // drift on this single field is intentional and documented.
  email                         String                       @map("emailEncrypted")
  emailHash                     String?                      @unique
  passwordHash                  String?
  name                          String?                      @map("nameEncrypted")
  emailVerified                 DateTime?
  image                         String?
  createdAt                     DateTime                     @default(now())
  updatedAt                     DateTime                     @updatedAt
  sessionVersion                Int                          @default(0)
  accounts                      Account[]
  ownedKris                     KeyRiskIndicator[]           @relation("KriOwner")
  ownedAssets                   Asset[]                      @relation("AssetOwner")
  assetRiskLinksCreated         AssetRiskLink[]              @relation("AssetRiskCreator")
  auditCyclesCreated            AuditCycle[]
  auditLogs                     AuditLog[]
  auditPacksFrozen              AuditPack[]                  @relation("AuditPackFrozenBy")
  auditSharesCreated            AuditPackShare[]
  controlApplicabilityDecisions Control[]                    @relation("ControlApplicabilityDecider")
  createdControls               Control[]                    @relation("ControlCreator")
  ownedControls                 Control[]                    @relation("ControlOwner")
  assignedFindings              Finding[]                    @relation("FindingAssignee")
  controlAssetsCreated          ControlAsset[]               @relation("ControlAssetCreator")
  controlContributions          ControlContributor[]
  controlEvidenceLinksCreated   ControlEvidenceLink[]        @relation("ControlEvidenceCreator")
  controlTaskAssignments        ControlTask[]                @relation("ControlTaskAssignee")
  testEvidenceLinksCreated      ControlTestEvidenceLink[]    @relation("TestEvidenceCreator")
  createdTestPlans              ControlTestPlan[]            @relation("TestPlanCreator")
  ownedTestPlans                ControlTestPlan[]            @relation("TestPlanOwner")
  createdTestRuns               ControlTestRun[]             @relation("TestRunCreator")
  executedTestRuns              ControlTestRun[]             @relation("TestRunExecutor")
  evidenceReviews               EvidenceReview[]
  ownedEvidence                 Evidence[]                   @relation("EvidenceOwner")
  uploadedFiles                 FileRecord[]                 @relation("FileUploader")
  notifications                 Notification[]
  ownedPolicies                 Policy[]                     @relation("PolicyOwner")
  policyAcknowledgements        PolicyAcknowledgement[]
  policyApprovals               PolicyApproval[]             @relation("PolicyApprover")
  policyApprovalRequests        PolicyApproval[]             @relation("PolicyApprovalRequester")
  policyVersionsCreated         PolicyVersion[]              @relation("PolicyVersionCreator")
  riskControlsCreated           RiskControl[]                @relation("RiskControlCreator")
  riskSuggestionSessions        RiskSuggestionSession[]      @relation("SuggestionSessionCreator")
  sessions                      AuthSession[]
  assignedTasks                 Task[]                       @relation("TaskAssignee")
  createdTasks                  Task[]                       @relation("TaskCreator")
  reviewingTasks                Task[]                       @relation("TaskReviewer")
  taskCommentsCreated           TaskComment[]                @relation("TaskCommentCreator")
  taskWatches                   TaskWatcher[]
  invitesSent                   TenantInvite[]
  invitedMemberships            TenantMembership[]           @relation("MembershipInviter")
  tenantMemberships             TenantMembership[]
  identityLinks                 UserIdentityLink[]
  mfaEnrollments                UserMfaEnrollment[]
  notificationPreferences       UserNotificationPreference[]
  ownedVendors                  Vendor[]                     @relation("VendorOwner")
  assessmentsDecided            VendorAssessment[]           @relation("AssessmentDecider")
  assessmentsRequested          VendorAssessment[]           @relation("AssessmentRequester")
  // Epic G-3 — assessment lifecycle actors.
  assessmentsSent               VendorAssessment[]           @relation("AssessmentSender")
  assessmentsReviewed           VendorAssessment[]           @relation("AssessmentReviewer")
  assessmentsClosed             VendorAssessment[]           @relation("AssessmentCloser")
  assessmentTemplatesCreated    VendorAssessmentTemplate[]   @relation("AssessmentTemplateCreator")
  vendorDocsUploaded            VendorDocument[]             @relation("VendorDocUploader")
  vendorBundlesCreated          VendorEvidenceBundle[]       @relation("EvidenceBundleCreator")
  apiKeysCreated                TenantApiKey[]               @relation("ApiKeyCreator")
  userSessions                  UserSession[]                @relation("UserSessionOwner")
  passwordResetTokens           PasswordResetToken[]         @relation("UserPasswordResetTokens")
  orgMemberships                OrgMembership[]
  orgAuditLogActions            OrgAuditLog[]                @relation("OrgAuditLogActor")
  orgAuditLogTargets            OrgAuditLog[]                @relation("OrgAuditLogTarget")
  orgInvitesIssued              OrgInvite[]                  @relation("OrgInviteInviter")
  // Epic G-4 — Access Review Campaigns. The User shows up in both
  // sides (running campaigns AND being reviewed) so the relations
  // need explicit, distinct names.
  accessReviewsAsReviewer       AccessReview[]               @relation("AccessReviewReviewer")
  accessReviewsCreated          AccessReview[]               @relation("AccessReviewCreator")
  accessReviewsClosed           AccessReview[]               @relation("AccessReviewCloser")
  accessReviewsDeleted          AccessReview[]               @relation("AccessReviewDeleter")
  accessReviewDecisionsSubject  AccessReviewDecision[]       @relation("AccessReviewDecisionSubject")
  accessReviewDecisionsDecided  AccessReviewDecision[]       @relation("AccessReviewDecisionDecider")
  accessReviewDecisionsExecuted AccessReviewDecision[]       @relation("AccessReviewDecisionExecutor")
  // Epic G-5 — control exceptions involve up to five distinct
  // user-roles per row (creator, risk-acceptor, approver, rejecter,
  // deleter). Distinct relation names so Prisma can disambiguate.
  controlExceptionsCreated      ControlException[]           @relation("ControlExceptionCreatedBy")
  controlExceptionsRiskAccepted ControlException[]           @relation("ControlExceptionRiskAcceptedBy")
  controlExceptionsApproved     ControlException[]           @relation("ControlExceptionApprovedBy")
  controlExceptionsRejected     ControlException[]           @relation("ControlExceptionRejectedBy")
  controlExceptionsDeleted      ControlException[]           @relation("ControlExceptionDeletedBy")
  // Epic G-7 — risk treatment plans. Up to four distinct user-roles
  // per plan (owner, creator, completer, deleter) plus the
  // milestone completer. Distinct relation names so Prisma can
  // disambiguate.
  riskTreatmentPlansOwned       RiskTreatmentPlan[]          @relation("RiskTreatmentPlanOwner")
  riskTreatmentPlansCreated     RiskTreatmentPlan[]          @relation("RiskTreatmentPlanCreator")
  riskTreatmentPlansCompleted   RiskTreatmentPlan[]          @relation("RiskTreatmentPlanCompleter")
  riskTreatmentPlansDeleted     RiskTreatmentPlan[]          @relation("RiskTreatmentPlanDeleter")
  treatmentMilestonesCompleted  TreatmentMilestone[]         @relation("TreatmentMilestoneCompleter")
  // Roadmap-26 PR-A — persisted process maps.
  processMapsCreated            ProcessMap[]                 @relation("ProcessMapCreatedBy")
  processMapsDeleted            ProcessMap[]                 @relation("ProcessMapDeletedBy")
  // Epic P5-PR-A — process map snapshots.
  processMapSnapshotsCreated    ProcessMapSnapshot[]         @relation("ProcessMapSnapshotCreatedBy")
}

model Account {
  id                    String  @id @default(cuid())
  userId                String
  type                  String
  provider              String
  providerAccountId     String
  refresh_token         String?
  access_token          String?
  expires_at            Int?
  token_type            String?
  scope                 String?
  id_token              String?
  session_state         String?
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Session")
}

// Epic C.3 — operational session tracking (separate from the
// NextAuth-adapter `AuthSession` table, which we leave untouched to
// avoid churning the adapter contract). One row per JWT minted by the
// `jwt` callback. Subsequent passes look this row up by `sessionId`,
// honour `revokedAt`, and update `lastActiveAt` (throttled).
//
// Privacy notes:
//   - `ipAddress` is captured from the incoming request at sign-in;
//     stored as a string (IPv4 / IPv6) so geo-IP correlation can
//     happen out-of-band. Acceptable under the existing PII model
//     because it's tied to the user's own auth event.
//   - `userAgent` is truncated to 512 chars to bound row size.
//   - Neither field is encrypted; both are operational telemetry,
//     not business content. If your threat model demands it, route
//     them through the encrypted-fields manifest later.
model UserSession {
  id            String    @id @default(cuid())
  /// Stable identifier embedded in the JWT so subsequent requests can
  /// find this row without trusting any other token claim. Min-entropy
  /// of cuid is acceptable; the token itself is signed by AUTH_SECRET
  /// so a guessed sessionId on its own does nothing.
  sessionId     String    @unique
  userId        String
  /// Tenant the user signed in against. Nullable because the very
  /// first JWT mint may precede tenant resolution (rare but possible).
  tenantId      String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  lastActiveAt  DateTime  @default(now())
  revokedAt     DateTime?
  /// Free-form attribution for the revocation (e.g. "admin:abc123" or
  /// "user:self"). Not displayed to end users; surfaced in the audit
  /// log entry.
  revokedReason String?

  user User @relation("UserSessionOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([userId, revokedAt])
  @@index([tenantId, revokedAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Password-reset tokens (forgot-password / reset-password flow).
///
/// Distinct from `VerificationToken` on purpose: a single-purpose token
/// table means a verify-email link can never be replayed as a
/// password reset (and vice versa). `tokenHash` stores the SHA-256 of
/// the raw token — the raw value lives only in the emailed link and in
/// memory on the confirm path, so a leaked DB dump cannot be replayed.
/// `usedAt` makes the token single-use; the confirm path claims it with
/// a conditional `updateMany` so concurrent submits race to one winner.
/// Not tenant-scoped (identity-level, like User / VerificationToken) so
/// it carries no `tenantId` and needs no RLS policy.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation("UserPasswordResetTokens", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model BillingAccount {
  id                   String        @id @default(cuid())
  tenantId             String        @unique
  stripeCustomerId     String        @unique
  stripeSubscriptionId String?
  plan                 BillingPlan   @default(FREE)
  status               BillingStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  tenant               Tenant        @relation(fields: [tenantId], references: [id])
}

model BillingEvent {
  id            String   @id @default(cuid())
  tenantId      String
  type          String
  stripeEventId String   @unique
  payloadJson   Json
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
}

model TenantIdentityProvider {
  id            String               @id @default(cuid())
  tenantId      String
  type          IdentityProviderType
  name          String
  isEnabled     Boolean              @default(false)
  isEnforced    Boolean              @default(false)
  emailDomains  String[]             @default([])
  configJson    Json                 @default("{}")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  identityLinks UserIdentityLink[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// EI-2 — maps an Entra ID security-group object id to an IC role. At sign-in
/// (EI-3) a user's resolved `aadGroups` are matched against these rows to sync
/// their tenant-membership role. `priority` breaks ties when a user is in
/// several mapped groups (higher wins). OWNER is intentionally not a permitted
/// target — ownership stays manually granted (see the Zod schema).
model TenantEntraGroupMapping {
  id              String   @id @default(cuid())
  tenantId        String
  /// Entra security-group object id (GUID).
  aadGroupId      String
  /// Cached Graph display name, for the admin UI only (never load-bearing).
  aadGroupName    String?
  role            Role
  /// Higher wins when a user matches multiple mappings.
  priority        Int      @default(0)
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, aadGroupId])
  @@index([tenantId])
}

model UserIdentityLink {
  id                  String                 @id @default(cuid())
  userId              String
  tenantId            String
  providerId          String
  externalSubject     String
  // GAP-21: stored encrypted at rest, mapped to the encrypted column.
  // `emailAtLinkTimeHash` is nullable in TS (middleware populates) /
  // NOT NULL in DB (migration enforced). Same drift pattern as
  // User.emailHash — see that comment for rationale.
  emailAtLinkTime     String                 @map("emailAtLinkTimeEncrypted")
  emailAtLinkTimeHash String?
  lastLoginAt         DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  provider            TenantIdentityProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  tenant              Tenant                 @relation(fields: [tenantId], references: [id])
  user                User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, externalSubject])
  @@unique([userId, providerId])
  @@index([tenantId])
  @@index([userId])
}

model TenantSecuritySettings {
  id                         String    @id @default(cuid())
  tenantId                   String    @unique
  mfaPolicy                  MfaPolicy @default(DISABLED)
  /// Hard cap on JWT lifetime in minutes. When set, every newly minted
  /// session row's `expiresAt` is min(NextAuth max-age, now + this).
  sessionMaxAgeMinutes       Int?
  /// Maximum number of concurrent active sessions allowed per user
  /// in this tenant. When reached, the oldest session (by
  /// `lastActiveAt` ASC) is revoked to make room for the new sign-in.
  /// Null = unlimited (legacy behaviour).
  maxConcurrentSessions      Int?
  /// Epic C.4 — outbound audit-event streaming.
  /// `auditStreamUrl`: HTTPS endpoint the audit streamer POSTs batched
  /// audit events to. Null disables streaming.
  /// `auditStreamSecretEncrypted`: HMAC-SHA256 secret used to sign
  /// each batch. Stored encrypted via the field-encryption manifest
  /// (added to `ENCRYPTED_FIELDS.TenantSecuritySettings`).
  auditStreamUrl             String?
  auditStreamSecretEncrypted String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  mfaFailClosed              Boolean   @default(false)
  tenant                     Tenant    @relation(fields: [tenantId], references: [id])
}

model UserMfaEnrollment {
  id                  String    @id @default(cuid())
  userId              String
  tenantId            String
  type                MfaType   @default(TOTP)
  secretEncrypted     String
  isVerified          Boolean   @default(false)
  verifiedAt          DateTime?
  lastChallengeAt     DateTime?
  backupCodesHashJson String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  tenant              Tenant    @relation(fields: [tenantId], references: [id])
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId, type])
  @@index([userId])
  @@index([tenantId])
}

model TenantInvite {
  id          String    @id @default(cuid())
  tenantId    String
  email       String
  role        Role      @default(READER)
  token       String    @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  invitedBy   User      @relation(fields: [invitedById], references: [id])
  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@index([token])
  @@index([tenantId])
}

model TenantScimToken {
  id         String    @id @default(cuid())
  tenantId   String
  label      String
  tokenHash  String    @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  tenant     Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}
