// ─────────────────────────────────────────────────────────────────
//  GAP-09 — multi-file schema: ENUMS
//
//  All shared enum declarations live in this file. Prisma enums
//  are domain-spanning (e.g. `Role` is referenced by User,
//  TenantMembership, OrgMembership, AuditorAccess, …) so keeping
//  them in one file avoids the alternative — duplicating each enum
//  to its primary domain file and risking divergence.
//
//  Migration policy:
//    • Adding a new value to an existing enum is non-breaking but
//      requires a Prisma migration (Postgres ALTER TYPE … ADD VALUE).
//    • Removing or reordering values is breaking. Plan a forward
//      migration with explicit data-migration of any rows.
//    • Renaming a value: prefer @@map() on the enum case to keep
//      the SQL value stable across rename refactors.
//
//  This file is currently empty. The actual enums live in the
//  transitional `schema.prisma` and will be relocated here in the
//  next prompt of GAP-09.
// ─────────────────────────────────────────────────────────────────

enum Role {
  /// OWNER — tenant lifecycle (delete tenant, rotate DEK, transfer
  /// ownership) + owner management (invite/remove OWNERs, assign OWNER
  /// role). Strictly superset of ADMIN. The last ACTIVE OWNER of a
  /// tenant cannot be removed or demoted (DB trigger + usecase guard).
  OWNER
  ADMIN
  EDITOR
  READER
  AUDITOR
}

/// Hub-and-spoke organization roles (Epic O-1).
///
/// Distinct from `Role` (which scopes per-tenant permissions). Org
/// roles scope portfolio-level access:
///
///   - ORG_ADMIN — manage the organization (create tenants, add/remove
///     org members, view portfolio dashboard, drill into individual
///     tenants). Triggers AUDITOR auto-provisioning into every child
///     tenant via the Epic O-2 service. CISO-class identity.
///
///   - ORG_READER — portfolio-only. Sees org summary cards but is NOT
///     auto-provisioned into child tenants. Can be elevated to
///     ORG_ADMIN later, at which point provisioning fans out
///     idempotently.
enum OrgRole {
  ORG_ADMIN
  ORG_READER
}

