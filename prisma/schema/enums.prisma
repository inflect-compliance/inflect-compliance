  MODIFY
}

/// Epic G-5 — Control Exception Register lifecycle.
///
///   REQUESTED — submitted by a control owner or risk admin; awaits
///               approver action. Default state at creation.
///   APPROVED  — risk-accepted with an explicit approver and an
///               expiry deadline (`expiresAt` non-null).
///   REJECTED  — approver declined; the original control remains
///               applicable. Terminal — a fresh REQUESTED row is
///               the path forward.
///   EXPIRED   — APPROVED row whose `expiresAt` has elapsed without
///               a renewal landing. Terminal — a renewal points to
///               this row via `renewedFromId`.
enum ControlExceptionStatus {
  REQUESTED
  APPROVED
  REJECTED
  EXPIRED
}

/// Epic G-7 — Risk Treatment Plans (ISO 27001 6.1.3).
///
/// Strategy chosen for the risk. Distinct from the legacy
/// `TreatmentDecision` enum on `Risk.treatment` — that field is the
/// quick free-text decision; this enum drives the structured plan
/// shape (milestones, deadlines, tracking).
///
///   MITIGATE — implement controls to reduce likelihood/impact
///   ACCEPT   — formally accept the residual risk (paired with
///              the Epic G-5 ControlException flow when relevant)
///   TRANSFER — shift the risk to a third party (insurance, vendor)
///   AVOID    — eliminate the activity that creates the risk
enum TreatmentStrategy {
  MITIGATE
  ACCEPT
  TRANSFER
  AVOID
}

/// Lifecycle for a structured treatment plan.
///
///   DRAFT     — plan created, not yet activated; milestones
///               can still be reordered/edited freely
///   ACTIVE    — plan is being executed; milestones gated
///   COMPLETED — every milestone is done OR plan was closed
///               with a closing remark; terminal
///   OVERDUE   — `targetDate` elapsed without COMPLETED status;
///               set by the daily monitor job, not the user paths
enum TreatmentPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  OVERDUE
}

/// Roadmap-26 PR-A — Process Map lifecycle.
///
///   DRAFT    — being authored, not yet published. Default for
///              every new map.
///   ACTIVE   — published / canonical. The map represents the
///              current understanding of the process.
///   ARCHIVED — historical / superseded. Hidden from default
///              list views; still readable for audit context.
enum ProcessMapStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// VR-2 — canvas surface mode. DOCUMENT = process-map flowcharts (existing);
// AUTOMATION = the visual rule editor (AutomationRule nodes on canvas).
enum ProcessCanvasMode {
  DOCUMENT
  AUTOMATION
}

/// Control automation classification (operator-set on the control).
///   AUTOMATED            — runs without human action.
///   MANUAL               — performed entirely by a person.
///   IT_DEPENDENT_MANUAL  — a manual control that relies on
///                          system-generated information/reports.
enum ControlAutomationType {
  AUTOMATED
  MANUAL
  IT_DEPENDENT_MANUAL
}

/// Risk-mitigation nature of a control (how it acts on a risk).
enum ControlMitigationType {
  PREVENTIVE
  DETECTIVE
  DETERRENT
  CORRECTIVE
  COMPENSATING
}

/// RQ2-1 — what a RiskScoreEvent records.
///   INHERENT — the pre-controls likelihood/impact assessment.
///   RESIDUAL — the post-controls assessment (asserted or derived).
enum RiskScoreEventKind {
  INHERENT
  RESIDUAL
}

/// RQ2-1 — provenance of a score change. Distinguishable forever:
///   USER      — a human entered/edited the values directly.
///   DERIVED   — the system computed it (e.g. control-effectiveness
///               suggestion accepted as-is, RQ2-2).
///   PLAN      — written by treatment-plan completion.
///   AI        — accepted from an AI suggestion.
///   MIGRATION — backfilled from pre-provenance data.
enum RiskScoreEventSource {
  USER
  DERIVED
  PLAN
  AI
  MIGRATION
}

enum LossEventSource {
  /// Recorded by a person (manual entry on the loss-event register).
  USER
  /// Recorded from a finding's close-out — the actual loss that
  /// finding ended up costing.
  FINDING
  /// Recorded from an incident / ticket — the realised cost the
  /// incident closed at.
  INCIDENT
}

/// Data-residency regions a Tenant can be assigned to. A value here is
/// NOT automatically available — only regions also listed in
/// OPERATIONALLY_PROVISIONED_REGIONS (src/lib/regions.ts) are accepted at
/// provision time. An enum value without provisioned infrastructure is a
/// declared-but-unavailable region (the data-residency-foundation ratchet
/// enforces every value is either provisioned or has a documented plan).
enum TenantRegion {
  US_EAST_1
  EU_WEST_1
  AP_SOUTHEAST_1
}

/// DSAR request type — GDPR Art. 15 (export) vs Art. 17 (erasure).
enum DataSubjectRequestType {
  EXPORT
  ERASURE
}

/// DSAR workflow state. RECEIVED → VERIFIED (email click) → IN_PROGRESS
/// (job running) → COMPLETED, or → REJECTED (see rejectionReason).
enum DataSubjectRequestStatus {
  RECEIVED
  VERIFIED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

/// NIS2 Article 23 incident severity. Four-level scale; HIGH/CRITICAL
/// is the default heuristic that SUGGESTS (never asserts) a reporting
/// obligation — the tenant's DPO/legal makes the final call.
enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// The seven-phase NIS2 incident-response flow (+ CLOSED terminal).
/// DETECTION → CLASSIFICATION → EARLY_WARNING → CONTAINMENT →
/// INVESTIGATION → DETAILED_REPORT → RECOVERY → CLOSED.
/// Methodology adapted (CC BY 4.0) from Kshreenath/NIS2-Checklist
/// (Paolo Carner / BARE Consulting).
enum IncidentPhase {
  DETECTION
  CLASSIFICATION
  EARLY_WARNING
  CONTAINMENT
  INVESTIGATION
  DETAILED_REPORT
  RECOVERY
  CLOSED
}

/// The three Article 23 regulatory notification milestones, each with a
/// deadline derived from the incident's detectedAt: early warning within
/// 24h, detailed report within 72h, final report within 1 month.
enum IncidentNotificationKind {
  EARLY_WARNING_24H
  DETAILED_72H
  FINAL_1MONTH
}

/// Notification deadline state. PENDING → DUE (deadline approaching) →
/// OVERDUE (deadline passed, not submitted — the loud one) or SUBMITTED.
/// NOT_REQUIRED when the tenant determines this milestone does not apply.
enum IncidentNotificationStatus {
  PENDING
  DUE
  OVERDUE
  SUBMITTED
  NOT_REQUIRED
}

/// EU AI Act (Regulation (EU) 2024/1689) — the role a tenant plays for an AI
/// system. Providers develop/place a system on the market (Art 16/17 duties);
/// deployers use one under their authority (Art 26/27 duties).
enum AiDeploymentRole {
  PROVIDER
  DEPLOYER
}

/// EU AI Act risk tier. PROHIBITED (Art 5) > HIGH (Art 6 + Annex III) >
/// LIMITED (Art 50 transparency) > MINIMAL (Art 95 voluntary). Strict
/// precedence; see src/lib/eu-ai-act/classification.ts.
enum AiRiskTier {
  PROHIBITED
  HIGH
  LIMITED
  MINIMAL
}

/// Lifecycle state of a registered AI system.
enum AiSystemStatus {
  ACTIVE
  RETIRED
}

/// AI Guard enforcement posture, per tenant, stored on
/// TenantSecuritySettings.aiGuardMode. Resolves the action the AI
/// injection/egress guard applies to a non-clean verdict:
///   STRICT   — block the model call / drop the proposed action on a
///              malicious input verdict or a secret-leak egress hit.
///   BALANCED — (default) allow but flag + force human review; a secret
///              leak in outbound content is still blocked.
///   AUDIT    — log only; never enforce (deliberate triage opt-in).
enum AiGuardMode {
  STRICT
  BALANCED
  AUDIT
}

/// AI decision human-oversight outcome (EU AI Act Art 14). PENDING until a
/// human acts on the suggestion; then a one-way transition to a terminal state.
enum AiHumanOutcome {
  PENDING
  ACCEPTED
  EDITED
  REJECTED
}

/// Per-tenant AI-residency posture (AI sovereignty / DS-1). EXTERNAL (default)
/// allows the configured external provider; LOCAL_ONLY is a HARD invariant —
/// inference MUST stay on the tenant's local gateway and MUST NOT reach an
/// external provider. See src/app-layer/ai/risk-assessment/index.ts.
enum AiResidency {
  EXTERNAL
  LOCAL_ONLY
}
