/// Epic G-4 — Access Review Campaigns (SOC 2 CC6.2).
///
/// `scope` decides which TenantMemberships get snapshotted into
/// AccessReviewDecision rows at campaign creation. CUSTOM lets the
/// creator hand-pick the subject list at creation time; the
/// authoritative scope record is always the set of decision rows.
enum AccessReviewScope {
  ALL_USERS
  ADMIN_ONLY
  CUSTOM
}

/// Lifecycle for an access review campaign.
///   OPEN      — created + snapshotted, awaiting reviewer
///   IN_REVIEW — at least one decision recorded, not all complete
///   CLOSED    — finalized; decisions are immutable from here on
enum AccessReviewStatus {
  OPEN
  IN_REVIEW
  CLOSED
}

/// Per-user reviewer decision.
///   CONFIRM — keep access as-is
///   REVOKE  — deactivate the membership
///   MODIFY  — change role/customRole (target captured on the
///             AccessReviewDecision row)
enum AccessReviewDecisionType {
  CONFIRM
  REVOKE
  MODIFY
}

/// Epic G-5 — Control Exception Register lifecycle.
///
///   REQUESTED — submitted by a control owner or risk admin; awaits
///               approver action. Default state at creation.
///   APPROVED  — risk-accepted with an explicit approver and an
///               expiry deadline (`expiresAt` non-null).
///   REJECTED  — approver declined; the original control remains
///               applicable. Terminal — a fresh REQUESTED row is
///               the path forward.
///   EXPIRED   — APPROVED row whose `expiresAt` has elapsed without
///               a renewal landing. Terminal — a renewal points to
///               this row via `renewedFromId`.
enum ControlExceptionStatus {
  REQUESTED
  APPROVED
  REJECTED
  EXPIRED
}

/// Epic G-7 — Risk Treatment Plans (ISO 27001 6.1.3).
///
/// Strategy chosen for the risk. Distinct from the legacy
/// `TreatmentDecision` enum on `Risk.treatment` — that field is the
/// quick free-text decision; this enum drives the structured plan
/// shape (milestones, deadlines, tracking).
///
///   MITIGATE — implement controls to reduce likelihood/impact
///   ACCEPT   — formally accept the residual risk (paired with
///              the Epic G-5 ControlException flow when relevant)
///   TRANSFER — shift the risk to a third party (insurance, vendor)
///   AVOID    — eliminate the activity that creates the risk
enum TreatmentStrategy {
  MITIGATE
  ACCEPT
  TRANSFER
  AVOID
}

/// Lifecycle for a structured treatment plan.
///
///   DRAFT     — plan created, not yet activated; milestones
///               can still be reordered/edited freely
///   ACTIVE    — plan is being executed; milestones gated
///   COMPLETED — every milestone is done OR plan was closed
///               with a closing remark; terminal
///   OVERDUE   — `targetDate` elapsed without COMPLETED status;
///               set by the daily monitor job, not the user paths
enum TreatmentPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  OVERDUE
}

/// Roadmap-26 PR-A — Process Map lifecycle.
///
///   DRAFT    — being authored, not yet published. Default for
///              every new map.
///   ACTIVE   — published / canonical. The map represents the
