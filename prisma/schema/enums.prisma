  VENDOR_RENEWAL_DIGEST
  // Epic G-3 — outbound questionnaire invitation. Body carries the
  // external access URL with the raw token (the only place the raw
  // token ever appears in the system).
  VENDOR_ASSESSMENT_INVITATION
  // Epic G-3 prompt 8 — admin-triggered resend of the same
  // invitation; reuses the existing token, dedupes per-day.
  VENDOR_ASSESSMENT_REMINDER
  // Auto-fired from submitResponse → notifies the assessment
  // requester that an external respondent has submitted answers.
  VENDOR_ASSESSMENT_SUBMITTED
  // Auto-fired from reviewAssessment → notifies the vendor owner
  // (or requester) that internal review is complete.
  VENDOR_ASSESSMENT_REVIEWED
  // Epic G-4 — daily reminder to the campaign reviewer when the
  // campaign is approaching its dueAt with pending decisions.
  // Deduped per-day per-(tenant, type, email, campaign) by the
  // outbox unique constraint.
  ACCESS_REVIEW_REMINDER
  // Audit Coherence S7 (2026-05-24) — escalation fired when a
  // campaign is more than ESCALATION_DAYS past `dueAt`. Reviewer
  // already has the daily reminder; this nudges tenant ADMIN/OWNER
  // recipients so they can intervene (reassign, force-close, or
  // chase the reviewer). Same per-day dedupe shape as the reviewer
  // reminder.
  ACCESS_REVIEW_OVERDUE_ESCALATION
  // Epic G-5 — control exception approaching expiry. Fires at the
  // 30 / 14 / 7 day calendar windows before `expiresAt`. Per-day
  // dedupe at the outbox layer prevents double-fires; the
  // calendar-day trigger condition is the spam guard.
  EXCEPTION_EXPIRING
}

