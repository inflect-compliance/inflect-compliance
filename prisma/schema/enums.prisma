enum NotificationType {
  EVIDENCE_DUE_SOON
  EVIDENCE_OVERDUE
  EVIDENCE_REJECTED
  EVIDENCE_APPROVED
  POLICY_APPROVAL_NEEDED
  POLICY_ACKNOWLEDGED
  FINDING_ASSIGNED
  FINDING_VERIFIED
  TASK_ASSIGNED
  // 2026-05-27 — fired by `setControlOwner` (mutations.ts) when
  // ownership transfers. Mirrors the TASK_ASSIGNED contract:
  // one in-app notification per (control, new owner, day) pair,
  // routed to the bell. Email + SSE follow the same dedup.
  CONTROL_ASSIGNED
  // 2026-05-30 — fired by `updateRisk` / `updateAsset` when the
  // `ownerUserId` ("Assigned to") changes. Same one-per-(entity,
  // owner, day) bell contract as CONTROL_ASSIGNED.
  RISK_ASSIGNED
  ASSET_ASSIGNED
  // Fired by the `task-due-notification` job at 08:00 UTC. One
  // notification per task at each of three reminder windows — one
  // week before, one day before, and on the calendar day the
  // task's `dueAt` falls. In-app only — the email deadline digest
  // already covers the same surface.
  TASK_DUE
  // Audit Coherence S6 (2026-05-22) — daily cron sweeps vendors
  // whose `nextReviewAt` has passed and fires one of these per
  // overdue vendor (routed to the vendor's `ownerUserId`). Bumps
  // the date forward by the cadence so the reminder isn't spam.
  VENDOR_REVIEW_DUE
  // NIS2 Article 23 deadline clock (incident-notification-deadlines job).
  // INCIDENT_DEADLINE_DUE fires when a 24h/72h/1-month deadline enters
  // its lead window; INCIDENT_DEADLINE_OVERDUE is the loud one — a
  // regulatory deadline lapsed without a filed report. Routed to the
  // incident owner + tenant OWNER/ADMINs, deduped per (deadline, day).
  INCIDENT_DEADLINE_DUE
  INCIDENT_DEADLINE_OVERDUE
  // Continuous vendor monitoring (vendor-monitoring job). Fired when a
  // monitored vendor's posture changes — a breach appears in a feed, a
  // parsed SOC 2 / cert attestation expires, or a reassessment is
  // triggered. Routed to the vendor's `ownerUserId`, deduped per
  // (vendor, signal, day).
  VENDOR_POSTURE_ALERT
  GENERAL
}

