# NextAuth
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
AUTH_SECRET="your-secret-key-here-must-be-min-16-chars" # pragma: allowlist secret — placeholder
JWT_SECRET="your-secret-key-here-must-be-min-16-chars" # pragma: allowlist secret — placeholder

# Database (PgBouncer connection pooling)
# Runtime queries go through PgBouncer on port 5433 (pooled, transaction mode).
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/inflect_compliance?schema=public&pgbouncer=true"
# Direct Postgres connection on port 5434 for Prisma migrations/introspection.
DIRECT_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5434/inflect_compliance?schema=public"

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret" # pragma: allowlist secret — placeholder
MICROSOFT_CLIENT_ID="your-microsoft-client-id"
MICROSOFT_CLIENT_SECRET="your-microsoft-client-secret" # pragma: allowlist secret — placeholder
MICROSOFT_TENANT_ID="common"

# File Storage
UPLOAD_DIR="./uploads"

# API & Security
CORS_ALLOWED_ORIGINS="http://localhost:3000,https://production-app.com"

# Rate Limiting
# RATE_LIMIT_ENABLED="1"
# RATE_LIMIT_MODE="memory" # use 'upstash' in prod
# UPSTASH_REDIS_REST_URL="https://your-upstash-url"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Data Encryption — REQUIRED in production (GAP-03 enforced).
# Production startup runs three checks in `src/env.ts` and
# `src/instrumentation.ts`: presence + length + functional sentinel
# (encrypt → decrypt round-trip). Boot exits 1 if any fail.
#
# Local dev: leave UNSET to use the in-source dev fallback (logged
# as a WARN on every server start). Set this if you want to
# round-trip encrypted columns from a real prod backup locally.
#
# Generate a real key with:  openssl rand -base64 48
# DATA_ENCRYPTION_KEY="your-encryption-key-min-32-chars"

# Redis (caching, jobs, async coordination)
# docker compose up -d redis  →  available at localhost:6379
REDIS_URL="redis://127.0.0.1:6379"
